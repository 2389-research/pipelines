workflow SprintExecStandard
  goal: "Execute one sprint from a SPRINT-NNN.md doc — pure gpt-5.4, no hybrid. Baseline cost measurement."
  start: Implement
  exit: Done

  defaults
    provider: openai
    fidelity: summary:low

  agent Implement
    label: "Implement Sprint (Standard)"
    model: gpt-5.4
    provider: openai
    max_turns: 25
    reasoning_effort: high
    prompt:
      You are working in `run.working_dir`.

      Read the sprint document: find the file matching .ai/sprints/SPRINT-*.md
      (or if only one sprint file exists, use that).

      Implement everything in the sprint's DoD end-to-end:
      - Read the Scope, Expected Artifacts, and DoD sections
      - Set up the project (install deps, create directories)
      - Write all files listed under Expected Artifacts
      - Write tests as specified in the DoD
      - Run the validation commands from the Validation section
      - Fix any failures until all tests pass
      - Update the DoD checklist: mark completed items with [x]

      When done, report: files written, test results, token-efficient summary.

  agent Done
    label: "Done"
    model: gpt-5.4
    provider: openai
    prompt:
      Sprint execution complete (standard).

  edges
    Implement -> Done    when ctx.outcome = fail
    Implement -> Done
