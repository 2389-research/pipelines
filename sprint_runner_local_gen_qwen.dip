workflow SprintRunnerLocalGenQwen
  goal: "Loop through .ai/ledger.tsv executing every pending sprint with the local-gen pattern. Each sprint: qwen3.6:35b-a3b-q8_0 generates files, runs tests, fixes locally, escalates to gpt-5.4 only on local exhaustion. Per-sprint commit. Stops on first sprint that does not converge."
  start: Start
  exit: Exit

  defaults
    provider: openai
    fidelity: summary:medium
    max_restarts: 50

  tool Start
    label: Start
    timeout: 5s
    command:
      printf 'runner-started'

  tool Exit
    label: Exit
    timeout: 5s
    command:
      printf 'runner-complete'

  tool check_ledger
    label: "Check Ledger"
    timeout: 10s
    command:
      set -eu
      if [ ! -f .ai/ledger.tsv ]; then
        printf 'no_ledger'
        exit 0
      fi
      target=$(awk -F '\t' 'NR>1 && $3!~/^completed$/ && $3!~/^skipped$/{print $1; exit}' .ai/ledger.tsv)
      if [ -z "$target" ]; then
        printf 'all_done'
        exit 0
      fi
      printf '%s' "$target" > .ai/current_sprint_id.txt
      printf 'next-%s' "$target"

  tool no_ledger_exit
    label: "No Ledger Found"
    timeout: 5s
    command:
      echo "No .ai/ledger.tsv found. Run spec_to_sprints.dip or tools/init-ledger.sh first."
      printf 'no-ledger'

  tool mark_in_progress
    label: "Mark In Progress"
    timeout: 10s
    command:
      set -eu
      target=$(cat .ai/current_sprint_id.txt)
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      awk -F '\t' -v OFS='\t' -v target="$target" -v now="$now" '
      NR==1 {print; next}
      { if ($1==target) { $3="in_progress"; $5=now }; print }
      ' .ai/ledger.tsv > .ai/ledger.tsv.tmp
      mv .ai/ledger.tsv.tmp .ai/ledger.tsv
      printf 'in_progress-%s' "$target"

  tool Setup
    label: "Install deps + reset per-sprint counters"
    timeout: 120s
    command:
      set -eu
      SPRINT_ID=$(cat .ai/current_sprint_id.txt)
      SPRINT_DOC=".ai/sprints/SPRINT-${SPRINT_ID}.md"
      if [ ! -f "$SPRINT_DOC" ]; then echo "missing $SPRINT_DOC"; exit 1; fi
      rm -f .ai/local_fix_attempts .ai/local_exhausted
      PROJ_ROOT=$(cat .ai/proj_root.txt 2>/dev/null || echo .)
      if [ -d "$PROJ_ROOT" ]; then cd "$PROJ_ROOT"; fi
      if [ -f go.mod ]; then
        go mod tidy 2>/dev/null || true
      elif [ -f package.json ]; then
        npm install 2>/dev/null || true
      elif [ -f pyproject.toml ] || [ -f requirements.txt ]; then
        uv sync --all-extras 2>/dev/null || true
      fi
      printf 'setup-done'

  tool Generate
    label: "Generate all files (qwen3.6:35b-a3b-q8_0, one Ollama call per file)"
    timeout: 600s
    command:
      set -e
      SPRINT_ID=$(cat .ai/current_sprint_id.txt)
      SPRINT_DOC=".ai/sprints/SPRINT-${SPRINT_ID}.md"
      SPRINT=$(cat "$SPRINT_DOC")
      OLLAMA=http://localhost:11434/api/chat
      SYS="You are a code generator. Output only the raw file content. No explanation, no markdown fences, no commentary."

      gen_file() {
        local filepath="$1"
        local description="$2"
        local max_tokens="${3:-4096}"
        local user_msg="CONTRACT (full spec):\n\n${SPRINT}\n\nGENERATE THIS FILE: ${filepath}\n${description}\n\nOutput ONLY the raw file content. Nothing else."
        echo "generating ${filepath}..."
        mkdir -p "$(dirname "${filepath}")" 2>/dev/null || true
        curl -sf "${OLLAMA}" \
          -H 'Content-Type: application/json' \
          --data "$(jq -n \
            --arg sys "${SYS}" \
            --arg msg "${user_msg}" \
            --argjson tokens "${max_tokens}" \
            '{model:"qwen3.6:35b-a3b-q8_0",think:false,stream:false,
              messages:[{role:"system",content:$sys},{role:"user",content:$msg}],
              options:{temperature:1.0,top_p:0.95,top_k:64,num_ctx:32768,num_predict:$tokens}}')" \
          | jq -r '.message.content' \
          > "${filepath}"
        echo "wrote ${filepath} ($(wc -c < "${filepath}") bytes)"
        validate_and_retry "${filepath}"
      }

      patch_file() {
        local filepath="$1"
        local max_tokens="${2:-4096}"
        local current
        current=$(cat "${filepath}")
        local user_msg="CONTRACT (full spec):\n\n${SPRINT}\n\nEXISTING FILE: ${filepath}\n\n${current}\n\nApply ONLY the modifications described for ${filepath} in the sprint spec under '## Modified files'. Output the complete updated file. Nothing else."
        echo "patching ${filepath}..."
        mkdir -p "$(dirname "${filepath}")" 2>/dev/null || true
        curl -sf "${OLLAMA}" \
          -H 'Content-Type: application/json' \
          --data "$(jq -n \
            --arg sys "${SYS}" \
            --arg msg "${user_msg}" \
            --argjson tokens "${max_tokens}" \
            '{model:"qwen3.6:35b-a3b-q8_0",think:false,stream:false,
              messages:[{role:"system",content:$sys},{role:"user",content:$msg}],
              options:{temperature:0.2,top_p:0.95,top_k:64,num_ctx:32768,num_predict:$tokens}}')" \
          | jq -r '.message.content' \
          | sed '/^```/d' \
          > "${filepath}"
        echo "patched ${filepath} ($(wc -c < "${filepath}") bytes)"
        validate_and_retry "${filepath}"
      }

      syntax_check() {
        local fp="$1"
        case "$fp" in
          *.go)      gofmt -e "$fp" 2>&1 >/dev/null | head -5 ;;
          *.py)      python3 -m py_compile "$fp" 2>&1 | head -5 ;;
          *.ts|*.js) node --check "$fp" 2>&1 | head -5 ;;
        esac
      }

      validate_and_retry() {
        local fp="$1"
        local attempt=0
        while [ $attempt -lt 2 ]; do
          local err
          err=$(syntax_check "$fp")
          [ -z "$err" ] && return 0
          attempt=$((attempt + 1))
          echo "syntax error in $fp (retry $attempt/2): $err"
          local line_num
          line_num=$(echo "$err" | grep -oE ':[0-9]+:' | head -1 | tr -d ':')
          local context=""
          if [ -n "$line_num" ]; then
            local start=$((line_num - 3))
            [ "$start" -lt 1 ] && start=1
            local end=$((line_num + 3))
            context=$(awk "NR>=$start && NR<=$end {printf \"%d: %s\n\", NR, \$0}" "$fp")
          fi
          local current
          current=$(cat "$fp")
          local fixed
          fixed=$(curl -sf "${OLLAMA}" \
            -H 'Content-Type: application/json' \
            --data "$(jq -n \
              --arg file "$current" \
              --arg err "$err" \
              --arg ctx "$context" \
              --arg path "$fp" \
              '{model:"qwen3.6:35b-a3b-q8_0",think:false,stream:false,
                messages:[
                  {role:"system",content:"Output ONLY the corrected file content. No markdown fences. No explanation."},
                  {role:"user",content:("File "+$path+" has a syntax error:\n\n"+$err+"\n\nContext around error:\n"+$ctx+"\n\nFull file:\n"+$file+"\n\nOutput the corrected file only.")}
                ],
                options:{temperature:0.1,num_ctx:32768}}')" \
            | jq -r '.message.content' | sed '/^```/d')
          [ -z "$fixed" ] && return 0
          echo "$fixed" > "$fp"
          echo "syntax-retry $attempt: rewrote $fp"
        done
        echo "warning: $fp may still have syntax errors after 2 retries"
      }

      # New files — generate only if file does not exist
      NEW_FILES=$(awk '/^## New files/{f=1;next} f && /^##/{exit} f{print}' \
        "$SPRINT_DOC" | sed -nE 's/^[[:space:]]*-[[:space:]]+`([^`]+)`.*/\1/p' || true)
      for filepath in $NEW_FILES; do
        if [ ! -f "${filepath}" ]; then
          gen_file "${filepath}" \
            'Implement exactly as specified in the sprint. Use the Interface contract, Algorithm notes, Imports per file, and Test plan sections for this file.' \
            4096
        else
          echo "skipping ${filepath} (already exists)"
        fi
      done

      # Modified files — read existing, apply targeted changes
      MOD_FILES=$(awk '/^## Modified files/{f=1;next} f && /^##/{exit} f{print}' \
        "$SPRINT_DOC" | sed -nE 's/^[[:space:]]*-[[:space:]]+`([^`]+)`.*/\1/p' || true)
      for filepath in $MOD_FILES; do
        patch_file "${filepath}" 4096
      done

      # Fallback: sprint uses old ## Expected Artifacts format (no New/Modified split)
      if [ -z "$NEW_FILES" ] && [ -z "$MOD_FILES" ]; then
        ARTIFACTS=$(awk '/^## Expected Artifacts/{f=1;next} f && /^##/{exit} f{print}' \
          "$SPRINT_DOC" | sed -nE 's/^[[:space:]]*-[[:space:]]+`([^`]+)`.*/\1/p' || true)
        for filepath in $ARTIFACTS; do
          gen_file "${filepath}" \
            'Implement exactly as specified in the sprint. Use the Interface contract, Algorithm notes, Imports per file, and Test plan sections for this file.' \
            4096
        done
      fi

      if [ -f go.mod ]; then go mod tidy 2>/dev/null || true; fi
      printf 'gen-done'

  tool RunTests
    label: "Run Tests"
    timeout: 120s
    command:
      set +e
      mkdir -p .ai
      WORKSPACE_ROOT=$(pwd)
      PROJ_ROOT=$(cat .ai/proj_root.txt 2>/dev/null || echo .)
      if [ -d "$PROJ_ROOT" ]; then cd "$PROJ_ROOT"; fi
      if [ -f go.mod ]; then
        go test ./... 2>&1 | tee "$WORKSPACE_ROOT/.ai/last_test_output.txt"
        code=${PIPESTATUS[0]}
      elif [ -f package.json ]; then
        npm test 2>&1 | tee "$WORKSPACE_ROOT/.ai/last_test_output.txt"
        code=${PIPESTATUS[0]}
      elif [ -f pyproject.toml ] || [ -f requirements.txt ]; then
        uv run pytest 2>&1 | tee "$WORKSPACE_ROOT/.ai/last_test_output.txt"
        code=${PIPESTATUS[0]}
      else
        echo "no test runner detected" | tee "$WORKSPACE_ROOT/.ai/last_test_output.txt"
        code=1
      fi
      if [ $code -eq 0 ]; then
        printf 'tests-pass'
      elif [ -f "$WORKSPACE_ROOT/.ai/local_exhausted" ]; then
        printf 'tests-fail-cloud'
      else
        printf 'tests-fail'
      fi

  tool LocalFix
    label: "Local fix (qwen3.6:35b-a3b-q8_0)"
    timeout: 300s
    command:
      set +e
      mkdir -p .ai
      OLLAMA=http://localhost:11434/api/chat
      WORKSPACE_ROOT=$(pwd)
      SPRINT_ID=$(cat .ai/current_sprint_id.txt)
      SPRINT_DOC=".ai/sprints/SPRINT-${SPRINT_ID}.md"
      SPRINT=$(cat "$SPRINT_DOC")
      TEST_OUT=$(cat .ai/last_test_output.txt)
      PROJ_ROOT=$(cat .ai/proj_root.txt 2>/dev/null || echo .)
      if [ -d "$PROJ_ROOT" ]; then cd "$PROJ_ROOT"; fi

      syntax_check() {
        local fp="$1"
        case "$fp" in
          *.go)      gofmt -e "$fp" 2>&1 >/dev/null | head -5 ;;
          *.py)      python3 -m py_compile "$fp" 2>&1 | head -5 ;;
          *.ts|*.js) node --check "$fp" 2>&1 | head -5 ;;
        esac
      }

      validate_and_retry() {
        local fp="$1"
        local attempt=0
        while [ $attempt -lt 2 ]; do
          local err
          err=$(syntax_check "$fp")
          [ -z "$err" ] && return 0
          attempt=$((attempt + 1))
          echo "syntax error in $fp (retry $attempt/2): $err"
          local line_num
          line_num=$(echo "$err" | grep -oE ':[0-9]+:' | head -1 | tr -d ':')
          local context=""
          if [ -n "$line_num" ]; then
            local start=$((line_num - 3))
            [ "$start" -lt 1 ] && start=1
            local end=$((line_num + 3))
            context=$(awk "NR>=$start && NR<=$end {printf \"%d: %s\n\", NR, \$0}" "$fp")
          fi
          local current
          current=$(cat "$fp")
          local fixed
          fixed=$(curl -sf "$OLLAMA" \
            -H 'Content-Type: application/json' \
            --data "$(jq -n \
              --arg file "$current" \
              --arg err "$err" \
              --arg ctx "$context" \
              --arg path "$fp" \
              '{model:"qwen3.6:35b-a3b-q8_0",think:false,stream:false,
                messages:[
                  {role:"system",content:"Output ONLY the corrected file content. No markdown fences. No explanation."},
                  {role:"user",content:("File "+$path+" has a syntax error:\n\n"+$err+"\n\nContext around error:\n"+$ctx+"\n\nFull file:\n"+$file+"\n\nOutput the corrected file only.")}
                ],
                options:{temperature:0.1,num_ctx:32768}}')" \
            | jq -r '.message.content' | sed '/^```/d')
          [ -z "$fixed" ] && return 0
          echo "$fixed" > "$fp"
          echo "syntax-retry $attempt: rewrote $fp"
        done
        echo "warning: $fp may still have syntax errors after 2 retries"
      }

      attempts=$(cat "$WORKSPACE_ROOT/.ai/local_fix_attempts" 2>/dev/null || echo 0)
      attempts=$((attempts + 1))
      echo $attempts > "$WORKSPACE_ROOT/.ai/local_fix_attempts"
      echo "local fix attempt $attempts/4"

      if [ "$attempts" -gt 4 ] || [ -f "$WORKSPACE_ROOT/.ai/local_exhausted" ]; then
        touch "$WORKSPACE_ROOT/.ai/local_exhausted"
        echo "local model exhausted, handing off to cloud"
        printf 'local-exhausted'
        exit 0
      fi

      if [ -f go.mod ]; then
        FILE_LIST=$(find . -name "*.go" -not -path "*/vendor/*" 2>/dev/null | sort)
      elif [ -f package.json ]; then
        FILE_LIST=$(find . \( -name "*.ts" -o -name "*.js" \) -not -path "*/node_modules/*" 2>/dev/null | sort)
      elif [ -f pyproject.toml ] || [ -f requirements.txt ]; then
        FILE_LIST=$(find . -name "*.py" -not -path "*/__pycache__/*" -not -path "*/.venv/*" 2>/dev/null | sort)
      else
        FILE_LIST=$(find . -type f -not -path "*/.git/*" -not -path "*/.ai/*" 2>/dev/null | sort)
      fi

      MANIFEST_FULL="$WORKSPACE_ROOT/.ai/scaffolding_manifest.txt"
      MANIFEST_LOCAL_TMP=""
      if [ -f "$MANIFEST_FULL" ] && [ -s "$MANIFEST_FULL" ]; then
        MANIFEST_LOCAL_TMP=$(mktemp -t scaffolding_local.XXXXXX)
        if [ "$PROJ_ROOT" = "." ] || [ -z "$PROJ_ROOT" ]; then
          sed 's|^|./|' "$MANIFEST_FULL" > "$MANIFEST_LOCAL_TMP"
        else
          sed -E "s|^${PROJ_ROOT}/||" "$MANIFEST_FULL" | sed 's|^|./|' > "$MANIFEST_LOCAL_TMP"
        fi
        FILE_LIST=$(echo "$FILE_LIST" | grep -vxFf "$MANIFEST_LOCAL_TMP" || true)
        FORBIDDEN_BLOCK=$(cat "$MANIFEST_LOCAL_TMP")
      else
        FORBIDDEN_BLOCK=""
      fi

      pick_file() {
        local extra_forbidden="$1"
        local sysmsg="You are a code debugger. Output ONLY the relative file path of the source file that needs to be fixed. One path only. No explanation, no punctuation."
        if [ -n "$FORBIDDEN_BLOCK" ] || [ -n "$extra_forbidden" ]; then
          sysmsg="${sysmsg}\n\nThe following files are SCAFFOLDING and are pinned by the architect. You MUST NOT pick any of them under any circumstance:\n${FORBIDDEN_BLOCK}\n${extra_forbidden}\n\nIf the failure appears to involve a scaffolding file, pick the test file or the closest non-scaffolding caller instead."
        fi
        curl -sf "$OLLAMA" \
          -H 'Content-Type: application/json' \
          --data "$(jq -n \
            --arg sprint "$SPRINT" \
            --arg test_out "$TEST_OUT" \
            --arg files "$FILE_LIST" \
            --arg sysmsg "$sysmsg" \
            '{model:"qwen3.6:35b-a3b-q8_0",think:false,stream:false,
              messages:[
                {role:"system",content:$sysmsg},
                {role:"user",content:("TEST FAILURE:\n\n"+$test_out+"\n\nAVAILABLE SOURCE FILES (scaffolding files have been removed):\n"+$files+"\n\nSPRINT SPEC:\n\n"+$sprint+"\n\nWhich source file needs to be fixed? Output only the relative file path.")}
              ],
              options:{temperature:0.1,num_ctx:32768}}')" \
          | jq -r '.message.content' | tr -d ' \n'
      }

      is_manifest_path() {
        local p="$1"
        [ -z "$MANIFEST_LOCAL_TMP" ] && return 1
        [ ! -s "$MANIFEST_LOCAL_TMP" ] && return 1
        grep -Fxq "$p" "$MANIFEST_LOCAL_TMP" 2>/dev/null
      }

      WHICH_FILE=""
      EXTRA_FORBIDDEN=""
      for picker_try in 1 2; do
        WHICH_FILE=$(pick_file "$EXTRA_FORBIDDEN")
        echo "picker attempt $picker_try: model identified: $WHICH_FILE"
        if [ -z "$WHICH_FILE" ] || [ ! -f "$WHICH_FILE" ]; then
          break
        fi
        if is_manifest_path "$WHICH_FILE"; then
          echo "qwen picked manifest file $WHICH_FILE — re-prompting with extended forbidden list"
          EXTRA_FORBIDDEN="${EXTRA_FORBIDDEN}${WHICH_FILE}\n"
          WHICH_FILE=""
          continue
        fi
        break
      done

      if [ -z "$WHICH_FILE" ] || [ ! -f "$WHICH_FILE" ]; then
        echo "picker failed to identify a non-scaffolding target, escalating"
        [ -n "$MANIFEST_LOCAL_TMP" ] && rm -f "$MANIFEST_LOCAL_TMP"
        printf 'local-exhausted'
        exit 0
      fi

      if is_manifest_path "$WHICH_FILE"; then
        echo "BLOCKED: qwen attempted to write to manifest file $WHICH_FILE — refusing, escalating"
        [ -n "$MANIFEST_LOCAL_TMP" ] && rm -f "$MANIFEST_LOCAL_TMP"
        printf 'local-exhausted'
        exit 0
      fi

      FILE_CONTENT=$(cat "$WHICH_FILE")
      FIXED=$(curl -sf "$OLLAMA" \
        -H 'Content-Type: application/json' \
        --data "$(jq -n \
          --arg sprint "$SPRINT" \
          --arg test_out "$TEST_OUT" \
          --arg file "$FILE_CONTENT" \
          --arg path "$WHICH_FILE" \
          '{model:"qwen3.6:35b-a3b-q8_0",think:false,stream:false,
            messages:[
              {role:"system",content:"You are a code fixer. Output ONLY the corrected file content. No explanation, no markdown fences, no commentary."},
              {role:"user",content:("The file "+$path+" has a bug causing test failures:\n\n"+$test_out+"\n\n---\nSPRINT SPEC:\n\n"+$sprint+"\n\n---\nCURRENT FILE:\n\n"+$file+"\n\nOutput the corrected "+$path+" only.")}
            ],
            options:{temperature:0.2,num_ctx:32768}}')" \
        | jq -r '.message.content')

      if [ -z "$FIXED" ]; then
        echo "model returned empty response, escalating"
        printf 'local-exhausted'
        exit 0
      fi

      if is_manifest_path "$WHICH_FILE"; then
        echo "BLOCKED at write: $WHICH_FILE is a manifest file — refusing, escalating"
        [ -n "$MANIFEST_LOCAL_TMP" ] && rm -f "$MANIFEST_LOCAL_TMP"
        printf 'local-exhausted'
        exit 0
      fi

      echo "$FIXED" | sed '/^```/d' > "$WHICH_FILE"
      echo "wrote fix to $WHICH_FILE ($(wc -l < "$WHICH_FILE") lines)"
      validate_and_retry "$WHICH_FILE"
      [ -n "$MANIFEST_LOCAL_TMP" ] && rm -f "$MANIFEST_LOCAL_TMP"
      printf 'local-fixed'

  tool Audit
    label: "Audit Sprint DoD (shell)"
    timeout: 30s
    command:
      set +e
      mkdir -p .ai
      WORKSPACE_ROOT=$(pwd)
      SPRINT_ID=$(cat .ai/current_sprint_id.txt)
      sprint="$WORKSPACE_ROOT/.ai/sprints/SPRINT-${SPRINT_ID}.md"
      AUDIT_OUT="$WORKSPACE_ROOT/.ai/last_audit_output.txt"
      PROJ_ROOT=$(cat .ai/proj_root.txt 2>/dev/null || echo .)
      if [ -d "$PROJ_ROOT" ]; then cd "$PROJ_ROOT"; fi
      fail=0

      in_section=0
      while IFS= read -r line; do
        if echo "$line" | grep -qE '^## Expected Artifacts'; then
          in_section=1; continue
        fi
        if [ "$in_section" -eq 1 ] && echo "$line" | grep -qE '^##'; then
          break
        fi
        if [ "$in_section" -eq 1 ]; then
          path=$(echo "$line" | grep -oE '`[^`]+`' | head -1 | tr -d '`')
          if [ -n "$path" ] && echo "$path" | grep -q '/'; then
            check_path="$path"
            case "$path" in "$PROJ_ROOT/"*) check_path="${path#$PROJ_ROOT/}" ;; esac
            if [ ! -f "$check_path" ]; then
              echo "MISSING artifact: $path" | tee -a "$AUDIT_OUT"
              fail=1
            fi
          fi
        fi
      done < "$sprint"

      if [ -f go.mod ]; then
        sprint_tests=$(awk '/^## Test plan/{f=1;next} f && /^##/{exit} f{print}' "$sprint" \
          | grep -cE "^func Test" 2>/dev/null || echo 0)
        actual_tests=$(grep -rE "^func Test" . --include="*.go" 2>/dev/null | wc -l | tr -d ' ')
      elif [ -f package.json ]; then
        sprint_tests=$(awk '/^## Test plan/{f=1;next} f && /^##/{exit} f{print}' "$sprint" \
          | grep -cE "^\s*(describe|it|test)\(" 2>/dev/null || echo 0)
        actual_tests=$(grep -rE "^\s*(describe|it|test)\(" . --include="*.ts" --include="*.js" 2>/dev/null | wc -l | tr -d ' ')
      elif [ -f pyproject.toml ] || [ -f requirements.txt ]; then
        sprint_tests=$(awk '/^## Test plan/{f=1;next} f && /^##/{exit} f{print}' "$sprint" \
          | grep -cE "^def test_" 2>/dev/null || echo 0)
        actual_tests=$(grep -rE "^def test_" . --include="*.py" 2>/dev/null | wc -l | tr -d ' ')
      else
        sprint_tests=0
        actual_tests=0
      fi

      if [ -z "$actual_tests" ]; then actual_tests=0; fi
      echo "test count: sprint=$sprint_tests actual=$actual_tests" | tee -a "$AUDIT_OUT"
      if [ "$actual_tests" -lt "$sprint_tests" ]; then
        echo "MISMATCH: sprint has $sprint_tests tests, found $actual_tests" \
          | tee -a "$AUDIT_OUT"
        fail=1
      fi

      if [ "$fail" -eq 0 ]; then printf 'audit-pass'; else printf 'audit-fail'; fi

  agent CloudFix
    label: "Cloud fix fallback (gpt-5.4 — single-session iterative)"
    model: gpt-5.4
    provider: openai
    max_turns: 25
    reasoning_effort: medium
    timeout: 1200s
    fallback_target: Escalate
    prompt:
      Tests are failing in the project. The local model (qwen3.6:35b-a3b-q8_0)
      attempted fixes for 4 iterations and could not converge. You have ONE
      session to drive tests to green — iterate within this session, do NOT
      stop after a single fix.

      Project layout:
      - The project root contains a subdirectory whose name is in
        `.ai/proj_root.txt` (e.g. `backend`). cd into it before running tests.
      - `.ai/last_test_output.txt` holds the most recent pytest output that
        triggered your invocation.
      - `.ai/last_audit_output.txt` holds the most recent audit output (read
        this if you were called for audit-fail rather than tests-fail).
      - `.ai/scaffolding_manifest.txt` lists architect-pinned files.
        ALL paths in that manifest are FROZEN — do not modify any of them.
        If a fix appears to require modifying scaffolding, fix the algorithmic
        callers instead, or report Escalate-class diagnosis.

      Loop within this single session:
      1. cat .ai/last_test_output.txt (and last_audit_output.txt if relevant).
         Identify the FIRST error class. Read the project subdirectory from
         .ai/proj_root.txt.
      2. cat the source file(s) that produce that error.
      3. apply_patch a targeted fix.
      4. cd into the project subdirectory and run pytest yourself
         (e.g. `cd backend && uv run pytest -x --tb=short 2>&1 | tail -80`).
      5. Read pytest output. If green, you are done — output a one-line
         summary and stop. If still failing, GOTO 1 with the new top error.

      Rules:
      - Iterate to green within this session. The pipeline does NOT call you
        again on failure — converge here or escalate.
      - When the same error appears in multiple places, fix all instances at once.
      - Skip the scaffolding manifest. If a manifest file is the root cause,
        stop and emit a one-line escalation note explaining what scaffolding
        choice is wrong (do not edit it).

      Tools available: bash, apply_patch, read.

  tool CommitSprint
    label: "Commit Sprint Work"
    timeout: 30s
    command:
      set -eu
      SPRINT_ID=$(cat .ai/current_sprint_id.txt)
      if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "no git repo in $(pwd) — skipping commit for sprint ${SPRINT_ID}"
        printf 'commit-skipped-no-git'
        exit 0
      fi
      SPRINT_DOC=".ai/sprints/SPRINT-${SPRINT_ID}.md"
      TITLE=$(grep -m1 '^#' "$SPRINT_DOC" \
        | sed -E 's/^#+[[:space:]]*//' \
        | sed -E "s/^SPRINT-${SPRINT_ID}:?[[:space:]]*//" \
        | tr -d '\n' \
        | head -c 100)
      [ -z "$TITLE" ] && TITLE="implement sprint ${SPRINT_ID}"
      git add -A
      if git diff --cached --quiet; then
        echo "no changes to commit for sprint ${SPRINT_ID}"
        printf 'commit-skipped'
        exit 0
      fi
      git commit -m "feat(sprint-${SPRINT_ID}): ${TITLE}"
      git log --oneline -1
      printf 'commit-done'

  tool Escalate
    label: "Escalate — could not converge"
    timeout: 5s
    command:
      echo "Sprint did not converge after local and cloud fix attempts."
      printf 'escalated'

  tool mark_complete
    label: "Complete Sprint"
    timeout: 10s
    command:
      set -eu
      target=$(cat .ai/current_sprint_id.txt)
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      awk -F '\t' -v OFS='\t' -v target="$target" -v now="$now" '
      NR==1 {print; next}
      { if ($1==target) { $3="completed"; $5=now }; print }
      ' .ai/ledger.tsv > .ai/ledger.tsv.tmp
      mv .ai/ledger.tsv.tmp .ai/ledger.tsv
      printf 'completed-%s' "$target"

  tool report_progress
    label: "Report Progress"
    timeout: 10s
    command:
      set -eu
      total=$(awk -F '\t' 'NR>1' .ai/ledger.tsv | wc -l | tr -d ' ')
      done=$(awk -F '\t' 'NR>1 && ($3=="completed" || $3=="skipped")' .ai/ledger.tsv | wc -l | tr -d ' ')
      if [ "$total" -gt 0 ]; then
        pct=$((done * 100 / total))
      else
        pct=0
      fi
      printf 'progress-%s-of-%s-%spct' "$done" "$total" "$pct"

  human sprint_gate
    label: "Continue to Next Sprint?"

  tool skip_gate
    label: "Skip Gate"
    timeout: 5s
    command:
      set -eu
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      target=$(cat .ai/current_sprint_id.txt 2>/dev/null || echo "unknown")
      printf 'continue\t%s\t%s\n' "$target" "$now"

  edges
    Start -> check_ledger
    check_ledger -> Exit            when ctx.tool_stdout = all_done       label: all_done
    check_ledger -> no_ledger_exit  when ctx.tool_stdout = no_ledger      label: no_ledger
    check_ledger -> mark_in_progress when ctx.tool_stdout != all_done     label: next_sprint
    no_ledger_exit -> Exit
    mark_in_progress -> Setup
    Setup -> Generate
    Generate -> RunTests
    RunTests -> LocalFix            when ctx.tool_stdout contains tests-fail
    RunTests -> Escalate            when ctx.tool_stdout contains tests-fail-cloud
    RunTests -> Audit               when ctx.tool_stdout contains tests-pass
    RunTests -> Audit
    LocalFix -> RunTests            when ctx.tool_stdout contains local-fixed       restart: true
    LocalFix -> CloudFix            when ctx.tool_stdout contains local-exhausted
    Audit -> CommitSprint           when ctx.tool_stdout contains audit-pass
    Audit -> CloudFix               when ctx.tool_stdout contains audit-fail        restart: true
    CloudFix -> RunTests            when ctx.outcome = success                      restart: true
    CloudFix -> RunTests            when ctx.outcome = fail                         restart: true
    CloudFix -> Escalate
    Escalate -> Exit
    CommitSprint -> mark_complete
    mark_complete -> report_progress
    report_progress -> sprint_gate
    sprint_gate -> skip_gate        label: "[S] Continue"
    sprint_gate -> Exit             label: "[A] Pause"
    skip_gate -> check_ledger       restart: true
