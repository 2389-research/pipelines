{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://2389-research.github.io/pipelines/dev_loop/plan.schema.json",
  "title": "Plan",
  "description": "Output of the PlanMinimalPRs agent. The minimal PR(s) the implementer will produce for the selected issue.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "issue_number",
    "branch_name",
    "pr_title",
    "pr_body",
    "changes",
    "risk_class",
    "test_strategy"
  ],
  "properties": {
    "issue_number": {
      "type": "integer",
      "minimum": 1
    },
    "branch_name": {
      "type": "string",
      "pattern": "^(feat|fix|chore|docs|refactor|test)/[a-z0-9][a-z0-9_./-]*$",
      "maxLength": 100
    },
    "pr_title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 80,
      "description": "Conventional Commits prefix recommended."
    },
    "pr_body": {
      "type": "string",
      "minLength": 50,
      "description": "Markdown body. Should reference the issue and lay out the change plan."
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action", "summary"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": ["create", "modify", "delete"]
          },
          "summary": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "estimated_diff_loc": {
      "type": "integer",
      "minimum": 0
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "test_strategy": {
      "type": "string",
      "minLength": 20,
      "description": "How the implementer will verify correctness: tests added/modified, manual probes, repo gates run."
    }
  }
}
