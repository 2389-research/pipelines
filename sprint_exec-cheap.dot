digraph SprintExecCheap {
  graph [
    goal="Execute the next incomplete sprint using cheap models (Haiku, GPT-5.4 Nano, Gemini Flash-Lite) with retry loops and escalation to Sonnet on failure.",
    rankdir=LR,
    default_max_retry=0,
    default_fidelity="summary:low"
  ];

  Start [shape=Mdiamond, label="Start"];
  Exit [shape=Msquare, label="Exit"];

  // === DISCOVERY ===

  EnsureLedger [
    shape=parallelogram,
    label="Ensure Ledger",
    tool_command="set -eu\nmkdir -p .ai .ai/drafts .ai/sprints\nif [ ! -f .ai/ledger.tsv ]; then\n  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)\n  printf 'sprint_id\\ttitle\\tstatus\\tcreated_at\\tupdated_at\\n001\\tBootstrap sprint\\tplanned\\t%s\\t%s\\n' \"$now\" \"$now\" > .ai/ledger.tsv\nfi\nprintf 'ledger-ready'"
  ];

  FindNextSprint [
    shape=box,
    label="Find Next Sprint",
    llm_provider="gemini",
    llm_model="gemini-3.1-flash-lite-preview",
    reasoning_effort="medium",
    prompt="Identify the next non-completed sprint in .ai/ledger.tsv and summarize the target sprint ID and why it is next."
  ];

  SetCurrentSprint [
    shape=parallelogram,
    label="Set Current Sprint",
    tool_command="set -eu\ntarget=$(awk -F '\\t' 'NR>1 && $3!~/^completed$/ && $3!~/^skipped$/{print $1; exit}' .ai/ledger.tsv)\nif [ -z \"$target\" ]; then\n  target=$(awk -F '\\t' 'NR>1 && $3!~/^completed$/{print $1; exit}' .ai/ledger.tsv)\nfi\nif [ -z \"$target\" ]; then\n  target=$(awk -F '\\t' 'END{print $1}' .ai/ledger.tsv)\nfi\nprintf '%s' \"$target\" > .ai/current_sprint_id.txt\nprintf 'current-%s' \"$target\""
  ];

  ReadSprint [
    shape=box,
    label="Read Sprint",
    llm_provider="gemini",
    llm_model="gemini-3.1-flash-lite-preview",
    reasoning_effort="medium",
    prompt="Read the target sprint document under .ai/sprints/SPRINT-<id>.md and summarize requirements, DoD checklist status, and expected artifacts."
  ];

  MarkInProgress [
    shape=parallelogram,
    label="Mark In Progress",
    tool_command="set -eu\ntarget=$(cat .ai/current_sprint_id.txt)\nnow=$(date -u +%Y-%m-%dT%H:%M:%SZ)\nawk -F '\\t' -v OFS='\\t' -v target=\"$target\" -v now=\"$now\" '\nNR==1 {print; next}\n{ if ($1==target) { $3=\"in_progress\"; $5=now }; print }\n' .ai/ledger.tsv > .ai/ledger.tsv.tmp\nmv .ai/ledger.tsv.tmp .ai/ledger.tsv\nprintf 'in_progress-%s' \"$target\""
  ];

  // === CHEAP IMPLEMENTATION LANE ===

  ImplementCheap [
    shape=box,
    label="Implement Sprint\n(Haiku — Cheap)",
    llm_provider="anthropic",
    llm_model="claude-haiku-4-5",
    reasoning_effort="high",
    fidelity="summary:medium",
    prompt="Implement the sprint requirements end-to-end using minimal, focused changes. If prior review/critique/squad context exists, treat those findings as required fixes. Update the sprint doc checklist as work is completed, and provide a concrete summary of changes and validation evidence."
  ];

  ValidateBuild [
    shape=parallelogram,
    label="Validate Build and Tests",
    tool_command="set -eu\nif [ -f Package.swift ]; then\n  swift build >/tmp/sprint-exec-build.log 2>&1\n  swift test >/tmp/sprint-exec-test.log 2>&1 || true\n  cat /tmp/sprint-exec-build.log\n  cat /tmp/sprint-exec-test.log\n  if rg -n 'error:' /tmp/sprint-exec-build.log >/dev/null 2>&1; then exit 1; fi\n  if rg -n 'failed' /tmp/sprint-exec-test.log >/dev/null 2>&1; then exit 1; fi\n  printf 'validation-pass-swift'\n  exit 0\nfi\nif [ -f package.json ]; then\n  npm test >/tmp/sprint-exec-test.log 2>&1 || { cat /tmp/sprint-exec-test.log; exit 1; }\n  printf 'validation-pass-node'\n  exit 0\nfi\nif [ -f pyproject.toml ]; then\n  uv run pytest >/tmp/sprint-exec-test.log 2>&1 || { cat /tmp/sprint-exec-test.log; exit 1; }\n  printf 'validation-pass-python'\n  exit 0\nfi\nprintf 'validation-pass-no-known-build-system'"
  ];

  CommitCheap [
    shape=box,
    label="Commit Sprint Work\n(Nano — Cheap)",
    llm_provider="openai",
    llm_model="gpt-5.4-nano",
    reasoning_effort="medium",
    prompt="Prepare and execute a clean commit for sprint implementation changes if there are staged/unstaged changes. If no changes are present, report that no commit was needed. Include commit hash in your summary."
  ];

  // === REVIEW SQUADS ===

  SquadParallel [shape=component, label="Review Squads\n(Parallel)"];

  PracticalDev [
    shape=box,
    label="Squad: Practical Dev\n(Haiku)",
    llm_provider="anthropic",
    llm_model="claude-haiku-4-5",
    reasoning_effort="medium",
    fidelity="summary:medium",
    prompt="You are a pragmatic mid-level developer picking up this sprint's work for the first time. Review the implementation for: does it actually work as specified? Are there obvious bugs or missing pieces? Does the code flow make sense? Check the sprint doc checklist against what was actually delivered. Be concrete — cite files and line numbers."
  ];

  Nitpicker [
    shape=box,
    label="Squad: Nitpicker\n(Nano)",
    llm_provider="openai",
    llm_model="gpt-5.4-nano",
    reasoning_effort="medium",
    fidelity="summary:medium",
    prompt="You are an obsessively detail-oriented code reviewer. Find every edge case that isn't handled, every naming inconsistency, every missing validation, every code smell. You care about error paths, boundary conditions, and things that will break at 2am. Rank findings by severity."
  ];

  FreshEyes [
    shape=box,
    label="Squad: Fresh Eyes\n(Flash-Lite)",
    llm_provider="gemini",
    llm_model="gemini-3.1-flash-lite-preview",
    reasoning_effort="medium",
    fidelity="summary:medium",
    prompt="You have never seen this codebase before. Read the sprint output cold and report: what's confusing? What assumptions does the code make that aren't documented? What would trip up a new contributor? Focus on readability, structure, and whether the code is self-explanatory."
  ];

  SquadJoin [shape=tripleoctagon, label="Squad Join"];

  // === REVIEWS + CROSS-CRITIQUE ===

  ReviewParallel [shape=component, label="Reviews\n(Parallel)"];

  ReviewHaiku [
    shape=box,
    label="Haiku Review",
    llm_provider="anthropic",
    llm_model="claude-haiku-4-5",
    reasoning_effort="medium",
    fidelity="summary:medium",
    prompt="Review sprint execution using squad findings as additional context. Evaluate: sprint doc checklist completion, implementation correctness, and validation evidence. Return clear PASS/FAIL reasoning and required fixes."
  ];

  ReviewNano [
    shape=box,
    label="Nano Review",
    llm_provider="openai",
    llm_model="gpt-5.4-nano",
    reasoning_effort="medium",
    fidelity="summary:medium",
    prompt="Review sprint execution using squad findings as additional context. Evaluate: implementation quality, regression risk, and checklist completeness. Return clear PASS/FAIL reasoning and required fixes."
  ];

  ReviewsJoin [shape=tripleoctagon, label="Reviews Join"];

  CrossCritiqueParallel [shape=component, label="Cross-Critiques\n(Parallel)"];

  HaikuCritiqueNano [
    shape=box,
    label="Haiku Critique\nof Nano Review",
    llm_provider="anthropic",
    llm_model="claude-haiku-4-5",
    reasoning_effort="medium",
    fidelity="summary:low",
    prompt="Critique the Nano review for missing checks, weak evidence, or mistaken conclusions."
  ];

  NanoCritiqueHaiku [
    shape=box,
    label="Nano Critique\nof Haiku Review",
    llm_provider="openai",
    llm_model="gpt-5.4-nano",
    reasoning_effort="medium",
    fidelity="summary:low",
    prompt="Critique the Haiku review for missing checks, weak evidence, or mistaken conclusions."
  ];

  CritiquesJoin [shape=tripleoctagon, label="Critiques Join"];

  // === CHEAP GATE ===

  GateCheap [
    shape=box,
    label="Gate (Haiku — Cheap)",
    llm_provider="anthropic",
    llm_model="claude-haiku-4-5",
    reasoning_effort="high",
    goal_gate=true,
    max_retries=3,
    retry_target="ImplementCheap",
    prompt="Synthesize all squad findings, reviews, and critiques into one verdict. Return success only if sprint is truly complete and checklist is satisfied. Return retry if rework is needed with specific fix instructions. Return fail if blocked by issues beyond implementation scope."
  ];

  // === RESCUE LANE ===

  ImplementRescue [
    shape=box,
    label="Implement Sprint\n(Sonnet — Rescue)",
    llm_provider="anthropic",
    llm_model="claude-sonnet-4-6",
    reasoning_effort="high",
    fidelity="summary:high",
    prompt="ESCALATION: Cheap implementation failed after multiple attempts. You have all prior context — squad findings, review critiques, gate verdicts, and implementation history. Fix the remaining issues definitively. This is the last attempt before failure."
  ];

  ValidateRescue [
    shape=parallelogram,
    label="Validate Rescue Build",
    tool_command="set -eu\nif [ -f Package.swift ]; then\n  swift build >/tmp/sprint-exec-build.log 2>&1\n  swift test >/tmp/sprint-exec-test.log 2>&1 || true\n  cat /tmp/sprint-exec-build.log\n  cat /tmp/sprint-exec-test.log\n  if rg -n 'error:' /tmp/sprint-exec-build.log >/dev/null 2>&1; then exit 1; fi\n  if rg -n 'failed' /tmp/sprint-exec-test.log >/dev/null 2>&1; then exit 1; fi\n  printf 'validation-pass-swift'\n  exit 0\nfi\nif [ -f package.json ]; then\n  npm test >/tmp/sprint-exec-test.log 2>&1 || { cat /tmp/sprint-exec-test.log; exit 1; }\n  printf 'validation-pass-node'\n  exit 0\nfi\nif [ -f pyproject.toml ]; then\n  uv run pytest >/tmp/sprint-exec-test.log 2>&1 || { cat /tmp/sprint-exec-test.log; exit 1; }\n  printf 'validation-pass-python'\n  exit 0\nfi\nprintf 'validation-pass-no-known-build-system'"
  ];

  CommitRescue [
    shape=box,
    label="Commit Rescue Work\n(Nano)",
    llm_provider="openai",
    llm_model="gpt-5.4-nano",
    reasoning_effort="medium",
    prompt="Prepare and execute a clean commit for rescue implementation changes if there are staged/unstaged changes. If no changes are present, report that no commit was needed. Include commit hash in your summary."
  ];

  RescueReview [
    shape=box,
    label="Rescue Sanity Check\n(Haiku)",
    llm_provider="anthropic",
    llm_model="claude-haiku-4-5",
    reasoning_effort="medium",
    fidelity="summary:medium",
    prompt="Quick sanity check on the rescue implementation. Verify the Sonnet rescue addressed the issues that caused cheap implementation to fail. Return PASS if the sprint checklist is satisfied, FAIL if critical issues remain."
  ];

  // === TERMINAL ===

  CompleteSprint [
    shape=parallelogram,
    label="Complete Sprint",
    tool_command="set -eu\ntarget=$(cat .ai/current_sprint_id.txt)\nnow=$(date -u +%Y-%m-%dT%H:%M:%SZ)\nawk -F '\\t' -v OFS='\\t' -v target=\"$target\" -v now=\"$now\" '\nNR==1 {print; next}\n{ if ($1==target) { $3=\"completed\"; $5=now }; print }\n' .ai/ledger.tsv > .ai/ledger.tsv.tmp\nmv .ai/ledger.tsv.tmp .ai/ledger.tsv\nprintf 'completed-%s' \"$target\""
  ];

  FailureSummary [
    shape=box,
    label="Failure Summary\n(Nano)",
    llm_provider="openai",
    llm_model="gpt-5.4-nano",
    reasoning_effort="medium",
    prompt="Summarize why sprint execution failed across both cheap and rescue lanes. Include: what was attempted, what failed, what remains unresolved, and concrete next steps for recovery."
  ];

  // === EDGES: Discovery ===
  Start -> EnsureLedger;
  EnsureLedger -> FindNextSprint;
  FindNextSprint -> SetCurrentSprint;
  SetCurrentSprint -> ReadSprint;
  ReadSprint -> MarkInProgress;

  // === EDGES: Cheap Implementation ===
  MarkInProgress -> ImplementCheap;
  ImplementCheap -> ValidateBuild;
  ValidateBuild -> CommitCheap [condition="outcome=success", label="validated"];
  ValidateBuild -> ImplementCheap [condition="outcome=fail", label="fix_validation"];

  // === EDGES: Fail-safes ===
  FindNextSprint -> FailureSummary [style=dashed, color=red];
  ReadSprint -> FailureSummary [style=dashed, color=red];
  CommitCheap -> FailureSummary [style=dashed, color=red];
  CommitRescue -> FailureSummary [style=dashed, color=red];
  ImplementRescue -> FailureSummary [style=dashed, color=red];

  // === EDGES: Review Squads ===
  CommitCheap -> SquadParallel;
  SquadParallel -> PracticalDev;
  SquadParallel -> Nitpicker;
  SquadParallel -> FreshEyes;
  PracticalDev -> SquadJoin;
  Nitpicker -> SquadJoin;
  FreshEyes -> SquadJoin;

  // === EDGES: Reviews + Cross-Critique ===
  SquadJoin -> ReviewParallel;
  ReviewParallel -> ReviewHaiku;
  ReviewParallel -> ReviewNano;
  ReviewHaiku -> ReviewsJoin;
  ReviewNano -> ReviewsJoin;
  ReviewsJoin -> CrossCritiqueParallel;
  CrossCritiqueParallel -> HaikuCritiqueNano;
  CrossCritiqueParallel -> NanoCritiqueHaiku;
  HaikuCritiqueNano -> CritiquesJoin;
  NanoCritiqueHaiku -> CritiquesJoin;

  // === EDGES: Cheap Gate ===
  CritiquesJoin -> GateCheap;
  GateCheap -> CompleteSprint [condition="outcome=success", label="pass"];
  GateCheap -> ImplementCheap [condition="outcome=retry", label="rework"];
  GateCheap -> ImplementRescue [condition="outcome=fail", label="escalate"];

  // === EDGES: Rescue Lane ===
  ImplementRescue -> ValidateRescue;
  ValidateRescue -> CommitRescue [condition="outcome=success", label="rescue_validated"];
  ValidateRescue -> FailureSummary [condition="outcome=fail", label="rescue_failed"];
  CommitRescue -> RescueReview;
  RescueReview -> CompleteSprint [condition="outcome=success", label="rescue_pass"];
  RescueReview -> FailureSummary [condition="outcome=fail", label="rescue_fail"];

  // === EDGES: Terminal ===
  CompleteSprint -> Exit;
  FailureSummary -> Exit;
}
