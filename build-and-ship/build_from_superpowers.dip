workflow BuildFromSuperpowers
  goal: "The project described in the superpowers spec is fully built, tested, and committed — every task in the plan completed with passing tests"
  start: find_superpowers
  exit: done

  defaults
    model: claude-sonnet-4-6
    provider: anthropic
    max_retries: 3
    max_restarts: 20

  tool find_superpowers
    label: "Find Superpowers Spec + Plan"
    timeout: 30s
    command:
      #!/bin/sh
      spec=""
      plan=""
      if [ -d docs/superpowers/specs ]; then
        for f in docs/superpowers/specs/*.md; do
          [ -f "$f" ] && spec="$f" && break
        done
      fi
      if [ -d docs/superpowers/plans ]; then
        for f in docs/superpowers/plans/*.md; do
          [ -f "$f" ] && plan="$f" && break
        done
      fi
      if [ -z "$spec" ] || [ -z "$plan" ]; then
        printf 'missing_files'
      else
        printf 'ready'
      fi

  agent setup_project
    label: "Setup Project and Analyze Plan"
    model: claude-opus-4-6
    reasoning_effort: high
    goal_gate: true
    max_retries: 3
    retry_target: setup_project
    fallback_target: done
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Read the superpowers spec and plan. Set up the project and create a progress tracker.

      ## Process
      1. Find the spec in docs/superpowers/specs/*.md and plan in docs/superpowers/plans/*.md
      2. Read both files completely
      3. Execute Task 1 from the plan (Project Scaffolding) — follow every step exactly
      4. Create docs/plans/progress.md with this format:

      ```
      # Build Progress

      ## Tech Stack
      [extracted from spec]

      ## Infrastructure
      [any emulators/services needed for testing, with start commands]

      ## Tasks
      - [x] Task 1: [Name] — completed during setup
      - [ ] Task 2: [Name]
      - [ ] Task 3: [Name]
      ...list ALL tasks from the plan...
      ```

      5. Commit: git add -A && git commit -m 'feat: project scaffolding and progress tracker'

      ## Success Criteria
      - Project scaffolding from Task 1 is complete
      - docs/plans/progress.md exists with all tasks listed
      - Task 1 is marked [x], all others are [ ]
      - go build / npm run build / uv run python -c "pass" succeeds (language-dependent)

  tool check_setup
    label: "Check Setup Complete"
    timeout: 30s
    command:
      #!/bin/sh
      if [ -f docs/plans/progress.md ] && grep -q '\[x\]' docs/plans/progress.md; then
        printf 'setup_done'
      else
        printf 'setup_missing'
      fi

  tool find_next_task
    label: "Find Next Uncompleted Task"
    timeout: 30s
    command:
      #!/bin/sh
      if [ ! -f docs/plans/progress.md ]; then
        printf 'all_tasks_done'
        exit 0
      fi
      next=$(grep -n '^\- \[ \] Task' docs/plans/progress.md | head -1 || true)
      if [ -z "$next" ]; then
        printf 'all_tasks_done'
      else
        task_num=$(echo "$next" | sed 's/.*Task \([0-9]*\).*/\1/')
        printf 'task_%s' "$task_num"
      fi

  agent implement_task
    label: "Implement Next Task"
    model: claude-opus-4-6
    goal_gate: true
    max_retries: 3
    retry_target: implement_task
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Implement the next uncompleted task from the superpowers plan.

      ## Process
      1. Read docs/plans/progress.md — find the first task marked `- [ ]`
      2. Read the superpowers plan file in docs/superpowers/plans/*.md
      3. Find the matching "## Task N: [Name]" section
      4. Follow EVERY step in that task section exactly:
         - Create the files listed
         - Write the test code shown
         - Write the implementation code
         - Run the commands specified
      5. Do NOT skip steps or improvise — the plan is detailed for a reason

      ## Tech Stack
      Read docs/plans/progress.md for the tech stack section.

      ## TDD Process
      - Write failing tests FIRST (from the plan's test code)
      - Implement until tests pass
      - Run linter/type checker

      ## Infrastructure
      Check docs/plans/progress.md for infrastructure requirements.
      If tests need an emulator or service, start it before running tests.

      ## Success Criteria
      - All files for the current task are created/modified as specified
      - All tests for the current task pass
      - Linter/type checker passes
      - Do NOT update progress.md yet — the verify step handles that

  agent verify_task
    label: "Verify Task Implementation"
    model: claude-opus-4-6
    goal_gate: true
    auto_status: true
    max_retries: 3
    retry_target: implement_task
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Verify the most recently implemented task passes all checks.

      ## IRON LAW: NO COMPLETION CLAIMS WITHOUT FRESH VERIFICATION
      Run commands. Read output. Check exit codes. THEN make claims.
      DO NOT trust the implementer's claims. Verify independently.

      ## Process
      1. Read docs/plans/progress.md — identify which task was just implemented (first `- [ ]` entry)
      2. Read the superpowers plan to find that task's acceptance criteria
      3. Run the full test suite for the affected packages:
         - Go: go test ./[package]/... -v && golangci-lint run ./[package]/...
         - TypeScript: npm test && npx tsc --noEmit && npx eslint .
         - Python: uv run pytest [package] -v && uv run ruff check .
      4. Check that all files listed in the task actually exist
      5. If ALL checks pass: set STATUS: success
      6. If ANY check fails: set STATUS: fail — describe what failed

      ## Infrastructure
      Check docs/plans/progress.md for infrastructure requirements.
      Start any needed emulators/services before running tests.

      ## Success Criteria
      - All tests for the current task pass
      - All files from the task exist
      - Linter/type checker passes on affected packages

  agent commit_task
    label: "Commit and Mark Task Done"
    model: claude-sonnet-4-6
    goal_gate: true
    max_retries: 3
    retry_target: commit_task
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Commit the completed task and update the progress tracker.

      ## Process
      1. Read docs/plans/progress.md — find the first `- [ ]` task (the one just verified)
      2. Read the superpowers plan to find the suggested commit message for this task
      3. Stage and commit: git add -A && git commit -m '[commit message from plan]'
      4. Update docs/plans/progress.md: change that task's `- [ ]` to `- [x]`
      5. Commit the progress update: git add docs/plans/progress.md && git commit -m 'docs: mark task N complete'

      ## Success Criteria
      - Task code is committed
      - progress.md shows the task as [x]
      - Clean git status

  agent diagnose_failure
    label: "Diagnose Verification Failure"
    model: claude-opus-4-6
    reasoning_effort: high
    goal_gate: true
    max_retries: 3
    retry_target: diagnose_failure
    prompt:
      You are working in `run.working_dir`.

      ## Task
      The verify step failed. Diagnose why and fix it.

      ## Process
      1. Read docs/plans/progress.md — which task failed?
      2. Run the test suite and capture the FULL output
      3. Read the failing test code and the implementation
      4. Identify the root cause — do NOT guess, read the actual error
      5. Fix the issue
      6. Re-run tests to confirm the fix works
      7. If you cannot fix it after careful analysis, read the superpowers plan again — you may have missed a step

      ## DO NOT
      - Disable or skip failing tests
      - Claim it works without running the tests
      - Rewrite working code from scratch — make targeted fixes

      ## Success Criteria
      - Root cause identified and explained
      - Fix applied
      - Tests pass after the fix

  tool check_diagnose_budget
    label: "Check Diagnose Budget"
    timeout: 30s
    command:
      #!/bin/sh
      mkdir -p .tracker
      COUNTER='.tracker/diagnose_count'
      count=0
      [ -f "$COUNTER" ] && count=$(cat "$COUNTER")
      count=$((count + 1))
      printf '%s' "$count" > "$COUNTER"
      if [ "$count" -gt 5 ]; then
        printf 'budget_exhausted'
      else
        printf 'budget_ok'
      fi

  tool reset_diagnose_budget
    label: "Reset Diagnose Budget"
    timeout: 30s
    command:
      #!/bin/sh
      mkdir -p .tracker
      printf '0' > .tracker/diagnose_count
      printf 'reset'

  agent final_review
    label: "Final Project Review"
    model: claude-opus-4-6
    reasoning_effort: high
    goal_gate: true
    max_retries: 3
    retry_target: final_review
    fallback_target: done
    prompt:
      You are working in `run.working_dir`.

      ## Task
      All tasks from the superpowers plan are complete. Do a final review.

      ## IRON LAW: NO COMPLETION CLAIMS WITHOUT FRESH VERIFICATION
      Run commands. Read output. Check exit codes. THEN make claims.

      ## Process
      1. Read docs/plans/progress.md — confirm ALL tasks are [x]
      2. Read the superpowers spec — verify the built project matches the design
      3. Run the FULL test suite (all packages, not just the last task):
         - Go: go test ./... -v && golangci-lint run ./...
         - TypeScript: npm test && npx tsc --noEmit
         - Python: uv run pytest -v && uv run ruff check .
      4. Run the build:
         - Go: go build ./...
         - TypeScript: npm run build
         - Python: uv run python -c "import [main_package]"
      5. Check for any obvious gaps: missing error handling, untested edge cases, dead code
      6. Write a brief summary to docs/plans/build_complete.md:
         - Total tasks completed
         - Test count and pass rate
         - Any known issues or gaps
         - Suggested next steps
      7. Commit: git add -A && git commit -m 'docs: final build review and summary'

      ## Success Criteria
      - All tasks marked complete in progress.md
      - Full test suite passes
      - Project builds successfully
      - docs/plans/build_complete.md exists with summary

  agent skip_and_continue
    label: "Skip Stuck Task and Continue"
    model: claude-sonnet-4-6
    goal_gate: true
    max_retries: 3
    retry_target: skip_and_continue
    prompt:
      You are working in `run.working_dir`.

      ## Task
      The current task has exhausted its diagnose budget. Mark it as stuck and move on.

      ## Process
      1. Read docs/plans/progress.md — find the first `- [ ]` task
      2. Change it to `- [!] Task N: [Name] — STUCK: exceeded retry budget`
      3. Commit: git add docs/plans/progress.md && git commit -m 'docs: mark task N as stuck'
      4. Log what went wrong in docs/plans/stuck_tasks.md (append):
         - Task number and name
         - Last error output
         - What was tried

      ## Success Criteria
      - Task marked as [!] in progress.md
      - stuck_tasks.md updated
      - Pipeline can continue to next task

  agent done
    label: Exit
    model: claude-sonnet-4-6
    prompt:
      Build from superpowers plan complete.

  edges
    find_superpowers -> setup_project  when ctx.tool_stdout = ready  label: found  weight: 2
    find_superpowers -> done  label: "no superpowers output"
    setup_project -> check_setup
    check_setup -> find_next_task  when ctx.tool_stdout = setup_done  weight: 2
    check_setup -> setup_project  label: "retry setup"  restart: true
    find_next_task -> final_review  label: "all done"
    find_next_task -> implement_task  label: "next task"  weight: 2
    implement_task -> verify_task
    verify_task -> check_diagnose_budget  label: fail
    verify_task -> commit_task  label: pass  weight: 2
    commit_task -> reset_diagnose_budget
    reset_diagnose_budget -> find_next_task  restart: true
    check_diagnose_budget -> skip_and_continue  label: stuck
    check_diagnose_budget -> diagnose_failure  label: "budget ok"  weight: 2
    diagnose_failure -> verify_task  restart: true
    skip_and_continue -> reset_diagnose_budget
    final_review -> done
