          goal_gate: true
          reads: test_results
          writes: source_code
          max_retries: 2
          retry_target: run_tests
          fallback_target: done
          prompt:
            You are working in `run.working_dir`.
            Implement the code to make failing tests pass.

        human review_gate
          label: "Approve implementation?"
          mode: choice

        parallel build_parallel -> build_frontend, build_backend
        fan_in build_join <- build_frontend, build_backend

        agent build_frontend
          label: "Build Frontend"
          prompt:
            Build the frontend components.

        agent build_backend
          label: "Build Backend"
          prompt:
            Build the backend services.

        edges
          begin -> run_tests
          run_tests -> implement  when ctx.tool_stdout = fail
          run_tests -> review_gate  when ctx.tool_stdout = pass
          implement -> run_tests  restart: true
          review_gate -> build_parallel  when ctx.outcome = success
          review_gate -> implement  when ctx.outcome = fail  restart: true
