# ABOUTME: Bench harness for the SR + rollback LocalFix tool body. Model:
#          qwen3.6:35b-a3b-q8_0. Edit strategy: SEARCH/REPLACE via merge_sr.py.
#          NOT a sprint runner — no Generate, no ledger, no Audit, no CloudFix.
#          Designed to A/B prompt designs and validate rollback layers against
#          the deterministic pre-broken fixtures in
#          DS-scratch/local_llm_patch_bench/. The production runner that uses
#          this same LocalFix shape is sprint_runner_qwen.dip (sibling).
#          All per-language dispatch lives in lib/lang_profile.sh — same lib
#          the production runner sources, so the bench tests the same code path.
workflow BenchLocalFixSR
  goal: "Minimal dip that exercises the SR + rollback LocalFix logic against a pre-broken Python project. No generation, no ledger, no audit. Used to validate the LocalFix tool body in isolation against the local_llm_patch_bench fixtures."
  start: Setup
  exit: Done

  defaults
    provider: openai
    fidelity: summary:low
    max_restarts: 30

  tool Setup
    label: "Stage lib + detect proj_root + install deps"
    timeout: 300s
    command:
      set +e
      WORKDIR_ABS=$(pwd)
      mkdir -p .ai
      rm -f .ai/local_fix_attempts .ai/local_exhausted .ai/consecutive_rollbacks .ai/passing_pre.txt .ai/escalation.txt
      rm -rf .ai/snapshot_pre_local .ai/snapshot_round_pre

      # Stage lib helpers from the repo into .ai/ so RunTests/LocalFix are
      # self-contained — works whether the bench runs inside the repo or
      # against a fixture workdir elsewhere on disk. lang_profile.sh is
      # sourced by RunTests/LocalFix; merge_sr.py is invoked by LocalFix.
      # Mirrors sprint_runner_qwen.dip's stage_lib so the bench tests the
      # same code path as production.
      stage_lib() {
        local name="$1"
        local target=".ai/$name"
        for src in \
          "local_code_gen/lib/$name" \
          "local_code_gen/$name" \
          "${PIPELINES_REPO:-}/local_code_gen/lib/$name" \
          "${PIPELINES_REPO:-}/local_code_gen/$name" \
          "$HOME/Documents/GitHub/pipelines/local_code_gen/lib/$name" \
          "$HOME/Documents/GitHub/pipelines/local_code_gen/$name"; do
          if [ -n "$src" ] && [ -f "$src" ]; then
            cp "$src" "$target"
            echo "staged $name from $src"
            return 0
          fi
        done
        if [ -f "$target" ]; then
          echo "staged $name not found in repo; using existing $target"
          return 0
        fi
        echo "ERROR: $name not found in any expected location" >&2
        return 1
      }
      stage_lib lang_profile.sh || exit 1
      stage_lib merge_sr.py     || exit 1

      # Detect language + install deps + record test command via lang_profile.
      # Adding a language: edit lib/lang_profile.sh, not this dip.
      . .ai/lang_profile.sh
      proj_root=$(detect_proj_root)
      printf '%s' "$proj_root" > .ai/proj_root.txt

      cd "$proj_root"
      lang=$(detect_lang ".")
      lang_install "$lang"
      test_command=$(lang_test_cmd "$lang")
      cd "$WORKDIR_ABS"

      printf '%s' "$lang"         > .ai/lang.txt
      printf '%s' "$test_command" > .ai/test_command.txt
      echo "Setup: proj_root=$proj_root lang=$lang test_command='$test_command' cwd=$WORKDIR_ABS" >&2

      printf 'setup-done'

  # RunTests' three conditional edges (tests-pass, tests-fail, tests-fail-cloud)
  # are exhaustive over what the body emits; marker_grep declares that set so
  # dippin's DIP101/DIP102 coverage analysis stops flagging the conditionals
  # as needing an unconditional fallback. (An unconditional fallback would
  # route to the same target as one of the conditionals, which is the
  # infinite-loop trap we want to avoid.) LocalFix and Done are likewise only
  # reachable through these conditionals by design — the routing IS the logic.
  tool RunTests
    label: "Run tests"
    marker_grep: '^(tests-pass|tests-fail|tests-fail-cloud)$'
    timeout: 600s
    command:
      set +e
      mkdir -p .ai
      WORKDIR_ABS=$(pwd)
      . .ai/lang_profile.sh

      proj_root=$(detect_proj_root)
      printf '%s' "$proj_root" > .ai/proj_root.txt

      lang=$(cat .ai/lang.txt 2>/dev/null || echo "")
      [ -z "$lang" ] && lang=$(detect_lang "$proj_root")
      printf '%s' "$lang" > .ai/lang.txt

      cd "$proj_root"
      lang_run_tests "$WORKDIR_ABS/.ai/last_test_output.txt" "$lang"
      code=$?
      cd "$WORKDIR_ABS"
      tail -10 .ai/last_test_output.txt

      if [ $code -eq 0 ]; then
        printf 'tests-pass'
      elif [ -f .ai/local_exhausted ]; then
        printf 'tests-fail-cloud'
      else
        printf 'tests-fail'
      fi

  # LocalFix's two conditional edges (local-fixed → RunTests restart,
  # local-exhausted → Done) are exhaustive over what the SR rollback loop
  # emits; marker_grep declares the set for dippin's coverage analysis.
  # Same same-target trap reasoning as RunTests — no unconditional fallback
  # would be safe to add.
  tool LocalFix
    label: "Local fix (qwen3.6:35b-a3b-q8_0, SR + rollback)"
    marker_grep: '^(local-fixed|local-exhausted)$'
    timeout: 600s
    command:
      set +e
      mkdir -p .ai
      OLLAMA=http://localhost:11434/api/chat
      WORKDIR_ABS=$(pwd)
      . .ai/lang_profile.sh
      proj_root=$(detect_proj_root)
      printf '%s' "$proj_root" > .ai/proj_root.txt
      PROJ_ROOT_ABS="$WORKDIR_ABS/$proj_root"
      lang=$(cat .ai/lang.txt 2>/dev/null || detect_lang "$proj_root")

      MAX_ROUNDS=8
      MAX_ROLLBACKS=3

      # Locate merge_sr.py: prefer .ai/merge_sr.py (Setup stages it there),
      # fallback to $PIPELINES_REPO/local_code_gen/merge_sr.py if env var set.
      MERGE_SR=""
      if [ -f .ai/merge_sr.py ]; then
        MERGE_SR="$WORKDIR_ABS/.ai/merge_sr.py"
      elif [ -n "${PIPELINES_REPO:-}" ] && [ -f "$PIPELINES_REPO/local_code_gen/merge_sr.py" ]; then
        MERGE_SR="$PIPELINES_REPO/local_code_gen/merge_sr.py"
      else
        echo "ERROR: merge_sr.py not found. Place it at .ai/merge_sr.py or set PIPELINES_REPO."
        printf 'local-exhausted'
        exit 0
      fi

      # Source dirs to snapshot — pulled from lang_profile.sh, plus the
      # universal "tests" / "scripts" superset so multi-style projects (e.g.
      # Python tests/ alongside scripts/) are covered. Matches the production
      # runner's snapshot/restore surface.
      SOURCE_DIRS=$(lang_src_dirs "$lang")
      for extra in tests scripts; do
        case " $SOURCE_DIRS " in *" $extra "*) ;; *) SOURCE_DIRS="$SOURCE_DIRS $extra" ;; esac
      done

      snapshot_state() {
        local snap_dir="$1"
        rm -rf "$snap_dir"; mkdir -p "$snap_dir"
        cd "$PROJ_ROOT_ABS"
        for d in $SOURCE_DIRS; do
          [ -d "$d" ] && cp -R "$d" "$snap_dir/" || true
        done
        cd "$WORKDIR_ABS"
      }
      restore_state() {
        local snap_dir="$1"
        cd "$PROJ_ROOT_ABS"
        for d in $SOURCE_DIRS; do
          [ -d "$d" ] && rm -rf "$d"
        done
        for d in $SOURCE_DIRS; do
          [ -d "$snap_dir/$d" ] && cp -R "$snap_dir/$d" .
        done
        cd "$WORKDIR_ABS"
      }
      extract_passing() {
        grep -E "::[a-zA-Z_][a-zA-Z0-9_]* PASSED " "$1" 2>/dev/null | awk '{print $1}' | sort -u
      }

      attempts=$(cat .ai/local_fix_attempts 2>/dev/null || echo 0)
      consecutive_rollbacks=$(cat .ai/consecutive_rollbacks 2>/dev/null || echo 0)

      # Layer 1: regression check (only meaningful from round 2+)
      if [ "$attempts" -gt 0 ] && [ -f .ai/passing_pre.txt ]; then
        POST_PASSING=$(mktemp)
        extract_passing .ai/last_test_output.txt > "$POST_PASSING"
        DROPPED=$(comm -23 .ai/passing_pre.txt "$POST_PASSING")
        if [ -n "$DROPPED" ]; then
          DROPPED_COUNT=$(echo "$DROPPED" | grep -c .)
          echo "REGRESSION: $DROPPED_COUNT previously-passing test(s) now fail"
          echo "dropped: $(echo "$DROPPED" | tr '\n' ',' | sed 's/,$//')"
          echo "rolling back to pre-round snapshot"
          restore_state .ai/snapshot_round_pre
          consecutive_rollbacks=$((consecutive_rollbacks + 1))
          echo $consecutive_rollbacks > .ai/consecutive_rollbacks
        else
          echo 0 > .ai/consecutive_rollbacks
          consecutive_rollbacks=0
        fi
        rm -f "$POST_PASSING"
      fi

      attempts=$((attempts + 1))
      echo $attempts > .ai/local_fix_attempts
      echo "local fix round $attempts/$MAX_ROUNDS (consecutive_rollbacks=$consecutive_rollbacks/$MAX_ROLLBACKS)"

      # Exhaustion → restore pre-local for cloud handoff
      if [ "$attempts" -gt "$MAX_ROUNDS" ] || [ "$consecutive_rollbacks" -ge "$MAX_ROLLBACKS" ] || [ -f .ai/local_exhausted ]; then
        if [ -d .ai/snapshot_pre_local ]; then
          echo "restoring pre-local snapshot for cloud handoff"
          restore_state .ai/snapshot_pre_local
        fi
        touch .ai/local_exhausted
        printf 'local-exhausted'
        exit 0
      fi

      # First round: snapshot pre-local
      if [ "$attempts" -eq 1 ]; then
        snapshot_state .ai/snapshot_pre_local
        echo "saved pre-local snapshot"
      fi

      # Snapshot pre-round + capture pre-round passing set
      snapshot_state .ai/snapshot_round_pre
      extract_passing .ai/last_test_output.txt > .ai/passing_pre.txt
      PRE_PASS_COUNT=$(wc -l < .ai/passing_pre.txt | tr -d ' ')
      echo "pre-round passing tests: $PRE_PASS_COUNT"

      # Build context bundle: full source-dir contents + failing test files.
      # All per-language dispatch lives in lang_profile.sh — same as
      # sprint_runner_qwen.dip's LocalFix.
      cd "$PROJ_ROOT_ABS"
      FAILING_TESTS=$(lang_failing_test_files "$lang" "$WORKDIR_ABS/.ai/last_test_output.txt")

      lf_src_dirs=$(lang_src_dirs "$lang")
      lf_glob=$(lang_src_glob "$lang")
      lf_extra_globs=$(lang_src_glob_extras "$lang")
      lf_prune=$(lang_find_prune "$lang")

      : > /tmp/lf_app_files.txt
      for d in $lf_src_dirs; do
        [ -d "$d" ] || continue
        # shellcheck disable=SC2086 — $lf_prune is a flag list we want word-split.
        find "$d" -name "$lf_glob" $lf_prune 2>/dev/null | sort >> /tmp/lf_app_files.txt
        for g in $lf_extra_globs; do
          # shellcheck disable=SC2086
          find "$d" -name "$g" $lf_prune 2>/dev/null | sort >> /tmp/lf_app_files.txt
        done
      done

      printf '%s\n' "$FAILING_TESTS" > /tmp/lf_failing_tests.txt
      : > /tmp/lf_context.txt
      while IFS= read -r f; do
        [ -z "$f" ] && continue
        printf '===== %s =====\n' "$f" >> /tmp/lf_context.txt
        cat "$f" >> /tmp/lf_context.txt
        printf '\n\n' >> /tmp/lf_context.txt
      done < /tmp/lf_app_files.txt
      while IFS= read -r f; do
        [ -z "$f" ] && continue
        if [ -f "$f" ]; then
          printf '===== %s =====\n' "$f" >> /tmp/lf_context.txt
          cat "$f" >> /tmp/lf_context.txt
          printf '\n\n' >> /tmp/lf_context.txt
        fi
      done < /tmp/lf_failing_tests.txt
      CONTEXT=$(cat /tmp/lf_context.txt)
      rm -f /tmp/lf_app_files.txt /tmp/lf_failing_tests.txt /tmp/lf_context.txt

      FAIL_BLOCKS=$(lang_failure_block "$lang" "$WORKDIR_ABS/.ai/last_test_output.txt")
      FAIL_SUMMARY=$(lang_failure_summary "$lang" "$WORKDIR_ABS/.ai/last_test_output.txt")
      FAIL_COUNT=$(echo "$FAIL_SUMMARY" | grep -c . || echo 0)

      cd "$WORKDIR_ABS"

      # Optional sprint context (if a spec exists)
      SPRINT=""
      if [ -f .ai/sprints/SPRINT-001.md ]; then
        SPRINT=$(cat .ai/sprints/SPRINT-001.md)
      fi

      SYS_SR=$(printf '%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s' "You are a code editor that produces SEARCH/REPLACE blocks. Each block looks EXACTLY like this:" "" "app/models.py" "<<<<<<< SEARCH" "    foo: Mapped[int]" "=======" "    foo: Mapped[int] = mapped_column(default=0)" ">>>>>>> REPLACE" "" "Rules: filepath on its own line; SEARCH must match file content EXACTLY (whitespace, indentation, every character); output ONLY SEARCH/REPLACE blocks - no prose, no markdown fences, no explanation; multiple bugs require multiple blocks (each with its own filepath, SEARCH, REPLACE, and markers); each block targets one small change; the replacement must be syntactically valid; do not output entire files - only the lines you are changing with enough surrounding context to be unique.")

      USER_SR=$(printf '%s\n%s\n\n%s\n%s\n\n%s\n\n%s\n\n%s\n\n%s\n\n%s\n\n%s\n\n%s' \
        "There are ${FAIL_COUNT} failing test(s). Read the project context, diagnose the cause(s), and emit SEARCH/REPLACE blocks to fix them." \
        "IMPORTANT: when a test asserts something the code does not provide (e.g. assert obj.foo raises AttributeError), the FIX is in the source file (add the field), NOT in the test (don't remove the assertion). Tests describe what the code SHOULD do." \
        "FAILURES SUMMARY:" \
        "${FAIL_SUMMARY}" \
        "---" \
        "DETAILED TRACEBACKS:" \
        "${FAIL_BLOCKS}" \
        "---" \
        "PROJECT CONTEXT (paths relative to project root):" \
        "${CONTEXT}" \
        "---SPRINT SPEC---")
      USER_SR=$(printf '%s\n%s\n%s\n%s' "$USER_SR" "$SPRINT" "---" "Emit SEARCH/REPLACE blocks. Each block's filepath line must use a path relative to the project root (e.g. app/models.py). Do NOT prefix paths with the project root directory name. Address every failure.")

      RESPONSE=$(curl -sf "$OLLAMA" \
        -H 'Content-Type: application/json' \
        --data "$(jq -n --arg sys "$SYS_SR" --arg msg "$USER_SR" \
          '{model:"qwen3.6:35b-a3b-q8_0",think:false,stream:false,
            messages:[{role:"system",content:$sys},{role:"user",content:$msg}],
            options:{temperature:0.2,top_p:0.95,top_k:64,num_ctx:32768,num_predict:4096}}')" \
        | jq -r '.message.content')

      echo "$RESPONSE" > .ai/last_qwen_response.txt

      # Guard: empty/null Ollama response (curl failure, model timeout, etc.).
      # Skip the merger entirely — running it on empty input throws away the
      # round and inflates consecutive_rollbacks confusingly.
      RESPONSE_TRIMMED=$(printf '%s' "$RESPONSE" | tr -d '[:space:]')
      if [ -z "$RESPONSE_TRIMMED" ] || [ "$RESPONSE_TRIMMED" = "null" ]; then
        echo "ERROR: empty/null Ollama response — skipping merger"
        APPLIED=0
        FAILED_BLOCKS=0
        FILES_TOUCHED=""
        echo '{"applied":0,"failed":0,"results":[],"error":"empty-ollama-response"}' > .ai/last_merge.json
        consecutive_rollbacks=$((consecutive_rollbacks + 1))
        echo $consecutive_rollbacks > .ai/consecutive_rollbacks
        if [ "$consecutive_rollbacks" -ge "$MAX_ROLLBACKS" ]; then
          if [ -d .ai/snapshot_pre_local ]; then
            restore_state .ai/snapshot_pre_local
          fi
          touch .ai/local_exhausted
          printf 'local-exhausted'
          exit 0
        fi
        printf 'local-fixed'
        exit 0
      fi

      MERGE_OUT=$(echo "$RESPONSE" | python3 "$MERGE_SR" "$PROJ_ROOT_ABS" 2>&1)
      echo "$MERGE_OUT" > .ai/last_merge.json
      APPLIED=$(echo "$MERGE_OUT" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("applied",0))' 2>/dev/null || echo 0)
      FAILED_BLOCKS=$(echo "$MERGE_OUT" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("failed",0))' 2>/dev/null || echo 0)
      FILES_TOUCHED=$(echo "$MERGE_OUT" | python3 -c 'import sys,json; r=json.load(sys.stdin).get("results",[]); print(",".join(sorted(set(x["file"] for x in r if x.get("ok")))))' 2>/dev/null || echo "")
      echo "merger: applied=$APPLIED failed=$FAILED_BLOCKS files=[$FILES_TOUCHED]"

      if [ "$APPLIED" = "0" ]; then
        consecutive_rollbacks=$((consecutive_rollbacks + 1))
        echo $consecutive_rollbacks > .ai/consecutive_rollbacks
        echo "no blocks applied; consecutive failures: $consecutive_rollbacks"
        if [ "$consecutive_rollbacks" -ge "$MAX_ROLLBACKS" ]; then
          if [ -d .ai/snapshot_pre_local ]; then
            restore_state .ai/snapshot_pre_local
          fi
          touch .ai/local_exhausted
          printf 'local-exhausted'
          exit 0
        fi
      fi

      printf 'local-fixed'

  tool Done
    label: "Done"
    timeout: 5s
    command:
      printf 'bench-complete'

  edges
    Setup -> RunTests
    RunTests -> LocalFix       when ctx.tool_stdout contains tests-fail
    RunTests -> Done           when ctx.tool_stdout contains tests-pass
    RunTests -> Done           when ctx.tool_stdout contains tests-fail-cloud
    LocalFix -> RunTests       when ctx.tool_stdout contains local-fixed       restart: true
    LocalFix -> Done           when ctx.tool_stdout contains local-exhausted
