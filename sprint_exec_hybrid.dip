workflow SprintExecHybrid
  goal: "Execute the next incomplete sprint using hybrid architect/executor pattern — gpt-5.4 writes contract, nano generates, gpt-5.4 fixes strategically."
  start: Start
  exit: Exit

  defaults
    fidelity: summary:medium

  agent Start
    label: Start
    prompt:
      Begin sprint execution pipeline (hybrid).

  agent Exit
    label: Exit
    prompt:
      Sprint execution pipeline complete.

  tool EnsureLedger
    label: "Ensure Ledger"
    timeout: 30s
    command:
      set -eu
      mkdir -p .ai .ai/drafts .ai/sprints
      if [ ! -f .ai/ledger.tsv ]; then
        now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
        printf 'sprint_id\ttitle\tstatus\tcreated_at\tupdated_at\n001\tBootstrap sprint\tplanned\t%s\t%s\n' "$now" "$now" > .ai/ledger.tsv
      fi
      printf 'ledger-ready'

  agent FindNextSprint
    label: "Find Next Sprint"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Identify the next non-completed sprint in .ai/ledger.tsv and summarize the target sprint ID and why it is next.

  tool SetCurrentSprint
    label: "Set Current Sprint"
    timeout: 30s
    command:
      set -eu
      target=$(awk -F '\t' 'NR>1 && $3!~/^completed$/ && $3!~/^skipped$/{print $1; exit}' .ai/ledger.tsv)
      if [ -z "$target" ]; then
        target=$(awk -F '\t' 'NR>1 && $3!~/^completed$/{print $1; exit}' .ai/ledger.tsv)
      fi
      if [ -z "$target" ]; then
        target=$(awk -F '\t' 'END{print $1}' .ai/ledger.tsv)
      fi
      printf '%s' "$target" > .ai/current_sprint_id.txt
      printf 'current-%s' "$target"

  agent ReadSprint
    label: "Read Sprint"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Read the target sprint document under .ai/sprints/SPRINT-<id>.md and summarize requirements, DoD checklist status, and expected artifacts.

  tool MarkInProgress
    label: "Mark In Progress"
    timeout: 30s
    command:
      set -eu
      target=$(cat .ai/current_sprint_id.txt)
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      awk -F '\t' -v OFS='\t' -v target="$target" -v now="$now" '
      NR==1 {print; next}
      { if ($1==target) { $3="in_progress"; $5=now }; print }
      ' .ai/ledger.tsv > .ai/ledger.tsv.tmp
      mv .ai/ledger.tsv.tmp .ai/ledger.tsv
      printf 'in_progress-%s' "$target"

  agent ArchitectSprint
    label: "Architect Sprint — Contract + Generate"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    max_turns: 5
    fidelity: summary:low
    prompt:
      You are working in `run.working_dir`.

      ## Step 1: Orient
      bash: cat .ai/current_sprint_id.txt, then cat the sprint doc at
      .ai/sprints/SPRINT-<id>.md. If the sprint has dependencies, cat those docs too.
      Cat any existing files this sprint must integrate with.

      ## Step 2: Write the contract
      The contract is the ONLY thing nano will see. Make every decision here.
      Use ACTUAL CODE SYNTAX — not prose. Nano pattern-matches tokens; it cannot
      interpret English descriptions into correct code.

      ## DATA CONTRACT
      Write the actual TypeScript interfaces/types/enums or Python dataclasses/Pydantic
      models with exact field names, types, and defaults — not descriptions of them.
        interface Volunteer { id: string; name: string; email: string; status: VolunteerStatus }
        type VolunteerStatus = 'active' | 'inactive'
      For SQL: write the exact CREATE TABLE statements with column names and types.
      For Python: use actual dataclass/Pydantic syntax with field() defaults.

      ## FILE STRUCTURE
      Every file this sprint produces, one line each:
        path/to/file.ts — exported: FunctionName, ClassName, CONSTANT
      Include test files. Match exactly the Expected Artifacts from the sprint doc.

      ## INTERFACE CONTRACT
      Every exported function or class with exact signature:
        export async function runMigrations(db: Database): Promise<void>
        def append(self, stream_id: str, events: list[NewEvent], expected_version: int) -> AppendResult
      Nano implements exactly what you write here — nothing more, nothing less.

      ## ALGORITHM
      For any non-trivial logic (>3 steps), state machine, concurrency, or security:
      write numbered pseudocode. Specify error conditions explicitly.
      For seed data: the exact fixture values, not "example values".
      For schema: list each table's columns explicitly.

      ## TEST PLAN
      Every test function by name with one-line expected behavior:
        it('GET /health returns 200 with { status: ok }')
        test_append_conflict — append with wrong expected_version raises ConcurrencyError
      Nano generates exactly the tests you list. What you omit will not be tested.
      Target: 1 test per DoD item minimum.

      ## CROSS-CUTTING CONCERNS
      For auth, logging, error handling, or middleware spanning multiple files:
      specify the exact pattern per component. Nano processes files in isolation.

      ## RULES
      - Exact import paths, framework patterns (express vs fastify, jest vs vitest,
        pytest vs unittest, decorator ordering, fixture naming, sync vs async)
      - Error response shapes
      - Pydantic: use exclude_unset=True for PATCH (NOT exclude_none)
      - Any constraints from the sprint Non-goals or DoD

      Keep the contract under 300 lines. Dense and code-like, not prose.

      ## Step 3: Call generate_code
      Pass:
      - contract: your contract from Step 2
      - output_dir: a single dot (the working directory root)
      - files array (sequential mode) for each file — one LLM call per file keeps nano focused.
        Each entry: {"path": "exact/path.ext", "description": "exports and exact content"}

      You have ONLY these tools: bash, generate_code.
      Do NOT use: read, glob, grep_search, write, apply_patch, edit.

  tool RunTests
    label: "Run Tests"
    timeout: 180s
    command:
      set +e
      if [ -f package.json ]; then
        npm test 2>&1
        if [ $? -eq 0 ]; then printf 'tests-pass'; else printf 'tests-fail'; fi
      elif [ -d .venv ]; then
        .venv/bin/python -m pytest tests/ -v 2>&1
        if [ $? -eq 0 ]; then printf 'tests-pass'; else printf 'tests-fail'; fi
      else
        printf 'tests-pass-no-runner'
      fi

  agent FixSprint
    label: "Fix Sprint — Strategic Repair"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    max_turns: 12
    fidelity: summary:low
    prompt:
      You are working in `run.working_dir`.

      The sprint implementation was generated by a nano model from a contract.
      Your job: run tests and fix all failures surgically.

      ## Step 1: Orient
        cat .ai/current_sprint_id.txt
        (then discover test runner: look for pytest.ini, package.json, Package.swift, etc.)

      ## Step 2: Run tests
      Run the full test suite. Read the traceback carefully.

      ## Step 3: Fix failures
      Apply surgical fixes using edit. Strategy by failure type:

      LOCAL errors (import missing, type mismatch, wrong arg, missing param default):
        Fix the specific line the traceback points to. One edit per error.

      FIXTURE / naming mismatch across files:
        Read conftest (or equivalent), find the canonical name, align all callers to it.

      MISSING logic (test expects behavior that is absent):
        Read the failing test and the file it calls. Add the missing logic precisely.
        Do not rewrite the file — add only what is missing.

      FRAMEWORK semantics (exclude_none vs exclude_unset, sync vs async fixtures):
        These are always wrong-default substitutions. Fix the specific pattern.

      ARCHITECTURAL mismatch (test expects class, file exports function):
        This is the only case where a small targeted rewrite of the affected file is
        acceptable. Keep it to the interface change only.

      ## Step 4: Repeat
      Re-run tests after each batch of fixes. Repeat until all pass.

      ## Step 5: Update checklist
      Mark completed DoD items in .ai/sprints/SPRINT-<id>.md: change [ ] to [x].

      You have ONLY these tools: bash, edit, read.
      Do NOT use: glob, grep_search, write, apply_patch, generate_code.
      Never rewrite entire files. Surgical changes only.

  tool ValidateBuild
    label: "Validate Build and Tests"
    timeout: 300s
    command:
      set -eu
      if [ -f Package.swift ]; then
        swift build >/tmp/sprint-exec-build.log 2>&1
        swift test >/tmp/sprint-exec-test.log 2>&1 || true
        cat /tmp/sprint-exec-build.log
        cat /tmp/sprint-exec-test.log
        if rg -n 'error:' /tmp/sprint-exec-build.log >/dev/null 2>&1; then exit 1; fi
        if rg -n 'failed' /tmp/sprint-exec-test.log >/dev/null 2>&1; then exit 1; fi
        printf 'validation-pass-swift'
        exit 0
      fi
      if [ -f package.json ]; then
        npm test >/tmp/sprint-exec-test.log 2>&1 || { cat /tmp/sprint-exec-test.log; exit 1; }
        printf 'validation-pass-node'
        exit 0
      fi
      if [ -f pytest.ini ] || [ -f pyproject.toml ] || [ -f setup.py ] || [ -d tests ] || find . -maxdepth 3 -name 'test_*.py' -quit 2>/dev/null; then
        python -m pytest tests/ -v >/tmp/sprint-exec-test.log 2>&1 || { cat /tmp/sprint-exec-test.log; exit 1; }
        printf 'validation-pass-pytest'
        exit 0
      fi
      printf 'validation-pass-no-known-build-system'

  agent CommitSprintWork
    label: "Commit Sprint Work"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Prepare and execute a clean commit for sprint implementation changes if there are staged/unstaged changes. If no changes are present, report that no commit was needed. Include commit hash in your summary.

  parallel ReviewParallel -> ReviewA, ReviewB, ReviewC

  agent ReviewA
    label: "Review A"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Review sprint execution thoroughly: sprint doc checklist completion, implementation correctness, and validation evidence. Return clear PASS/FAIL reasoning and required fixes.

  agent ReviewB
    label: "Review B"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Review sprint execution for implementation quality, regression risk, and checklist completeness. Return clear PASS/FAIL reasoning and required fixes.

  agent ReviewC
    label: "Review C"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Review sprint execution for delivery robustness, test coverage, and checklist completeness. Return clear PASS/FAIL reasoning and required fixes.

  fan_in ReviewsJoin <- ReviewA, ReviewB, ReviewC

  parallel CritiquesParallel -> CritiqueAonB, CritiqueAonC, CritiqueBonA, CritiqueBonC, CritiqueConA, CritiqueConB

  agent CritiqueAonB
    label: "A Critique of B"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Critique Review B for missing checks, weak evidence, or mistaken conclusions.

  agent CritiqueAonC
    label: "A Critique of C"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Critique Review C for missing checks, weak evidence, or mistaken conclusions.

  agent CritiqueBonA
    label: "B Critique of A"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Critique Review A for missing checks, weak evidence, or mistaken conclusions.

  agent CritiqueBonC
    label: "B Critique of C"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Critique Review C for missing checks, weak evidence, or mistaken conclusions.

  agent CritiqueConA
    label: "C Critique of A"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Critique Review A for missing checks, weak evidence, or mistaken conclusions.

  agent CritiqueConB
    label: "C Critique of B"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Critique Review B for missing checks, weak evidence, or mistaken conclusions.

  fan_in CritiquesJoin <- CritiqueAonB, CritiqueAonC, CritiqueBonA, CritiqueBonC, CritiqueConA, CritiqueConB

  agent ReviewAnalysis
    label: "Review Analysis"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    goal_gate: true
    max_retries: 3
    retry_target: FixSprint
    prompt:
      Synthesize all reviews and critiques into one verdict. Return success only if sprint is truly complete and checklist is satisfied. Return retry if rework is needed. Return fail if blocked.

  tool CompleteSprint
    label: "Complete Sprint"
    timeout: 30s
    command:
      set -eu
      target=$(cat .ai/current_sprint_id.txt)
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      awk -F '\t' -v OFS='\t' -v target="$target" -v now="$now" '
      NR==1 {print; next}
      { if ($1==target) { $3="completed"; $5=now }; print }
      ' .ai/ledger.tsv > .ai/ledger.tsv.tmp
      mv .ai/ledger.tsv.tmp .ai/ledger.tsv
      printf 'completed-%s' "$target"

  agent FailureSummary
    label: "Failure Summary"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Summarize why sprint execution failed, what remains unresolved, and concrete next steps for recovery.

  edges
    Start -> EnsureLedger
    EnsureLedger -> FindNextSprint
    FindNextSprint -> SetCurrentSprint
    SetCurrentSprint -> ReadSprint
    ReadSprint -> MarkInProgress
    MarkInProgress -> ArchitectSprint
    ArchitectSprint -> RunTests
    RunTests -> FixSprint     when ctx.tool_stdout contains tests-fail
    RunTests -> ValidateBuild when ctx.tool_stdout contains tests-pass
    RunTests -> FixSprint
    FixSprint -> ValidateBuild
    ValidateBuild -> CommitSprintWork  when ctx.outcome = success  label: validated
    ValidateBuild -> FixSprint  when ctx.outcome = fail  label: fix_validation  restart: true
    ValidateBuild -> FailureSummary
    CommitSprintWork -> ReviewParallel
    ReviewParallel -> ReviewA
    ReviewParallel -> ReviewB
    ReviewParallel -> ReviewC
    ReviewA -> ReviewsJoin
    ReviewB -> ReviewsJoin
    ReviewC -> ReviewsJoin
    ReviewsJoin -> CritiquesParallel
    CritiquesParallel -> CritiqueAonB
    CritiquesParallel -> CritiqueAonC
    CritiquesParallel -> CritiqueBonA
    CritiquesParallel -> CritiqueBonC
    CritiquesParallel -> CritiqueConA
    CritiquesParallel -> CritiqueConB
    CritiqueAonB -> CritiquesJoin
    CritiqueAonC -> CritiquesJoin
    CritiqueBonA -> CritiquesJoin
    CritiqueBonC -> CritiquesJoin
    CritiqueConA -> CritiquesJoin
    CritiqueConB -> CritiquesJoin
    CritiquesJoin -> ReviewAnalysis
    ReviewAnalysis -> CompleteSprint  when ctx.outcome = success  label: pass
    ReviewAnalysis -> FixSprint  when ctx.outcome = retry  label: rework  restart: true
    ReviewAnalysis -> FailureSummary  when ctx.outcome = fail  label: fail
    ReviewAnalysis -> FailureSummary
    CompleteSprint -> Exit
    FailureSummary -> Exit
