digraph SprintRunnerCheap {
  rankdir=LR;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];
  Start [label="Start", prompt="Begin cheap sprint runner pipeline. Will loop through all incomplete sprints in the ledger.", shape="Mdiamond"];
  Exit [label="Exit", prompt="Cheap sprint runner pipeline complete.", shape="Msquare"];
  check_ledger [label="Check Ledger", shape="parallelogram", timeout="10s", tool_command="set -eu\nif [ ! -f .ai/ledger.tsv ]; then\n  printf 'no_ledger'\n  exit 0\nfi\ntarget=$(awk -F '\\t' 'NR>1 && $3!~/^completed$/ && $3!~/^skipped$/{print $1; exit}' .ai/ledger.tsv)\nif [ -z \"$target\" ]; then\n  printf 'all_done'\n  exit 0\nfi\nprintf '%s' \"$target\" > .ai/current_sprint_id.txt\nprintf 'next-%s' \"$target\""];
  no_ledger_exit [label="No Ledger Found", prompt="No .ai/ledger.tsv found. The sprint runner requires an existing ledger with planned sprints.\n\nTo create one, run spec_to_sprints.dip with a spec file, or megaplan.dip to plan incrementally.", shape="box"];
  read_sprint [label="Read Sprint", model="gemini-3.1-flash-lite-preview", prompt="You are working in `run.working_dir`.\n\nRead .ai/current_sprint_id.txt to get the target sprint ID.\nRead the sprint document at .ai/sprints/SPRINT-<id>.md.\n\nSummarize:\n1. Sprint title and scope\n2. Requirements covered (FR IDs)\n3. Dependencies — confirm all dependency sprints are completed in .ai/ledger.tsv\n4. Expected artifacts\n5. DoD checklist items\n6. Validation commands\n\nIf a dependency sprint is NOT completed, flag this as a blocker.", provider="gemini", shape="box"];
  mark_in_progress [label="Mark In Progress", shape="parallelogram", timeout="10s", tool_command="set -eu\ntarget=$(cat .ai/current_sprint_id.txt)\nnow=$(date -u +%Y-%m-%dT%H:%M:%SZ)\nawk -F '\\t' -v OFS='\\t' -v target=\"$target\" -v now=\"$now\" '\nNR==1 {print; next}\n{ if ($1==target) { $3=\"in_progress\"; $5=now }; print }\n' .ai/ledger.tsv > .ai/ledger.tsv.tmp\nmv .ai/ledger.tsv.tmp .ai/ledger.tsv\nprintf 'in_progress-%s' \"$target\""];
  implement_cheap [label="Implement Sprint (Cheap)", model="claude-haiku-4-5", prompt="You are working in `run.working_dir`.\n\n## Task\nRead .ai/current_sprint_id.txt to get the sprint ID. Read the sprint doc at .ai/sprints/SPRINT-<id>.md. Implement all requirements end-to-end.\n\n## Process\n1. Read the sprint doc thoroughly — understand scope, requirements, expected artifacts, DoD\n2. Read .ai/spec_analysis.md for broader context\n3. Review existing code to understand current state\n4. Write failing tests FIRST for each DoD item\n5. Implement minimum code to pass tests\n6. Run the project's test suite and linter — fix all issues\n7. Update the sprint doc checklist as work is completed\n\n## If Prior Review Feedback Exists\nIf you have context from a prior review/critique cycle, treat those findings as required fixes. Address every finding before declaring done.\n\n## Success Criteria\n- All DoD items checked off in the sprint doc\n- All tests pass\n- Linter passes\n- Expected artifacts exist", provider="anthropic", shape="box"];
  validate_build [label="Validate Build and Tests", shape="parallelogram", timeout="5m", tool_command="set +e\nfail=0\nif [ -f Package.swift ]; then\n  swift build 2>&1 || fail=1\n  swift test 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nif [ -f pyproject.toml ]; then\n  uv run pytest -v 2>&1 || fail=1\n  uv run ruff check . 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nif [ -f package.json ]; then\n  npm test 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nif [ -f Cargo.toml ]; then\n  cargo build 2>&1 || fail=1\n  cargo test 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nif [ -f go.mod ]; then\n  go build ./... 2>&1 || fail=1\n  go test ./... 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nprintf 'validation-pass-no-known-build-system'"];
  commit_cheap [label="Commit Sprint Work (Cheap)", model="gpt-5.4-nano", prompt="You are working in `run.working_dir`.\n\n## Task\nRead .ai/current_sprint_id.txt to get the sprint ID.\nReview all changes with git diff and git status.\nStage all relevant files and commit.\n\n## Rules\n- Use conventional commit format: feat(sprint-NNN): <description>\n- Do NOT commit generated files, __pycache__, node_modules, .env, or build artifacts\n- If no changes exist, report that no commit was needed\n- Verify the commit succeeded with git log --oneline -1\n- Include the commit hash in your summary", provider="openai", shape="box"];
  squad_parallel [label="squad_parallel", shape="component", targets="practical_dev,nitpicker,fresh_eyes"];
  practical_dev [label="Squad: Practical Dev", model="claude-haiku-4-5", prompt="You are working in `run.working_dir`.\n\nYou are a pragmatic mid-level developer picking up this sprint's work for the first time.\n\n## Context (MANDATORY)\n1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md\n2. Get the full diff: git log --oneline -3 and git diff HEAD~1\n3. Read every changed file\n\n## Review Focus\n- Does it actually work as specified?\n- Are there obvious bugs or missing pieces?\n- Does the code flow make sense?\n- Check the sprint doc checklist against what was actually delivered\n\nBe concrete — cite files and line numbers.", provider="anthropic", shape="box"];
  nitpicker [label="Squad: Nitpicker", model="gpt-5.4-nano", prompt="You are working in `run.working_dir`.\n\nYou are an obsessively detail-oriented code reviewer.\n\n## Context (MANDATORY)\n1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md\n2. Get the full diff: git log --oneline -3 and git diff HEAD~1\n3. Read every changed file\n\n## Review Focus\nFind every edge case that isn't handled, every naming inconsistency, every missing validation, every code smell. You care about error paths, boundary conditions, and things that will break at 2am. Rank findings by severity.", provider="openai", shape="box"];
  fresh_eyes [label="Squad: Fresh Eyes", model="gemini-3.1-flash-lite-preview", prompt="You are working in `run.working_dir`.\n\nYou have never seen this codebase before. Read the sprint output cold.\n\n## Context (MANDATORY)\n1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md\n2. Get the full diff: git log --oneline -3 and git diff HEAD~1\n3. Read every changed file\n\n## Review Focus\n- What's confusing?\n- What assumptions does the code make that aren't documented?\n- What would trip up a new contributor?\n- Focus on readability, structure, and whether the code is self-explanatory", provider="gemini", shape="box"];
  squad_join [label="squad_join", shape="tripleoctagon", sources="practical_dev,nitpicker,fresh_eyes"];
  review_parallel [label="review_parallel", shape="component", targets="review_haiku,review_nano"];
  review_haiku [label="Haiku Review", model="claude-haiku-4-5", prompt="You are working in `run.working_dir`.\n\n## IRON LAW: NO COMPLETION CLAIMS WITHOUT FRESH VERIFICATION\nRun commands. Read output. Check exit codes. THEN make claims.\n\n## Context (MANDATORY)\n1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md\n2. Get the full diff: git log --oneline -3 and git diff HEAD~1\n3. Read every changed file\n4. Run the test suite yourself\n\nDO NOT trust the implementer's claims. Verify independently.\nUse squad findings as additional context for your review.\n\n## Review Focus\n- Sprint doc checklist: is every DoD item genuinely satisfied?\n- Implementation correctness: does the code match the requirements?\n- Test quality: do tests cover the DoD items meaningfully?\n\n## Verdict\nReturn clear PASS or FAIL with specific reasoning. If FAIL, list required fixes.", provider="anthropic", shape="box"];
  review_nano [label="Nano Review", model="gpt-5.4-nano", prompt="You are working in `run.working_dir`.\n\n## IRON LAW: NO COMPLETION CLAIMS WITHOUT FRESH VERIFICATION\nRun commands. Read output. Check exit codes. THEN make claims.\n\n## Context (MANDATORY)\n1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md\n2. Get the full diff: git log --oneline -3 and git diff HEAD~1\n3. Read every changed file\n4. Run the test suite yourself\n\nDO NOT trust the implementer's claims. Verify independently.\nUse squad findings as additional context for your review.\n\n## Review Focus\n- Implementation quality: is the code clean, readable, well-structured?\n- Regression risk: could these changes break other sprints?\n- Edge cases: are error paths and boundary conditions handled?\n\n## Verdict\nReturn clear PASS or FAIL with specific reasoning. If FAIL, list required fixes.", provider="openai", shape="box"];
  reviews_join [label="reviews_join", shape="tripleoctagon", sources="review_haiku,review_nano"];
  cross_critique_parallel [label="cross_critique_parallel", shape="component", targets="haiku_critique_nano,nano_critique_haiku"];
  haiku_critique_nano [label="Haiku Critique of Nano Review", model="claude-haiku-4-5", prompt="Critique the Nano review for: missing checks, weak evidence, overly lenient verdicts, or mistaken conclusions. Be specific — cite what was missed and why it matters.", provider="anthropic", shape="box"];
  nano_critique_haiku [label="Nano Critique of Haiku Review", model="gpt-5.4-nano", prompt="Critique the Haiku review for: missing checks, weak evidence, overly lenient verdicts, or mistaken conclusions. Be specific — cite what was missed and why it matters.", provider="openai", shape="box"];
  critiques_join [label="critiques_join", shape="tripleoctagon", sources="haiku_critique_nano,nano_critique_haiku"];
  gate_cheap [label="Gate (Cheap)", model="claude-haiku-4-5", prompt="You are working in `run.working_dir`.\n\n## Task\nSynthesize all squad findings, reviews, and cross-critiques into a single verdict for this sprint.\n\n## Process\n1. Weight each review by the critiques it received — heavily critiqued reviews get less weight\n2. Identify consensus findings (multiple reviewers agree)\n3. Identify disputed findings (reviewers disagree) — resolve by examining the code yourself\n\n## Verdicts\n- **success**: Sprint is genuinely complete. All DoD items satisfied, tests pass, no regressions.\n- **retry**: Sprint needs rework. List specific findings that must be addressed.\n- **fail**: Sprint is blocked by something outside the implementation agent's control.", provider="anthropic", shape="box"];
  implement_rescue [label="Implement Sprint (Rescue)", model="claude-sonnet-4-6", prompt="You are working in `run.working_dir`.\n\n## ESCALATION\nCheap implementation failed after multiple attempts. You have all prior context — squad findings, review critiques, gate verdicts, and implementation history.\n\n## Task\nRead .ai/current_sprint_id.txt to get the sprint ID. Read the sprint doc at .ai/sprints/SPRINT-<id>.md. Fix the remaining issues definitively.\n\nThis is the last attempt before failure. Review all prior feedback carefully and address every outstanding finding.\n\n## Success Criteria\n- All DoD items checked off in the sprint doc\n- All tests pass\n- Linter passes\n- Expected artifacts exist", provider="anthropic", shape="box"];
  validate_rescue [label="Validate Rescue Build", shape="parallelogram", timeout="5m", tool_command="set +e\nfail=0\nif [ -f Package.swift ]; then\n  swift build 2>&1 || fail=1\n  swift test 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nif [ -f pyproject.toml ]; then\n  uv run pytest -v 2>&1 || fail=1\n  uv run ruff check . 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nif [ -f package.json ]; then\n  npm test 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nif [ -f Cargo.toml ]; then\n  cargo build 2>&1 || fail=1\n  cargo test 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nif [ -f go.mod ]; then\n  go build ./... 2>&1 || fail=1\n  go test ./... 2>&1 || fail=1\n  if [ \"$fail\" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi\n  exit 0\nfi\nprintf 'validation-pass-no-known-build-system'"];
  commit_rescue [label="Commit Rescue Work", model="gpt-5.4-nano", prompt="You are working in `run.working_dir`.\n\n## Task\nRead .ai/current_sprint_id.txt to get the sprint ID.\nReview all changes with git diff and git status.\nStage all relevant files and commit.\n\n## Rules\n- Use conventional commit format: feat(sprint-NNN): <description> [rescue]\n- Do NOT commit generated files, __pycache__, node_modules, .env, or build artifacts\n- If no changes exist, report that no commit was needed\n- Verify the commit succeeded with git log --oneline -1\n- Include the commit hash in your summary", provider="openai", shape="box"];
  rescue_review [label="Rescue Sanity Check", model="claude-haiku-4-5", prompt="You are working in `run.working_dir`.\n\nQuick sanity check on the rescue implementation. Read the sprint doc, check the diff, and verify the Sonnet rescue addressed the issues that caused cheap implementation to fail.\n\nReturn PASS if the sprint checklist is satisfied, FAIL if critical issues remain.", provider="anthropic", shape="box"];
  mark_complete [label="Complete Sprint", shape="parallelogram", timeout="10s", tool_command="set -eu\ntarget=$(cat .ai/current_sprint_id.txt)\nnow=$(date -u +%Y-%m-%dT%H:%M:%SZ)\nawk -F '\\t' -v OFS='\\t' -v target=\"$target\" -v now=\"$now\" '\nNR==1 {print; next}\n{ if ($1==target) { $3=\"completed\"; $5=now }; print }\n' .ai/ledger.tsv > .ai/ledger.tsv.tmp\nmv .ai/ledger.tsv.tmp .ai/ledger.tsv\nprintf 'completed-%s' \"$target\""];
  report_progress [label="Report Progress", shape="parallelogram", timeout="10s", tool_command="set -eu\ntotal=$(awk -F '\\t' 'NR>1' .ai/ledger.tsv | wc -l | tr -d ' ')\ndone=$(awk -F '\\t' 'NR>1 && ($3==\"completed\" || $3==\"skipped\")' .ai/ledger.tsv | wc -l | tr -d ' ')\nif [ \"$total\" -gt 0 ]; then\n  pct=$((done * 100 / total))\nelse\n  pct=0\nfi\nprintf 'progress-%s-of-%s-%spct' \"$done\" \"$total\" \"$pct\""];
  sprint_gate [label="Continue to Next Sprint?", shape="hexagon"];
  skip_gate [label="Skip Gate", shape="parallelogram", timeout="5s", tool_command="set -eu\nnow=$(date -u +%Y-%m-%dT%H:%M:%SZ)\ntarget=$(cat .ai/current_sprint_id.txt 2>/dev/null || echo \"unknown\")\nprintf 'continue\\t%s\\t%s\n' \"$target\" \"$now\""];
  failure_summary [label="Failure Summary", model="gpt-5.4-nano", prompt="You are working in `run.working_dir`.\n\nSprint execution failed. Diagnose what went wrong:\n\n1. Read .ai/current_sprint_id.txt to identify which sprint failed\n2. Read the sprint doc and the ledger\n3. Check git log for recent commits\n4. Examine build/test output if available\n\nReport:\n- Which sprint failed and why\n- What was completed before the failure\n- Concrete next steps for recovery\n- Whether downstream sprints are likely affected", provider="openai", shape="box"];

  Start -> check_ledger;
  check_ledger -> Exit [condition="tool_stdout = all_done", label="all_done"];
  check_ledger -> no_ledger_exit [condition="tool_stdout = no_ledger", label="no_ledger"];
  check_ledger -> read_sprint [condition="tool_stdout != all_done", label="next_sprint"];
  no_ledger_exit -> Exit;
  read_sprint -> mark_in_progress;
  read_sprint -> failure_summary;
  mark_in_progress -> implement_cheap;
  implement_cheap -> validate_build;
  validate_build -> commit_cheap [condition="tool_stdout startswith \"validation-pass\"", label="validated"];
  validate_build -> implement_cheap [condition="tool_stdout = validation-fail", label="fix_validation", restart="true", style="dashed"];
  validate_build -> failure_summary;
  commit_cheap -> failure_summary;
  commit_cheap -> squad_parallel;
  squad_parallel -> practical_dev;
  squad_parallel -> nitpicker;
  squad_parallel -> fresh_eyes;
  practical_dev -> squad_join;
  nitpicker -> squad_join;
  fresh_eyes -> squad_join;
  squad_join -> review_parallel;
  review_parallel -> review_haiku;
  review_parallel -> review_nano;
  review_haiku -> reviews_join;
  review_nano -> reviews_join;
  reviews_join -> cross_critique_parallel;
  cross_critique_parallel -> haiku_critique_nano;
  cross_critique_parallel -> nano_critique_haiku;
  haiku_critique_nano -> critiques_join;
  nano_critique_haiku -> critiques_join;
  critiques_join -> gate_cheap;
  gate_cheap -> mark_complete [condition="outcome = success", label="pass"];
  gate_cheap -> implement_cheap [condition="outcome = retry", label="rework", restart="true", style="dashed"];
  gate_cheap -> implement_rescue [condition="outcome = fail", label="escalate"];
  gate_cheap -> implement_rescue;
  implement_rescue -> validate_rescue;
  implement_rescue -> failure_summary;
  validate_rescue -> commit_rescue [condition="tool_stdout startswith \"validation-pass\"", label="rescue_validated"];
  validate_rescue -> failure_summary [condition="tool_stdout = validation-fail", label="rescue_failed"];
  validate_rescue -> failure_summary;
  commit_rescue -> failure_summary;
  commit_rescue -> rescue_review;
  rescue_review -> mark_complete [condition="outcome = success", label="rescue_pass"];
  rescue_review -> failure_summary [condition="outcome = fail", label="rescue_fail"];
  rescue_review -> failure_summary;
  mark_complete -> report_progress;
  report_progress -> sprint_gate;
  sprint_gate -> skip_gate [label="[S] Continue"];
  sprint_gate -> Exit [label="[A] Pause"];
  skip_gate -> check_ledger [restart="true", style="dashed"];
  failure_summary -> Exit;
}
