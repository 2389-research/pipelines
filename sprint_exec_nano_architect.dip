workflow SprintExecNanoArchitect
  goal: "Rich-sprint path — nano transcribes, nano generates, mini fixes, 5.4 rescues only if needed. Uses no flagship model on the happy path."
  start: Setup
  exit: Done

  defaults
    provider: openai
    fidelity: summary:low

  tool Setup
    label: "Setup Environment"
    timeout: 120s
    command:
      set -eu
      sprint=$(ls .ai/sprints/SPRINT-*.md 2>/dev/null | head -1)
      if [ -z "$sprint" ]; then echo "no sprint doc found"; exit 1; fi
      if grep -qi "typescript\|tsx\|npm\|node" "$sprint" 2>/dev/null; then
        npm install 2>/dev/null || true
      fi
      if grep -qi "python\|fastapi\|pytest\|pip" "$sprint" 2>/dev/null; then
        python3 -m venv .venv && .venv/bin/pip install -q fastapi httpx pytest pytest-asyncio pydantic uvicorn 2>/dev/null || true
      fi
      printf 'setup-done'

  agent Generate
    label: "Transcribe sprint + Generate (nano)"
    model: gpt-5.4-nano
    provider: openai
    max_turns: 3
    prompt:
      You are working in `run.working_dir`.

      The sprint doc at .ai/sprints/SPRINT-*.md is the contract. It already contains
      types, SQL schema, function signatures, test plan, and rules. Your only job is
      to pass that sprint to generate_code so nano can write the files.

      Steps:
      1. bash: cat .ai/sprints/SPRINT-*.md
      2. Call generate_code ONCE with:
         - contract: the full sprint text verbatim (do not rewrite)
         - output_dir: "."
         - files: one entry per path in Expected Artifacts:
           {"path": "<path>", "description": "per sprint contract"}
      3. STOP. Do not run tests. Do not cat files. The Fix node handles test failures.

      You have ONLY these tools: bash (for cat only), generate_code.
      Do NOT run tests. Do NOT use: read, glob, grep_search, write, apply_patch, edit.

  tool RunTests
    label: "Run Tests"
    timeout: 120s
    command:
      set +e
      if [ -f package.json ]; then
        npm test 2>&1
        if [ $? -eq 0 ]; then printf 'tests-pass'; else printf 'tests-fail'; fi
      elif [ -d .venv ]; then
        .venv/bin/python -m pytest tests/ -v 2>&1
        if [ $? -eq 0 ]; then printf 'tests-pass'; else printf 'tests-fail'; fi
      else
        printf 'no-test-runner'
      fi

  agent Fix
    label: "Fix (mini)"
    model: gpt-5.4-mini
    provider: openai
    max_turns: 8
    auto_status: true
    prompt:
      You are working in `run.working_dir`.

      Code was generated by nano from the sprint doc. Tests failed. Run them, read
      the tracebacks, apply surgical fixes with edit. Repeat until green.

      Steps:
      1. bash: npm test (or .venv/bin/python -m pytest tests/ -v)
      2. If all pass: STATUS: success
      3. If fail: use edit for targeted fixes. Re-run.
      4. After several failed attempts: STATUS: fail (escalates to Rescue)

      You have ONLY these tools: bash, edit.
      Do NOT use: read, glob, grep_search, write, apply_patch, generate_code.
      Never rewrite entire files.

  agent Rescue
    label: "Rescue (5.4)"
    model: gpt-5.4
    provider: openai
    max_turns: 10
    reasoning_effort: high
    prompt:
      You are working in `run.working_dir`.

      A cheaper model attempted to fix test failures and could not resolve them.
      Diagnose and fix the remaining issues.

      Steps:
      1. bash: run tests to see current failures
      2. If needed: bash: cat <specific failing file> to see its current state
      3. Use edit for surgical fixes only
      4. Re-run until green

      You have ONLY these tools: bash, edit.
      Do NOT use: read, glob, grep_search, write, apply_patch, generate_code.

  agent Done
    label: "Done"
    model: gpt-5.4-nano
    provider: openai
    prompt:
      Sprint execution complete (nano-architect tier).

  edges
    Setup -> Generate
    Generate -> RunTests
    Generate -> RunTests      when ctx.outcome = fail
    RunTests -> Fix           when ctx.tool_stdout contains tests-fail
    RunTests -> Done          when ctx.tool_stdout contains tests-pass
    RunTests -> Done
    Fix -> Done               when ctx.outcome = success
    Fix -> Rescue             when ctx.outcome = fail
    Fix -> Rescue
    Rescue -> Done
