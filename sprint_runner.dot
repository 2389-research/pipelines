digraph SprintRunner {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];
  Start [label="Start", shape="Mdiamond"];
  Exit [label="Exit", shape="Msquare"];
  check_ledger [label="Check Ledger", shape="parallelogram"];
  no_ledger_exit [label="No Ledger Found", shape="box"];
  read_sprint [label="Read Sprint", shape="box"];
  mark_in_progress [label="Mark In Progress", shape="parallelogram"];
  implement_sprint [label="Implement Sprint", shape="box"];
  validate_build [label="Validate Build and Tests", shape="parallelogram"];
  commit_work [label="Commit Sprint Work", shape="box"];
  review_parallel [label="review_parallel", shape="component"];
  review_claude [label="Claude Review", shape="box"];
  review_codex [label="Codex Review", shape="box"];
  review_gemini [label="Gemini Review", shape="box"];
  reviews_join [label="reviews_join", shape="tripleoctagon"];
  critiques_parallel [label="critiques_parallel", shape="component"];
  critique_claude_on_codex [label="Claude Critique of Codex", shape="box"];
  critique_claude_on_gemini [label="Claude Critique of Gemini", shape="box"];
  critique_codex_on_claude [label="Codex Critique of Claude", shape="box"];
  critique_codex_on_gemini [label="Codex Critique of Gemini", shape="box"];
  critique_gemini_on_claude [label="Gemini Critique of Claude", shape="box"];
  critique_gemini_on_codex [label="Gemini Critique of Codex", shape="box"];
  critiques_join [label="critiques_join", shape="tripleoctagon"];
  review_analysis [label="Review Analysis", shape="box"];
  mark_complete [label="Complete Sprint", shape="parallelogram"];
  report_progress [label="Report Progress", shape="parallelogram"];
  sprint_gate [label="Continue to Next Sprint?", shape="hexagon"];
  skip_gate [label="Skip Gate", shape="parallelogram"];
  failure_summary [label="Failure Summary", shape="box"];

  Start -> check_ledger;
  check_ledger -> Exit [condition="tool_stdout = all_done", label="all_done"];
  check_ledger -> no_ledger_exit [condition="tool_stdout = no_ledger", label="no_ledger"];
  check_ledger -> read_sprint [condition="tool_stdout != all_done", label="next_sprint"];
  no_ledger_exit -> Exit;
  read_sprint -> mark_in_progress;
  mark_in_progress -> implement_sprint;
  implement_sprint -> validate_build;
  validate_build -> commit_work [condition="tool_stdout startswith \"validation-pass\"", label="validated"];
  validate_build -> implement_sprint [condition="tool_stdout = validation-fail", label="fix_validation", restart="true", style="dashed"];
  validate_build -> failure_summary;
  commit_work -> review_parallel;
  review_parallel -> review_claude;
  review_parallel -> review_codex;
  review_parallel -> review_gemini;
  review_claude -> reviews_join;
  review_codex -> reviews_join;
  review_gemini -> reviews_join;
  reviews_join -> critiques_parallel;
  critiques_parallel -> critique_claude_on_codex;
  critiques_parallel -> critique_claude_on_gemini;
  critiques_parallel -> critique_codex_on_claude;
  critiques_parallel -> critique_codex_on_gemini;
  critiques_parallel -> critique_gemini_on_claude;
  critiques_parallel -> critique_gemini_on_codex;
  critique_claude_on_codex -> critiques_join;
  critique_claude_on_gemini -> critiques_join;
  critique_codex_on_claude -> critiques_join;
  critique_codex_on_gemini -> critiques_join;
  critique_gemini_on_claude -> critiques_join;
  critique_gemini_on_codex -> critiques_join;
  critiques_join -> review_analysis;
  review_analysis -> mark_complete [condition="outcome = success", label="pass"];
  review_analysis -> implement_sprint [condition="outcome = retry", label="rework", restart="true", style="dashed"];
  review_analysis -> failure_summary [condition="outcome = fail", label="fail"];
  review_analysis -> failure_summary;
  mark_complete -> report_progress;
  report_progress -> sprint_gate;
  sprint_gate -> skip_gate [label="[S] Continue"];
  sprint_gate -> Exit [label="[A] Pause"];
  skip_gate -> check_ledger [restart="true", style="dashed"];
  failure_summary -> Exit;
}
