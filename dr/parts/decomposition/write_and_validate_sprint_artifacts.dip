# ABOUTME: Sprint artifact write/validate/repair cluster — extracted from spec_to_sprints for composable iteration.
# ABOUTME: Validate-first design: enters at validate_output, branches to write_sprint_docs / RewriteOutput / EscalateOutput / commit_output as needed.
workflow WriteAndValidateSprintArtifacts
  goal: "Produce a complete, validated set of .ai/sprints/SPRINT-*.{yaml,md} and .ai/ledger.yaml. Validates first (so a fixture with already-good files passes through cleanly), falls back to write_sprint_docs → write_ledger → re-validate on failure, escalates to RewriteOutput at attempt 3 and to EscalateOutput at attempt 5."
  start: Start
  exit: Exit

  defaults
    max_restarts: 10
    fidelity: summary:medium

  agent Start
    label: Start
    max_turns: 1
    prompt:
      Acknowledge that the write/validate/repair cluster is starting.

      HARD CONSTRAINT: Do NOT read any files. Do NOT write any files. Do NOT create, modify, or delete anything. Do NOT call any tools. Your ONLY job is to emit a one-line acknowledgement.

  agent Exit
    label: Exit
    max_turns: 1
    prompt:
      Acknowledge that the write/validate/repair cluster has finished.

      HARD CONSTRAINT: Do NOT read any files. Do NOT write any files. Do NOT create, modify, or delete anything. Do NOT call any tools. Your ONLY job is to emit a one-line acknowledgement.

  agent write_sprint_docs
    label: "Write Sprint Docs"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    reads: sprint_plan, spec_analysis
    fallback_target: Exit
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Read .ai/sprint_plan.md and .ai/spec_analysis.md. For each sprint in the plan, write TWO files under .ai/sprints/:

      ### 1. SPRINT-<id>.md (narrative — same format as before)
      ```
      # Sprint NNN — Title

      ## Scope
      What this sprint delivers (2-3 sentences).

      ## Non-goals
      - What is explicitly excluded

      ## Requirements
      - FR IDs covered, with one-line descriptions

      ## Dependencies
      - Sprint numbers that must complete first (or "None")

      ## Expected Artifacts
      - Specific file paths

      ## DoD
      - [ ] Checkable item 1
      - [ ] Checkable item 2

      ## Validation
      - Exact commands
      ```

      ### 2. SPRINT-<id>.yaml (structured contract)
      ```yaml
      id: "NNN"
      title: "Sprint Title"
      status: planned
      bootstrap: true/false
      complexity: low/medium/high

      depends_on: ["000", "001"]
      dependents: ["004", "005"]

      stack:
        lang: python|javascript|swift|rust|go|null
        runner: uv|npm|swiftpm|cargo|go|null
        test: pytest|vitest|jest|swift-test|cargo-test|go-test|null
        lint: ruff|eslint|swiftlint|clippy|golangci-lint|null
        build: null
        services: []

      scope_fence:
        off_limits:
          - "do not modify .ai/ledger.yaml"
          - "do not implement sprint NNN+1 or later"
          - "do not add features beyond scope"
        touch_only: []

      entry_preconditions:
        files_must_exist: []
        sprints_must_be_complete: ["000"]

      artifacts:
        creates:
          - path: "path/to/file"
            type: module
        modifies: []

      validation:
        commands:
          - cmd: "exact command here"
            expect: exit_0

      dod:
        - "First checkable item"
        - "Second checkable item"

      history:
        attempts: []
      ```

      ## Rules
      - CRITICAL: All files MUST be written to .ai/sprints/ — NEVER to the project root
      - File paths: .ai/sprints/SPRINT-000.md, .ai/sprints/SPRINT-000.yaml, etc.
      - IDs MUST be zero-padded 3-digit: 000, 001, ... 016
      - The YAML must have ALL fields shown above — no missing sections
      - `stack.lang`, `stack.runner`, `stack.test`, `stack.lint`, and `stack.build` must be populated from the Tech Stack section of .ai/spec_analysis.md. Use `null` only when the spec analysis truly does not provide enough information.
      - `scope_fence.off_limits` must always include "do not modify .ai/ledger.yaml"
      - `entry_preconditions.sprints_must_be_complete` must match `depends_on`
      - `dependents` is the reverse index of `depends_on` — compute it from the full sprint list
      - `validation.commands` must have exact, runnable commands — not pseudocode
      - `stack.services` should list any external services this sprint introduces (database, message broker, etc.)
      - Bootstrap sprints (000-002) must have `bootstrap: true`
      - Write ALL sprint docs in one pass for cross-sprint consistency
      - Do NOT write or modify .ai/ledger.yaml — a separate tool handles that

  tool write_ledger
    label: "Write Ledger"
    timeout: 30s
    command:
      set -eu
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      stack_lang=$(yq '.stack.lang // "null" | @json' .ai/sprints/SPRINT-000.yaml 2>/dev/null || echo '"null"')
      stack_runner=$(yq '.stack.runner // "null" | @json' .ai/sprints/SPRINT-000.yaml 2>/dev/null || echo '"null"')
      stack_test=$(yq '.stack.test // "null" | @json' .ai/sprints/SPRINT-000.yaml 2>/dev/null || echo '"null"')
      stack_lint=$(yq '.stack.lint // "null" | @json' .ai/sprints/SPRINT-000.yaml 2>/dev/null || echo '"null"')
      stack_build=$(yq '.stack.build // "null" | @json' .ai/sprints/SPRINT-000.yaml 2>/dev/null || echo '"null"')
      printf 'project:\n  name: "Unknown"\n  stack:\n    lang: %s\n    runner: %s\n    test: %s\n    lint: %s\n    build: %s\n  created_at: "%s"\n\nsprints:\n' "$stack_lang" "$stack_runner" "$stack_test" "$stack_lint" "$stack_build" "$now" > .ai/ledger.yaml
      for f in .ai/sprints/SPRINT-*.yaml; do
        [ -f "$f" ] || continue
        case "$(basename "$f" .yaml)" in SPRINT-[0-9A-Z]) ;; SPRINT-[0-9][0-9A-Z]) ;; SPRINT-[0-9][0-9][0-9A-Z]) ;; *) continue ;; esac
        id=$(yq '.id' "$f")
        title=$(yq '.title | @json' "$f")
        bootstrap=$(yq '.bootstrap // false' "$f")
        complexity=$(yq '.complexity // "medium"' "$f")
        deps=$(yq '.depends_on // [] | @json' "$f")
        printf '  - id: "%s"\n    title: %s\n    status: planned\n    bootstrap: %s\n    depends_on: %s\n    complexity: %s\n    created_at: "%s"\n    updated_at: "%s"\n    attempts: 0\n    total_cost: "0.00"\n' "$id" "$title" "$bootstrap" "$deps" "$complexity" "$now" "$now" >> .ai/ledger.yaml
      done
      count=$(yq '.sprints | length' .ai/ledger.yaml)
      printf 'wrote-%s-sprints' "$count"

  tool validate_output
    label: "Validate Output"
    timeout: 30s
    command:
      set -eu
      errors=""
      stray=$(ls SPRINT-*.md SPRINT-*.yaml 2>/dev/null | wc -l | tr -d ' ')
      if [ "$stray" -gt 0 ]; then
        errors="${errors}sprint-files-in-root "
      fi
      ledger_ids=$(yq '.sprints[].id' .ai/ledger.yaml 2>/dev/null | sort || echo "")
      yaml_ids=$(ls .ai/sprints/SPRINT-*.yaml 2>/dev/null | sed 's|.*/SPRINT-||;s|\.yaml||' | grep -E '^[0-9A-Z]{1,3}$' | sort)
      md_ids=$(ls .ai/sprints/SPRINT-*.md 2>/dev/null | sed 's|.*/SPRINT-||;s|\.md||' | grep -E '^[0-9A-Z]{1,3}$' | sort)
      if [ "$ledger_ids" != "$yaml_ids" ]; then
        errors="${errors}ledger-yaml-mismatch "
      fi
      if [ "$ledger_ids" != "$md_ids" ]; then
        errors="${errors}ledger-md-mismatch "
      fi
      for f in .ai/sprints/SPRINT-*.yaml; do
        [ -f "$f" ] || continue
        case "$(basename "$f" .yaml)" in SPRINT-[0-9A-Z]) ;; SPRINT-[0-9][0-9A-Z]) ;; SPRINT-[0-9][0-9][0-9A-Z]) ;; *) continue ;; esac
        base=$(basename "$f")
        if ! yq -e '.' "$f" >/dev/null 2>&1; then
          errors="${errors}invalid-yaml-${base} "
          continue
        fi
        if ! yq -e '.id' "$f" >/dev/null 2>&1; then errors="${errors}missing-id-${base} "; fi
        if ! yq -e '.title' "$f" >/dev/null 2>&1; then errors="${errors}missing-title-${base} "; fi
        if ! yq -e '.status' "$f" >/dev/null 2>&1; then errors="${errors}missing-status-${base} "; fi
        if ! yq -e '.stack.lang' "$f" >/dev/null 2>&1; then errors="${errors}missing-stack-lang-${base} "; fi
        if ! yq -e '.stack.runner' "$f" >/dev/null 2>&1; then errors="${errors}missing-stack-runner-${base} "; fi
        if ! yq -e '.stack.test' "$f" >/dev/null 2>&1; then errors="${errors}missing-stack-test-${base} "; fi
        if ! yq -e '.stack.lint' "$f" >/dev/null 2>&1; then errors="${errors}missing-stack-lint-${base} "; fi
        if ! yq -e '.stack.build' "$f" >/dev/null 2>&1; then errors="${errors}missing-stack-build-${base} "; fi
        if [ "$base" = "SPRINT-000.yaml" ]; then
          for field in lang runner test lint; do
            value=$(yq ".stack.${field}" "$f" 2>/dev/null || printf 'null')
            if [ "$value" = "null" ]; then
              errors="${errors}null-stack-${field}-${base} "
            fi
          done
        fi
        if ! yq -e '.validation.commands' "$f" >/dev/null 2>&1; then errors="${errors}missing-validation-${base} "; fi
        if ! yq -e '.dod' "$f" >/dev/null 2>&1; then errors="${errors}missing-dod-${base} "; fi
        if ! yq -e '.scope_fence' "$f" >/dev/null 2>&1; then errors="${errors}missing-scope-fence-${base} "; fi
        if ! yq -e '.artifacts' "$f" >/dev/null 2>&1; then errors="${errors}missing-artifacts-${base} "; fi
      done
      for f in .ai/sprints/SPRINT-*.md; do
        [ -f "$f" ] || continue
        case "$(basename "$f" .md)" in SPRINT-[0-9A-Z]) ;; SPRINT-[0-9][0-9A-Z]) ;; SPRINT-[0-9][0-9][0-9A-Z]) ;; *) continue ;; esac
        base=$(basename "$f")
        for section in "## Scope" "## Requirements" "## Dependencies" "## Expected Artifacts" "## DoD" "## Validation"; do
          if ! grep -q "$section" "$f"; then
            tag=$(printf '%s' "$section" | sed 's/## //' | tr ' ' '-' | tr '[:upper:]' '[:lower:]')
            errors="${errors}missing-${tag}-${base} "
          fi
        done
      done
      if [ -z "$(yq '.sprints[]' .ai/ledger.yaml 2>/dev/null)" ]; then
        errors="${errors}empty-ledger "
      fi
      bootstrap_count=$(yq '[.sprints[] | select(.bootstrap == true)] | length' .ai/ledger.yaml 2>/dev/null || echo 0)
      if [ "$bootstrap_count" -lt 2 ]; then
        errors="${errors}insufficient-bootstrap-sprints "
      fi
      for f in .ai/sprints/SPRINT-*.yaml; do
        [ -f "$f" ] || continue
        case "$(basename "$f" .yaml)" in SPRINT-[0-9A-Z]) ;; SPRINT-[0-9][0-9A-Z]) ;; SPRINT-[0-9][0-9][0-9A-Z]) ;; *) continue ;; esac
        base=$(basename "$f")
        dod_count=$(yq '.dod | length' "$f" 2>/dev/null || echo 0)
        if [ "$dod_count" -gt 15 ]; then
          errors="${errors}oversized-sprint-${base}-${dod_count}-dod-items "
        fi
      done
      # Capstone check: last sprint must depend on all other sprints — auto-fix if wrong
      if yq -e '.sprints[-1].id' .ai/ledger.yaml >/dev/null 2>&1; then
        all_ids=$(yq '.sprints[].id' .ai/ledger.yaml | sort)
        last_id=$(yq '.sprints[-1].id' .ai/ledger.yaml)
        other_ids=$(printf '%s' "$all_ids" | grep -v "^${last_id}$" | sort)
        capstone_deps=$(yq ".sprints[-1].depends_on[]" .ai/ledger.yaml 2>/dev/null | sort)
        if [ "$other_ids" != "$capstone_deps" ]; then
          yq -i "(.sprints[-1]).depends_on = []" .ai/ledger.yaml
          for dep_id in $other_ids; do
            yq -i "(.sprints[-1]).depends_on += [\"$dep_id\"]" .ai/ledger.yaml
          done
          capstone_yaml=".ai/sprints/SPRINT-${last_id}.yaml"
          if [ -f "$capstone_yaml" ]; then
            yq -i ".depends_on = []" "$capstone_yaml"
            for dep_id in $other_ids; do
              yq -i ".depends_on += [\"$dep_id\"]" "$capstone_yaml"
            done
          fi
        fi
      fi
      attempt_file=".ai/.validate-output-attempts.txt"
      if [ -n "$errors" ]; then
        attempts=$(cat "$attempt_file" 2>/dev/null || echo 0)
        attempts=$((attempts + 1))
        echo "$attempts" > "$attempt_file"
        printf '\n--- validate_output attempt %s ---\n' "$attempts" >&2
        if [ "$attempts" -ge 5 ]; then
          printf 'escalate-output-%s' "$errors"
        elif [ "$attempts" -ge 3 ]; then
          printf 'rewrite-output-%s' "$errors"
        else
          printf 'invalid-%s' "$errors"
        fi
        exit 0
      fi
      rm -f "$attempt_file"
      printf 'valid'

  agent RewriteOutput
    label: "Rewrite sprint output to fix validation errors"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: high
    fidelity: full
    max_turns: 30
    prompt:
      validate_output has failed 3 consecutive times. Apply surgical fixes
      to the existing files. Do NOT rewrite from scratch — that approach
      has already failed three times.

      ## STEP 1 — Read the error-token taxonomy

      Your FIRST tool call MUST be reading this file:

          dr/docs/validation_error_taxonomy.md

      It contains the complete mapping of every error token to its fix
      recipe. The token alone is the fix instruction. DO NOT search the
      codebase for the validator script; DO NOT grep for the error
      strings. The taxonomy file is authoritative.

      ## STEP 2 — Read the actual errors

      The validate_output stdout from the previous tool call is in your
      context (look at `episode_summaries` / `last_response`). It's a
      space-separated list of tokens after `invalid-`. Parse it.

      You may also want:
      - `ls .ai/sprints/` to see the current sprint files
      - `.ai/spec_analysis.md` to find canonical stack values (lang,
        runner, test, lint, build) when populating null/missing stack
        fields

      ## STEP 3 — Apply fixes in batches by category

      Group error tokens by the recipe section in the taxonomy. Loop
      through each category with a single small script when possible
      (e.g., one bash for-loop that handles all `missing-scope-*.md`
      tokens, another for `missing-stack-build-*.yaml`, etc.). This is
      faster and more reliable than per-token tool calls.

      ## STEP 4 — Verify before exiting

      For each category you touched, run the verification command from
      the taxonomy (e.g., `yq -e '.dod' file.yaml` for `missing-dod`
      tokens). Don't claim success until verification passes for every
      token you addressed.

      ## Hard rules (also in the taxonomy, repeating here for clarity)

      - DO NOT rewrite files from scratch — only surgical patches.
      - DO NOT change SPRINT IDs or the number of sprints.
      - DO NOT touch .ai/spec_analysis.md or .ai/sprint_plan.md.
      - DO NOT modify project source files outside .ai/.
      - Use `yq -i` for in-place YAML edits.

      ## Turn budget awareness

      You have 30 turns. If you find yourself spending turns searching
      for "where does this error come from" — STOP. Re-read the
      taxonomy. The token is the fix.

      If you genuinely cannot fix something (e.g., a token shape not
      covered in the taxonomy), STATUS:fail with a specific note about
      which token blocked you. EscalateOutput will pick it up. Better
      to escalate with a clear handoff than burn turns guessing.

  human EscalateOutput
    label: "Sprint output validation stuck — pick how to proceed"
    mode: freeform
    default: rewrite
    prompt:
      validate_output has failed repeatedly and the rewriter could not
      get the sprint files clean. Latest validation errors are in the
      tool_stdout from the prior validate_output call.

      The current state is available on disk for inspection:
      - `.ai/sprints/SPRINT-*.{yaml,md}` — generated sprint files (open in editor before deciding)
      - `.ai/ledger.yaml` — current ledger
      - `.ai/.validate-output-attempts.txt` — counter (cat to see how many cycles we've burned)
      - `dr/docs/validation_error_taxonomy.md` — the error-token decoder

      Options:
      - **retry**: Re-run validate_output as-is. Useful if you've fixed something by hand.
      - **rewrite**: Run the validation rewriter again (same as automatic recovery, fresh attempt).
      - **ship-as-is**: Commit the current output despite validation errors. The runner pipeline can deal with imperfect sprints downstream.
      - **abort**: Kill the run and bail.

  tool commit_output
    label: "Commit Output"
    timeout: 30s
    command:
      set -eu
      if [ ! -d .git ]; then
        printf 'no-git-skipped'
        exit 0
      fi
      for f in .ai/ledger.yaml .ai/sprints .ai/spec_analysis.md .ai/sprint_plan.md; do
        [ -e "$f" ] && git add "$f"
      done
      if git diff --cached --quiet; then
        printf 'no-changes-skipped'
        exit 0
      fi
      count=$(yq '.sprints | length' .ai/ledger.yaml)
      git commit -m "feat(sprints): decompose spec into ${count} sprints (YAML format)"
      printf 'committed-%s-sprints' "$count"

  edges
    Start -> validate_output                 when ctx.outcome = success
    Start -> Exit                            when ctx.outcome = fail   label: start_failed
    Start -> validate_output

    validate_output -> commit_output         when ctx.tool_stdout = valid                          label: valid
    validate_output -> EscalateOutput        when ctx.tool_stdout startswith escalate-output       label: escalate
    validate_output -> RewriteOutput         when ctx.tool_stdout startswith rewrite-output        label: rewrite
    validate_output -> write_sprint_docs     when ctx.tool_stdout startswith invalid               label: fix_validation  restart: true
    validate_output -> write_sprint_docs     restart: true

    write_sprint_docs -> Exit                when ctx.outcome = fail   label: write_docs_failed
    write_sprint_docs -> write_ledger        when ctx.outcome = success
    write_sprint_docs -> write_ledger

    write_ledger -> validate_output

    RewriteOutput -> validate_output         when ctx.outcome = success  label: rewrote_output  restart: true
    RewriteOutput -> EscalateOutput          when ctx.outcome = fail     label: rewrite_failed

    EscalateOutput -> validate_output        label: "retry"        restart: true
    EscalateOutput -> RewriteOutput          label: "rewrite"      restart: true
    EscalateOutput -> commit_output          label: "ship-as-is"
    EscalateOutput -> Exit                   label: "abort"

    commit_output -> Exit
