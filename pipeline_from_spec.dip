# ABOUTME: Meta-pipeline that generates validated, high-quality Dippin workflow files from project specs.
# ABOUTME: Implements an autoresearch-inspired generate-validate-score-refine loop.

workflow PipelineFromSpec
  goal: "A validated, high-quality pipeline .dip file exists in the working directory, generated from the spec, scoring quality_high on objective pattern and coverage metrics"
  start: find_spec
  exit: done

  defaults
    model: claude-sonnet-4-5
    provider: anthropic
    max_retries: 3

  # ==========================
  # FIND SPEC
  # ==========================
  tool find_spec
    label: "Find Spec File"
    command:
      #!/bin/sh
      set -eu
      for f in spec.md SPEC.md design.md design-doc.md specification.md requirements.md prompt_plan.md; do
        if [ -f "$f" ]; then
          printf '%s' "$f"
          exit 0
        fi
      done
      first=$(find . -maxdepth 2 -name '*.md' -not -path './.git/*' -not -path './docs/plans/*' | head -1)
      if [ -n "$first" ]; then
        printf '%s' "$first"
        exit 0
      fi
      printf 'no_spec_found'

  # ==========================
  # ANALYZE SPEC
  # ==========================
  agent analyze_spec
    label: "Analyze Spec"
    model: claude-opus-4-6
    reasoning_effort: high
    goal_gate: true
    retry_target: analyze_spec
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Read the spec file in the working directory and produce a structured analysis for pipeline generation.

      ## Process
      1. List markdown files and read the spec (the previous pipeline step already confirmed one exists)
      2. Extract and write to docs/plans/spec_analysis.md:

      ### Project Name
      [name from spec]

      ### Tech Stack
      - Language: [e.g., Python 3.12]
      - Framework: [e.g., stdlib http.server]
      - Database: [e.g., SQLite 3]
      - Test framework: [e.g., pytest]
      - Linter: [e.g., ruff]
      - Type checker: [e.g., mypy]
      - Package manager: [e.g., uv]
      - Other deps: [list]

      ### Components (numbered)
      For each component:
      - Name
      - Description (1 line)
      - Dependencies (which other components it needs)

      ### Dependency Graph
      Draw the dependency graph in text: which components can run in parallel, which must be sequential.

      ### Infrastructure Dependencies (for testing)
      List any services that need local emulators or daemons for tests to run:
      - [e.g., Firestore emulator on localhost:8080]
      - [e.g., Postgres on localhost:5432]
      - [e.g., Redis on localhost:6379]
      Include the start command and health check for each.

      ### Scope Analysis (v1 vs later)
      - IN: [components strictly needed for v1 MVP]
      - OUT: [components that can be deferred — integrations, nice-to-haves]
      - Justification for each CUT

      ### Pipeline Topology
      Based on component count and dependencies, recommend:
      - LINEAR: 1-3 components, simple deps
      - FAN_OUT: 4-8 components, shared foundation, independent features
      - DAG: 8+ components with cross-dependencies

      3. Commit: git add -A && git commit -m 'docs(analysis): spec analysis for pipeline generation'

      ## Success Criteria
      - docs/plans/spec_analysis.md exists with all sections filled in
      - No handwaving — every component named, every dependency mapped

  # ==========================
  # CHECK ANALYSIS EXISTS
  # ==========================
  tool check_analysis
    label: "Check Analysis File"
    command:
      #!/bin/sh
      set -eu
      if [ -f docs/plans/spec_analysis.md ] && [ -s docs/plans/spec_analysis.md ]; then
        printf 'analysis_ready'
      else
        printf 'analysis_missing'
      fi

  # ==========================
  # GENERATE DIP FILE
  # ==========================
  agent generate_dip
    label: "Generate Pipeline Dip"
    model: claude-opus-4-6
    goal_gate: true
    retry_target: generate_dip
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Read docs/plans/spec_analysis.md and generate a pipeline .dip file using the Dippin workflow language.

      ## Dippin Syntax Reference

      ### Structure
      ```
      workflow <Name>
        goal: "<text>"
        start: <NodeID>
        exit: <NodeID>

        defaults
          model: <string>
          provider: <string>

        <kind> <NodeID>
          <field>: <value>
          <multiline_field>:
            <indented content>

        parallel <ID> -> <Target1>, <Target2>[, ...]
        fan_in <ID> <- <Source1>, <Source2>[, ...]

        edges
          <From> -> <To> [when <condition>] [label: <text>] [weight: <int>]
      ```

      ### Node Kinds
      | Kind | Purpose | Required Fields | Optional Fields |
      |------|---------|----------------|-----------------|
      | agent | LLM coding/review tasks | prompt | model, provider, goal_gate, retry_target, max_retries, reasoning_effort, fidelity, max_turns, system_prompt, auto_status |
      | human | Human gate | mode (freeform or choice) | default |
      | tool | Shell command | command | timeout (e.g. 30s, 2m, 120s) |
      | parallel | Fan-out (parallel start) | -> Target1, Target2 (inline) | — |
      | fan_in | Fan-in (parallel join) | <- Source1, Source2 (inline) | — |

      All kinds also accept: label, reads, writes, retry_policy, max_retries, base_delay, retry_target, fallback_target.

      ### Edge Condition Syntax
      ```
      when ctx.outcome = success
      when ctx.outcome = fail
      when ctx.outcome != success
      when ctx.tool_stdout = value
      when ctx.tool_stdout != value
      ```
      Operators: =, ==, !=, <, >, <=, >=, contains, startswith, endswith, in
      Variables MUST be namespace-qualified: ctx.outcome, ctx.tool_stdout, ctx.status

      ### Validation
      Use `dippin check pipeline.dip` to validate. It outputs JSON with valid/errors/diagnostics.

      ## MANDATORY PATTERNS — Include ALL of These

      ### 1. Resume Support (first node after start)
      ```
      tool check_existing
        label: "Check Existing Plans"
        command:
          #!/bin/sh
          if [ -f docs/plans/plan.md ] && grep -q '^- \[ \]' docs/plans/plan.md 2>/dev/null; then
            printf 'resume'
          else
            printf 'fresh'
          fi
      ```

      ### 2. Scope Gating (before planning, for large specs)
      scope_analysis agent node with reasoning_effort: high that writes docs/plans/scope.md with IN/OUT sections.

      ### 3. Per-Phase Verification Gates
      After EVERY implement node, add an agent verify node with auto_status: true:
      ```
      agent verify_X
        auto_status: true
        label: "X Tests Pass?"
        prompt:
          Run tests + linter for component X. If ALL pass: set STATUS: success. If ANY fail: set STATUS: fail.
      ```
      Or use a tool node for deterministic verification:
      ```
      tool verify_X
        label: "X Tests Pass?"
        timeout: 120s
        command:
          #!/bin/sh
          set +e
          fail=0
          go test ./internal/X/... -v >&2 || fail=1
          golangci-lint run ./internal/X/... >&2 || fail=1
          if [ "$fail" -eq 0 ]; then printf 'pass'; else printf 'fail'; fi
      ```
      With edges:
      ```
      verify_X -> commit_X  when ctx.outcome = success  weight: 2
      verify_X -> implement_X  when ctx.outcome = fail
      ```
      (For tool verify nodes, use `ctx.tool_stdout` instead of `ctx.outcome`)

      ### 4. Graduated Escalation (at the end)
      ```
      debug_investigate -> e2e  when ctx.outcome = success
      debug_investigate -> replan  when ctx.outcome = fail
      replan -> e2e  when ctx.outcome = success
      replan -> done  when ctx.outcome = fail
      ```

      ### 5. Budget Tracking (before E2E retry loop)
      ```
      tool check_budget
        label: "Check Retry Budget"
        command:
          #!/bin/sh
          set -eu
          mkdir -p .tracker
          COUNTER='.tracker/e2e_count'
          count=0
          [ -f "$COUNTER" ] && count=$(cat "$COUNTER")
          count=$((count + 1))
          printf '%s' "$count" > "$COUNTER"
          if [ "$count" -gt 5 ]; then
            printf 'budget_exhausted'
          else
            printf 'budget_ok'
          fi
      ```

      ### 6. Stdout Hygiene for ALL tool command Scripts
      The pipeline engine matches ctx.tool_stdout EXACTLY. If a tool command prints anything besides the routing token to stdout, the condition will never match and the pipeline STALLS SILENTLY. Rules:
      - ALL command output (tests, linters, builds) MUST go to stderr via >&2
      - stdout MUST contain ONLY the routing token (e.g., printf 'pass', printf 'fail')
      - NEVER use 2>&1 — it merges noisy output into stdout and breaks routing
      - Example: go test ./... >&2 || fail=1 (output to stderr, capture exit code)

      ### 7. Language-Aware Build Validation (before final review, follows stdout hygiene)
      IMPORTANT: validate_build must output 'validation-pass', 'validation-fail', or 'validation-unknown'. Do NOT use 'exit 1' on test/lint failure — that crashes the node instead of routing. Capture exit codes and branch on them:
      ```
      tool validate_build
        label: "Validate Full Build"
        timeout: 120s
        command:
          #!/bin/sh
          set +e
          fail=0
          if [ -f pyproject.toml ]; then
            uv run pytest -v >&2 || fail=1
            uv run ruff check . >&2 || fail=1
            if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
          elif [ -f go.mod ]; then
            go build ./... >&2 && go test ./... >&2 || fail=1
            if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
          elif [ -f package.json ]; then
            npm test >&2 || fail=1
            if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
          else
            printf 'validation-unknown'
          fi
      ```

      ### 8. Timeout Budget for Verify Nodes
      The default tool command timeout is 30s. This is NOT enough for verify nodes that run multiple heavy tools sequentially. Set explicit timeouts:
      - Go (go test + golangci-lint): timeout: 120s
      - TypeScript/Node (vitest + tsc --noEmit + eslint): timeout: 120s
      - Rust (cargo test + cargo clippy): timeout: 180s
      - Python (pytest + ruff/mypy): timeout: 60s
      - Java/Kotlin (gradle test + lint): timeout: 180s

      ### 9. Infrastructure Prerequisites for Testing
      If the tech stack includes services that need local emulators or daemons for testing (Firestore, Postgres, Redis, NATS, etc.), every verify tool command MUST start or verify the service is running BEFORE executing tests. Example:
      ```
      tool verify_X
        label: "X Tests Pass?"
        timeout: 120s
        command:
          #!/bin/sh
          set +e
          fail=0
          # Start emulator if not running
          if ! curl -s http://localhost:8080/ >/dev/null 2>&1; then
            gcloud emulators firestore start --host-port=localhost:8080 >&2 &
            sleep 3
          fi
          export FIRESTORE_EMULATOR_HOST=localhost:8080
          go test ./internal/X/... -v >&2 || fail=1
          golangci-lint run ./internal/X/... >&2 || fail=1
          if [ "$fail" -eq 0 ]; then printf 'pass'; else printf 'fail'; fi
      ```
      Do NOT assume infrastructure is already running from a previous node — each verify node must be self-contained.

      ### 10. Review That Reads Code (final review prompt must include)
      ## IRON LAW: NO COMPLETION CLAIMS WITHOUT FRESH VERIFICATION
      Run commands. Read output. Check exit codes. THEN make claims.
      1. Get full diff  2. Read every changed file  3. Run test suite
      DO NOT trust implementer claims. Verify independently.

      ## Prompt Requirements for EVERY agent Node
      1. Start with: You are working in `run.working_dir`.
      2. Include ## Tech Stack with language, framework, deps from spec_analysis.md
      3. Include ## Process with TDD: Write failing tests FIRST
      4. Include ## Success Criteria
      5. Every agent node doing implementation MUST have goal_gate: true and retry_target pointing to itself or parent implement node

      ## Topology Rules (from spec_analysis.md)
      - LINEAR: start -> plan -> setup -> implement -> verify -> commit -> review -> done
      - FAN_OUT: foundation -> parallel P -> [impl nodes] -> fan_in J -> verify -> commit
      - DAG: Multiple parallel/fan_in with fan_in join nodes modeling real dependencies

      ## Commit Nodes
      After every implement+verify phase, add a commit node:
      ```
      agent commit_X
        goal_gate: true
        retry_target: implement_X
        label: "Commit X"
        prompt:
          ...git add -A && git commit -m 'type(scope): description'...
      ```

      ## Output
      Write the workflow file to pipeline.dip in the working directory root.
      Name the workflow Build_[ProjectName] (PascalCase).

      ## Worklog
      Append a generation summary to docs/plans/generation_worklog.md:
      - Timestamp, topology chosen, number of nodes/edges
      - Which patterns were included
      - Any decisions or tradeoffs made

      ## DO NOT
      - Invent fields not in the reference
      - Use bare variable names in edge conditions (use ctx.outcome, not outcome)
      - Leave agent nodes without goal_gate + retry_target
      - Create human gates unless the spec explicitly requests them (default: fully autonomous/headless)
      - Write prompts that assume context from other nodes (each prompt is self-contained)
      - Use 'exit 1' in tool command scripts to signal failure — output a routable string instead
      - Use '2>&1' in tool command scripts — this merges command output into stdout and breaks ctx.tool_stdout routing. Redirect noisy command output to stderr with '>&2' and reserve stdout for ONLY the routing token
      - Use parallel without a matching fan_in (every parallel P -> A, B needs fan_in J <- A, B)

      ## Success Criteria
      - pipeline.dip exists in working directory root
      - dippin check pipeline.dip reports valid
      - Contains all mandatory patterns
      - Every agent node has goal_gate + retry_target
      - Every implement phase has verify + commit node

  # ==========================
  # VALIDATE (does it parse?)
  # ==========================
  tool run_validate
    label: "Run Dippin Check"
    command:
      #!/bin/sh
      set -eu
      if [ ! -f pipeline.dip ]; then
        printf 'no_dip_file'
        exit 0
      fi
      result=$(dippin check pipeline.dip 2>/dev/null)
      if echo "$result" | grep -q '"valid":true'; then
        printf 'valid'
      else
        printf 'invalid'
      fi

  # ==========================
  # FIX BUDGET CHECK
  # ==========================
  tool check_fix_budget
    label: "Check Fix Budget"
    command:
      #!/bin/sh
      set -eu
      mkdir -p .tracker
      COUNTER='.tracker/fix_count'
      count=0
      [ -f "$COUNTER" ] && count=$(cat "$COUNTER")
      count=$((count + 1))
      printf '%s' "$count" > "$COUNTER"
      if [ "$count" -gt 3 ]; then
        printf 'budget_exhausted'
      else
        printf 'budget_ok'
      fi

  # ==========================
  # FIX VALIDATION ERRORS
  # ==========================
  agent fix_validation
    label: "Fix Validation Errors"
    model: claude-opus-4-6
    goal_gate: true
    retry_target: fix_validation
    prompt:
      You are working in `run.working_dir`.

      ## Task
      The pipeline.dip file failed validation. Fix the errors.

      ## Process
      1. Run: dippin check pipeline.dip
      2. Read the FULL JSON output — look at diagnostics[].message and diagnostics[].line
      3. Common fixes:
         - Missing start: or exit: -> add them referencing declared node IDs
         - Edge references undeclared node -> declare the node or fix the name
         - parallel without matching fan_in -> add fan_in with same sources
         - Bare variable names in conditions -> use ctx.outcome, not outcome
         - Agent node with empty prompt -> add prompt content
         - Invented fields -> remove them
      4. Save fixed pipeline.dip
      5. Run: dippin check pipeline.dip — confirm it passes

      ## Success Criteria
      - dippin check pipeline.dip reports valid

  # ==========================
  # REGENERATE (escalation)
  # ==========================
  agent regenerate_dip
    label: "Regenerate Pipeline Dip"
    model: claude-opus-4-6
    goal_gate: true
    retry_target: regenerate_dip
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Previous attempts to fix pipeline.dip have failed repeatedly. Start fresh with deep understanding.

      ## Process — Think Deeper Before Acting
      This is NOT 'try the same thing again.' You must understand WHY previous attempts failed.

      1. Read docs/plans/spec_analysis.md — re-internalize the project structure
      2. Read the current pipeline.dip — identify the specific validation errors via dippin check
      3. Read docs/plans/generation_worklog.md if it exists — learn from previous attempts
      4. Ask yourself: What pattern keeps causing failures? Wrong topology? Invented fields? Missing edges?
      5. Delete pipeline.dip and regenerate from scratch with a SIMPLER approach
      6. Focus on correctness first:
         - workflow has goal:, start:, exit:
         - Every agent node has goal_gate: true + retry_target
         - All edge conditions use ctx. prefix
         - Every parallel has a matching fan_in
         - tool nodes use command: (not tool_command)
      7. Run: dippin check pipeline.dip — confirm it passes

      ## Worklog
      Append to docs/plans/generation_worklog.md:
      - What went wrong in previous attempts
      - What you changed in this regeneration
      - Validation result

      ## Success Criteria
      - pipeline.dip exists and passes dippin check

  # ==========================
  # SCORE QUALITY
  # ==========================
  tool score_quality
    label: "Score Pipeline Quality"
    command:
      #!/bin/sh
      set -eu
      score=0
      total=7
      # Pattern 1: Resume support
      grep -qi 'check_existing\|Check Existing' pipeline.dip && score=$((score + 1))
      # Pattern 2: Scope gating
      grep -qi 'scope_analysis\|scope' pipeline.dip && score=$((score + 1))
      # Pattern 3: Per-phase verification (verify nodes)
      verify_count=$(grep -c 'verify_' pipeline.dip 2>/dev/null || echo 0)
      [ "$verify_count" -gt 0 ] && score=$((score + 1))
      # Pattern 4: Graduated escalation
      grep -qi 'debug_investigate\|debug\|replan' pipeline.dip && score=$((score + 1))
      # Pattern 5: Budget tracking
      grep -qi 'check_budget\|budget' pipeline.dip && score=$((score + 1))
      # Pattern 6: Language-aware build validation
      grep -qi 'validate_build' pipeline.dip && score=$((score + 1))
      # Pattern 7: Review reads code (IRON LAW)
      grep -qi 'IRON LAW' pipeline.dip && score=$((score + 1))
      # Component coverage: count implement nodes vs spec components
      impl_count=$(grep -c 'implement_' pipeline.dip 2>/dev/null || echo 0)
      printf 'score=%s/%s impl=%s ' "$score" "$total" "$impl_count" >&2
      if [ "$score" -ge 6 ]; then
        printf 'quality_high'
      elif [ "$score" -ge 4 ]; then
        printf 'quality_medium'
      else
        printf 'quality_low'
      fi

  # ==========================
  # REFINE BUDGET CHECK
  # ==========================
  tool check_refine_budget
    label: "Check Refine Budget"
    command:
      #!/bin/sh
      set -eu
      mkdir -p .tracker
      COUNTER='.tracker/refine_count'
      count=0
      [ -f "$COUNTER" ] && count=$(cat "$COUNTER")
      count=$((count + 1))
      printf '%s' "$count" > "$COUNTER"
      if [ "$count" -gt 3 ]; then
        printf 'budget_exhausted'
      else
        printf 'budget_ok'
      fi

  # ==========================
  # REFINE PIPELINE
  # ==========================
  agent refine_pipeline
    label: "Refine Pipeline Quality"
    model: claude-opus-4-6
    reasoning_effort: high
    goal_gate: true
    retry_target: refine_pipeline
    prompt:
      You are working in `run.working_dir`.

      ## Task
      The generated pipeline.dip is valid but scored below quality_high. Improve it by adding missing patterns and fixing coverage gaps.

      ## Process — Measure, Improve, Verify
      This is an iterative refinement step inspired by autoresearch: identify what's missing, add it, verify the result.

      1. Read pipeline.dip and docs/plans/spec_analysis.md
      2. Check each quality dimension and fix what's missing:

      ### Proven Patterns Checklist
      For each missing pattern, add it to pipeline.dip:
      - [ ] Resume support — check_existing tool node as first node after start
      - [ ] Scope gating — scope_analysis agent node with reasoning_effort: high before planning
      - [ ] Per-phase verification — verify node after EVERY implement node with pass/fail edges
      - [ ] Graduated escalation — debug_investigate -> replan -> done chain at the end
      - [ ] Budget tracking — check_budget tool node before E2E retry loop
      - [ ] Language-aware build validation — validate_build tool node (MUST use set +e and printf, NOT exit 1)
      - [ ] Timeout budget — verify tool nodes have explicit timeout based on tech stack (120s+ for TS/Go, 180s for Rust/Java)
      - [ ] Infrastructure prerequisites — verify tool commands start emulators/services before running tests (self-contained, no assumptions)
      - [ ] Review reads code — IRON LAW section in final review prompt

      ### Component Coverage
      For every component in docs/plans/spec_analysis.md, confirm pipeline.dip has:
      - implement_X agent node (goal_gate: true, retry_target)
      - verify_X node with pass/fail conditional edges
      - commit_X agent node

      ### Prompt Quality (spot-check 3 implement nodes)
      - Starts with: You are working in `run.working_dir`.
      - Includes ## Tech Stack with correct language/framework/deps
      - Includes TDD instruction
      - Has goal_gate: true + retry_target

      ### Topology
      - Independent components use parallel / fan_in
      - Dependent components have correct edge ordering

      3. After all fixes, run: dippin check pipeline.dip — confirm still valid
      4. If any fix breaks validation, revert that specific fix

      ## Worklog
      Append to docs/plans/generation_worklog.md:
      - What patterns were missing (with previous score)
      - What was added/fixed
      - New validation result

      ## Success Criteria
      - All 7 proven patterns present in pipeline.dip
      - All spec components have implement + verify + commit nodes
      - pipeline.dip still validates after fixes

  # ==========================
  # EXIT
  # ==========================
  agent done
    label: "Exit"
    prompt:
      Pipeline generation complete.

  # ==========================
  # EDGES
  # ==========================
  edges
    # Find and analyze spec
    find_spec -> analyze_spec  when ctx.tool_stdout != no_spec_found  label: "spec found"  weight: 2
    find_spec -> done  when ctx.tool_stdout = no_spec_found  label: "no spec found"

    analyze_spec -> check_analysis
    check_analysis -> generate_dip  when ctx.tool_stdout = analysis_ready  label: "analysis ready"  weight: 2
    check_analysis -> analyze_spec  when ctx.tool_stdout != analysis_ready  label: "analysis missing — retry"  restart: true

    # Generate and validate
    generate_dip -> run_validate

    # Validation routing
    run_validate -> score_quality  when ctx.tool_stdout = valid  label: "valid"  weight: 2
    run_validate -> check_fix_budget  when ctx.tool_stdout != valid  label: "invalid"

    # Fix loop with budget
    check_fix_budget -> fix_validation  when ctx.tool_stdout = budget_ok  label: "budget ok"  weight: 2
    check_fix_budget -> regenerate_dip  when ctx.tool_stdout = budget_exhausted  label: "too many fixes — start fresh"
    fix_validation -> run_validate  restart: true
    regenerate_dip -> run_validate  restart: true

    # Quality scoring (the autoresearch measure step)
    score_quality -> done  when ctx.tool_stdout = quality_high  label: "quality high"  weight: 2
    score_quality -> check_refine_budget  when ctx.tool_stdout != quality_high  label: "needs refinement"

    # Refine loop with budget (the autoresearch improve-measure loop)
    check_refine_budget -> refine_pipeline  when ctx.tool_stdout = budget_ok  label: "budget ok"  weight: 2
    check_refine_budget -> done  when ctx.tool_stdout = budget_exhausted  label: "best effort — budget exhausted"
    refine_pipeline -> run_validate  restart: true
