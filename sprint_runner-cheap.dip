workflow SprintRunnerCheap
  goal: "Execute all sprints from .ai/ledger.tsv in sequence using cheap models (Haiku, GPT-5.4 Nano, Gemini Flash-Lite) with retry loops, review squads, and escalation to Sonnet on failure."
  start: Start
  exit: Exit

  defaults
    max_retries: 3
    max_restarts: 50
    fidelity: summary:low

  agent Start
    label: Start
    prompt:
      Begin cheap sprint runner pipeline. Will loop through all incomplete sprints in the ledger.

  agent Exit
    label: Exit
    prompt:
      Cheap sprint runner pipeline complete.

  # === LEDGER CHECK + LOOP CONTROL ===

  tool check_ledger
    label: "Check Ledger"
    timeout: 10s
    command:
      set -eu
      if [ ! -f .ai/ledger.tsv ]; then
        printf 'no_ledger'
        exit 0
      fi
      target=$(awk -F '\t' 'NR>1 && $3!~/^completed$/ && $3!~/^skipped$/{print $1; exit}' .ai/ledger.tsv)
      if [ -z "$target" ]; then
        printf 'all_done'
        exit 0
      fi
      printf '%s' "$target" > .ai/current_sprint_id.txt
      printf 'next-%s' "$target"

  agent no_ledger_exit
    label: "No Ledger Found"
    prompt:
      No .ai/ledger.tsv found. The sprint runner requires an existing ledger with planned sprints.

      To create one, run spec_to_sprints.dip with a spec file, or megaplan.dip to plan incrementally.

  agent read_sprint
    label: "Read Sprint"
    model: gemini-3.1-flash-lite-preview
    provider: gemini
    reasoning_effort: medium
    prompt:
      You are working in `run.working_dir`.

      Read .ai/current_sprint_id.txt to get the target sprint ID.
      Read the sprint document at .ai/sprints/SPRINT-<id>.md.

      Summarize:
      1. Sprint title and scope
      2. Requirements covered (FR IDs)
      3. Dependencies — confirm all dependency sprints are completed in .ai/ledger.tsv
      4. Expected artifacts
      5. DoD checklist items
      6. Validation commands

      If a dependency sprint is NOT completed, flag this as a blocker.

  tool mark_in_progress
    label: "Mark In Progress"
    timeout: 10s
    command:
      set -eu
      target=$(cat .ai/current_sprint_id.txt)
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      awk -F '\t' -v OFS='\t' -v target="$target" -v now="$now" '
      NR==1 {print; next}
      { if ($1==target) { $3="in_progress"; $5=now }; print }
      ' .ai/ledger.tsv > .ai/ledger.tsv.tmp
      mv .ai/ledger.tsv.tmp .ai/ledger.tsv
      printf 'in_progress-%s' "$target"

  # === CHEAP IMPLEMENTATION LANE ===

  agent implement_cheap
    label: "Implement Sprint (Cheap)"
    model: claude-haiku-4-5
    provider: anthropic
    reasoning_effort: high
    fidelity: summary:medium
    goal_gate: true
    retry_target: implement_cheap
    fallback_target: implement_rescue
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Read .ai/current_sprint_id.txt to get the sprint ID. Read the sprint doc at .ai/sprints/SPRINT-<id>.md. Implement all requirements end-to-end.

      ## Process
      1. Read the sprint doc thoroughly — understand scope, requirements, expected artifacts, DoD
      2. Read .ai/spec_analysis.md for broader context
      3. Review existing code to understand current state
      4. Write failing tests FIRST for each DoD item
      5. Implement minimum code to pass tests
      6. Run the project's test suite and linter — fix all issues
      7. Update the sprint doc checklist as work is completed

      ## If Prior Review Feedback Exists
      If you have context from a prior review/critique cycle, treat those findings as required fixes. Address every finding before declaring done.

      ## Success Criteria
      - All DoD items checked off in the sprint doc
      - All tests pass
      - Linter passes
      - Expected artifacts exist

  tool validate_build
    label: "Validate Build and Tests"
    timeout: 300s
    command:
      set +e
      fail=0
      if [ -f Package.swift ]; then
        swift build 2>&1 || fail=1
        swift test 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      if [ -f pyproject.toml ]; then
        uv run pytest -v 2>&1 || fail=1
        uv run ruff check . 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      if [ -f package.json ]; then
        npm test 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      if [ -f Cargo.toml ]; then
        cargo build 2>&1 || fail=1
        cargo test 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      if [ -f go.mod ]; then
        go build ./... 2>&1 || fail=1
        go test ./... 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      printf 'validation-pass-no-known-build-system'

  agent commit_cheap
    label: "Commit Sprint Work (Cheap)"
    model: gpt-5.4-nano
    provider: openai
    reasoning_effort: medium
    goal_gate: true
    retry_target: commit_cheap
    fallback_target: failure_summary
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Read .ai/current_sprint_id.txt to get the sprint ID.
      Review all changes with git diff and git status.
      Stage all relevant files and commit.

      ## Rules
      - Use conventional commit format: feat(sprint-NNN): <description>
      - Do NOT commit generated files, __pycache__, node_modules, .env, or build artifacts
      - If no changes exist, report that no commit was needed
      - Verify the commit succeeded with git log --oneline -1
      - Include the commit hash in your summary

  # === REVIEW SQUADS ===

  parallel squad_parallel -> practical_dev, nitpicker, fresh_eyes

  agent practical_dev
    label: "Squad: Practical Dev"
    model: claude-haiku-4-5
    provider: anthropic
    reasoning_effort: medium
    fidelity: summary:medium
    prompt:
      You are working in `run.working_dir`.

      You are a pragmatic mid-level developer picking up this sprint's work for the first time.

      ## Context (MANDATORY)
      1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md
      2. Get the full diff: git log --oneline -3 and git diff HEAD~1
      3. Read every changed file

      ## Review Focus
      - Does it actually work as specified?
      - Are there obvious bugs or missing pieces?
      - Does the code flow make sense?
      - Check the sprint doc checklist against what was actually delivered

      Be concrete — cite files and line numbers.

  agent nitpicker
    label: "Squad: Nitpicker"
    model: gpt-5.4-nano
    provider: openai
    reasoning_effort: medium
    fidelity: summary:medium
    prompt:
      You are working in `run.working_dir`.

      You are an obsessively detail-oriented code reviewer.

      ## Context (MANDATORY)
      1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md
      2. Get the full diff: git log --oneline -3 and git diff HEAD~1
      3. Read every changed file

      ## Review Focus
      Find every edge case that isn't handled, every naming inconsistency, every missing validation, every code smell. You care about error paths, boundary conditions, and things that will break at 2am. Rank findings by severity.

  agent fresh_eyes
    label: "Squad: Fresh Eyes"
    model: gemini-3.1-flash-lite-preview
    provider: gemini
    reasoning_effort: medium
    fidelity: summary:medium
    prompt:
      You are working in `run.working_dir`.

      You have never seen this codebase before. Read the sprint output cold.

      ## Context (MANDATORY)
      1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md
      2. Get the full diff: git log --oneline -3 and git diff HEAD~1
      3. Read every changed file

      ## Review Focus
      - What's confusing?
      - What assumptions does the code make that aren't documented?
      - What would trip up a new contributor?
      - Focus on readability, structure, and whether the code is self-explanatory

  fan_in squad_join <- practical_dev, nitpicker, fresh_eyes

  # === REVIEWS + CROSS-CRITIQUE ===

  parallel review_parallel -> review_haiku, review_nano

  agent review_haiku
    label: "Haiku Review"
    model: claude-haiku-4-5
    provider: anthropic
    reasoning_effort: medium
    fidelity: summary:medium
    prompt:
      You are working in `run.working_dir`.

      ## IRON LAW: NO COMPLETION CLAIMS WITHOUT FRESH VERIFICATION
      Run commands. Read output. Check exit codes. THEN make claims.

      ## Context (MANDATORY)
      1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md
      2. Get the full diff: git log --oneline -3 and git diff HEAD~1
      3. Read every changed file
      4. Run the test suite yourself

      DO NOT trust the implementer's claims. Verify independently.
      Use squad findings as additional context for your review.

      ## Review Focus
      - Sprint doc checklist: is every DoD item genuinely satisfied?
      - Implementation correctness: does the code match the requirements?
      - Test quality: do tests cover the DoD items meaningfully?

      ## Verdict
      Return clear PASS or FAIL with specific reasoning. If FAIL, list required fixes.

  agent review_nano
    label: "Nano Review"
    model: gpt-5.4-nano
    provider: openai
    reasoning_effort: medium
    fidelity: summary:medium
    prompt:
      You are working in `run.working_dir`.

      ## IRON LAW: NO COMPLETION CLAIMS WITHOUT FRESH VERIFICATION
      Run commands. Read output. Check exit codes. THEN make claims.

      ## Context (MANDATORY)
      1. Read .ai/current_sprint_id.txt and .ai/sprints/SPRINT-<id>.md
      2. Get the full diff: git log --oneline -3 and git diff HEAD~1
      3. Read every changed file
      4. Run the test suite yourself

      DO NOT trust the implementer's claims. Verify independently.
      Use squad findings as additional context for your review.

      ## Review Focus
      - Implementation quality: is the code clean, readable, well-structured?
      - Regression risk: could these changes break other sprints?
      - Edge cases: are error paths and boundary conditions handled?

      ## Verdict
      Return clear PASS or FAIL with specific reasoning. If FAIL, list required fixes.

  fan_in reviews_join <- review_haiku, review_nano

  parallel cross_critique_parallel -> haiku_critique_nano, nano_critique_haiku

  agent haiku_critique_nano
    label: "Haiku Critique of Nano Review"
    model: claude-haiku-4-5
    provider: anthropic
    reasoning_effort: medium
    fidelity: summary:low
    prompt:
      Critique the Nano review for: missing checks, weak evidence, overly lenient verdicts, or mistaken conclusions. Be specific — cite what was missed and why it matters.

  agent nano_critique_haiku
    label: "Nano Critique of Haiku Review"
    model: gpt-5.4-nano
    provider: openai
    reasoning_effort: medium
    fidelity: summary:low
    prompt:
      Critique the Haiku review for: missing checks, weak evidence, overly lenient verdicts, or mistaken conclusions. Be specific — cite what was missed and why it matters.

  fan_in critiques_join <- haiku_critique_nano, nano_critique_haiku

  # === CHEAP GATE ===

  agent gate_cheap
    label: "Gate (Cheap)"
    model: claude-haiku-4-5
    provider: anthropic
    reasoning_effort: high
    goal_gate: true
    max_retries: 3
    retry_target: implement_cheap
    fallback_target: implement_rescue
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Synthesize all squad findings, reviews, and cross-critiques into a single verdict for this sprint.

      ## Process
      1. Weight each review by the critiques it received — heavily critiqued reviews get less weight
      2. Identify consensus findings (multiple reviewers agree)
      3. Identify disputed findings (reviewers disagree) — resolve by examining the code yourself

      ## Verdicts
      - **success**: Sprint is genuinely complete. All DoD items satisfied, tests pass, no regressions.
      - **retry**: Sprint needs rework. List specific findings that must be addressed.
      - **fail**: Sprint is blocked by something outside the implementation agent's control.

  # === RESCUE LANE ===

  agent implement_rescue
    label: "Implement Sprint (Rescue)"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: high
    fidelity: summary:high
    goal_gate: true
    retry_target: implement_rescue
    max_retries: 1
    fallback_target: failure_summary
    prompt:
      You are working in `run.working_dir`.

      ## ESCALATION
      Cheap implementation failed after multiple attempts. You have all prior context — squad findings, review critiques, gate verdicts, and implementation history.

      ## Task
      Read .ai/current_sprint_id.txt to get the sprint ID. Read the sprint doc at .ai/sprints/SPRINT-<id>.md. Fix the remaining issues definitively.

      This is the last attempt before failure. Review all prior feedback carefully and address every outstanding finding.

      ## Success Criteria
      - All DoD items checked off in the sprint doc
      - All tests pass
      - Linter passes
      - Expected artifacts exist

  tool validate_rescue
    label: "Validate Rescue Build"
    timeout: 300s
    command:
      set +e
      fail=0
      if [ -f Package.swift ]; then
        swift build 2>&1 || fail=1
        swift test 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      if [ -f pyproject.toml ]; then
        uv run pytest -v 2>&1 || fail=1
        uv run ruff check . 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      if [ -f package.json ]; then
        npm test 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      if [ -f Cargo.toml ]; then
        cargo build 2>&1 || fail=1
        cargo test 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      if [ -f go.mod ]; then
        go build ./... 2>&1 || fail=1
        go test ./... 2>&1 || fail=1
        if [ "$fail" -eq 0 ]; then printf 'validation-pass'; else printf 'validation-fail'; fi
        exit 0
      fi
      printf 'validation-pass-no-known-build-system'

  agent commit_rescue
    label: "Commit Rescue Work"
    model: gpt-5.4-nano
    provider: openai
    reasoning_effort: medium
    goal_gate: true
    retry_target: commit_rescue
    fallback_target: failure_summary
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Read .ai/current_sprint_id.txt to get the sprint ID.
      Review all changes with git diff and git status.
      Stage all relevant files and commit.

      ## Rules
      - Use conventional commit format: feat(sprint-NNN): <description> [rescue]
      - Do NOT commit generated files, __pycache__, node_modules, .env, or build artifacts
      - If no changes exist, report that no commit was needed
      - Verify the commit succeeded with git log --oneline -1
      - Include the commit hash in your summary

  agent rescue_review
    label: "Rescue Sanity Check"
    model: claude-haiku-4-5
    provider: anthropic
    reasoning_effort: medium
    fidelity: summary:medium
    prompt:
      You are working in `run.working_dir`.

      Quick sanity check on the rescue implementation. Read the sprint doc, check the diff, and verify the Sonnet rescue addressed the issues that caused cheap implementation to fail.

      Return PASS if the sprint checklist is satisfied, FAIL if critical issues remain.

  # === COMPLETION + LOOP ===

  tool mark_complete
    label: "Complete Sprint"
    timeout: 10s
    command:
      set -eu
      target=$(cat .ai/current_sprint_id.txt)
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      awk -F '\t' -v OFS='\t' -v target="$target" -v now="$now" '
      NR==1 {print; next}
      { if ($1==target) { $3="completed"; $5=now }; print }
      ' .ai/ledger.tsv > .ai/ledger.tsv.tmp
      mv .ai/ledger.tsv.tmp .ai/ledger.tsv
      printf 'completed-%s' "$target"

  tool report_progress
    label: "Report Progress"
    timeout: 10s
    command:
      set -eu
      total=$(awk -F '\t' 'NR>1' .ai/ledger.tsv | wc -l | tr -d ' ')
      done=$(awk -F '\t' 'NR>1 && ($3=="completed" || $3=="skipped")' .ai/ledger.tsv | wc -l | tr -d ' ')
      if [ "$total" -gt 0 ]; then
        pct=$((done * 100 / total))
      else
        pct=0
      fi
      printf 'progress-%s-of-%s-%spct' "$done" "$total" "$pct"

  human sprint_gate
    label: "Continue to Next Sprint?"

  tool skip_gate
    label: "Skip Gate"
    timeout: 5s
    command:
      set -eu
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      target=$(cat .ai/current_sprint_id.txt 2>/dev/null || echo "unknown")
      printf 'continue\t%s\t%s\n' "$target" "$now"

  # === FAILURE ===

  agent failure_summary
    label: "Failure Summary"
    model: gpt-5.4-nano
    provider: openai
    reasoning_effort: medium
    prompt:
      You are working in `run.working_dir`.

      Sprint execution failed. Diagnose what went wrong:

      1. Read .ai/current_sprint_id.txt to identify which sprint failed
      2. Read the sprint doc and the ledger
      3. Check git log for recent commits
      4. Examine build/test output if available

      Report:
      - Which sprint failed and why
      - What was completed before the failure
      - Concrete next steps for recovery
      - Whether downstream sprints are likely affected

  # === EDGES ===

  edges
    # Ledger check + routing
    Start -> check_ledger
    check_ledger -> Exit  when ctx.tool_stdout = all_done  label: all_done
    check_ledger -> no_ledger_exit  when ctx.tool_stdout = no_ledger  label: no_ledger
    check_ledger -> read_sprint  when ctx.tool_stdout != all_done  label: next_sprint
    no_ledger_exit -> Exit

    # Discovery
    read_sprint -> mark_in_progress
    read_sprint -> failure_summary

    # Cheap implementation lane
    mark_in_progress -> implement_cheap
    implement_cheap -> validate_build
    validate_build -> commit_cheap  when ctx.tool_stdout startswith "validation-pass"  label: validated
    validate_build -> implement_cheap  when ctx.tool_stdout = validation-fail  label: fix_validation  restart: true
    validate_build -> failure_summary

    # Commit fail-safe
    commit_cheap -> failure_summary

    # Review squads
    commit_cheap -> squad_parallel
    squad_parallel -> practical_dev
    squad_parallel -> nitpicker
    squad_parallel -> fresh_eyes
    practical_dev -> squad_join
    nitpicker -> squad_join
    fresh_eyes -> squad_join

    # Reviews + cross-critique
    squad_join -> review_parallel
    review_parallel -> review_haiku
    review_parallel -> review_nano
    review_haiku -> reviews_join
    review_nano -> reviews_join
    reviews_join -> cross_critique_parallel
    cross_critique_parallel -> haiku_critique_nano
    cross_critique_parallel -> nano_critique_haiku
    haiku_critique_nano -> critiques_join
    nano_critique_haiku -> critiques_join

    # Cheap gate
    critiques_join -> gate_cheap
    gate_cheap -> mark_complete  when ctx.outcome = success  label: pass
    gate_cheap -> implement_cheap  when ctx.outcome = retry  label: rework  restart: true
    gate_cheap -> implement_rescue  when ctx.outcome = fail  label: escalate
    gate_cheap -> implement_rescue

    # Rescue lane
    implement_rescue -> validate_rescue
    implement_rescue -> failure_summary
    validate_rescue -> commit_rescue  when ctx.tool_stdout startswith "validation-pass"  label: rescue_validated
    validate_rescue -> failure_summary  when ctx.tool_stdout = validation-fail  label: rescue_failed
    validate_rescue -> failure_summary
    commit_rescue -> failure_summary
    commit_rescue -> rescue_review
    rescue_review -> mark_complete  when ctx.outcome = success  label: rescue_pass
    rescue_review -> failure_summary  when ctx.outcome = fail  label: rescue_fail
    rescue_review -> failure_summary

    # Completion loop
    mark_complete -> report_progress
    report_progress -> sprint_gate
    sprint_gate -> skip_gate  label: "[S] Continue"
    sprint_gate -> Exit  label: "[A] Pause"
    skip_gate -> check_ledger  restart: true

    # Terminal
    failure_summary -> Exit
