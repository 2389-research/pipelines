# ABOUTME: Autonomous sprint runner loop using YAML ledger for sprint tracking.
# ABOUTME: Fork of sprint_runner.dip — fully autonomous with failure budget, auto-retry, and skip-on-repeated-failure.
workflow SprintRunnerYaml
  goal: "Execute all sprints from .ai/ledger.yaml autonomously in sequence, retrying failed sprints once and skipping on repeated failure, until every sprint is completed/skipped or the failure budget is exhausted."
  start: Start
  exit: Exit

  defaults
    max_retries: 3
    max_restarts: 50
    fidelity: summary:medium

  agent Start
    label: Start
    prompt:
      Begin autonomous sprint runner. Will loop through all incomplete sprints, retrying failures once, skipping on repeated failure, and stopping if the failure budget (3 total failures) is exhausted.

  agent Exit
    label: Exit
    prompt:
      Sprint runner pipeline complete.

  tool check_yq
    label: "Check yq"
    timeout: 5s
    command:
      set -eu
      if ! command -v yq >/dev/null 2>&1; then
        printf 'yq-not-found'
        exit 0
      fi
      printf 'yq-ok'

  agent yq_missing
    label: "yq Not Found"
    prompt:
      The yq YAML processor is required but not installed.

      Install it:
        macOS:  brew install yq
        Linux:  snap install yq  OR  wget https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 -O /usr/local/bin/yq && chmod +x /usr/local/bin/yq

      After installing, re-run the pipeline.

  tool check_ledger
    label: "Check Ledger"
    timeout: 10s
    command:
      set -eu
      if [ ! -f .ai/ledger.yaml ]; then
        printf 'no_ledger'
        exit 0
      fi
      target=$(yq '.sprints[] | select(.status != "completed" and .status != "skipped" and .status != "failed") | .id' .ai/ledger.yaml | head -1)
      if [ -z "$target" ]; then
        rm -f .ai/runner-last-failed-sprint.txt .ai/runner-total-failures.txt
        printf 'all_done'
        exit 0
      fi
      printf '%s' "$target" > .ai/current_sprint_id.txt
      printf 'next-%s' "$target"

  agent no_ledger_exit
    label: "No Ledger Found"
    prompt:
      No .ai/ledger.yaml found. The sprint runner requires an existing ledger with planned sprints.

      To create one, run spec_to_sprints_yaml.dip with a spec file.

  subgraph execute_sprint
    ref: sprint_exec_yaml.dip

  tool report_progress
    label: "Report Progress"
    timeout: 10s
    command:
      set -eu
      total=$(yq '.sprints | length' .ai/ledger.yaml)
      done=$(yq '[.sprints[] | select(.status == "completed")] | length' .ai/ledger.yaml)
      skipped=$(yq '[.sprints[] | select(.status == "skipped")] | length' .ai/ledger.yaml)
      failed=$(yq '[.sprints[] | select(.status == "failed")] | length' .ai/ledger.yaml)
      remaining=$((total - done - skipped - failed))
      if [ "$total" -gt 0 ]; then
        pct=$(( (done + skipped) * 100 / total))
      else
        pct=0
      fi
      printf 'progress-%s-of-%s-%spct-failed-%s-remaining-%s' "$done" "$total" "$pct" "$failed" "$remaining"

  tool handle_failure
    label: "Handle Sprint Failure"
    timeout: 10s
    command:
      set -eu
      target=$(cat .ai/current_sprint_id.txt 2>/dev/null || echo "unknown")
      last_failed=$(cat .ai/runner-last-failed-sprint.txt 2>/dev/null || echo "none")
      total_failures=$(cat .ai/runner-total-failures.txt 2>/dev/null || echo "0")
      total_failures=$((total_failures + 1))
      printf '%s' "$total_failures" > .ai/runner-total-failures.txt
      if [ "$target" = "$last_failed" ]; then
        now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
        yq -i "(.sprints[] | select(.id == \"$target\")).status = \"failed\" | (.sprints[] | select(.id == \"$target\")).updated_at = \"$now\"" .ai/ledger.yaml
        rm -f .ai/runner-last-failed-sprint.txt
        if [ "$total_failures" -ge 3 ]; then
          printf 'budget-exhausted-%s-total-failures' "$total_failures"
        else
          printf 'skipped-%s-moving-on' "$target"
        fi
      else
        printf '%s' "$target" > .ai/runner-last-failed-sprint.txt
        if [ "$total_failures" -ge 3 ]; then
          printf 'budget-exhausted-%s-total-failures' "$total_failures"
        else
          printf 'retry-%s-attempt-2' "$target"
        fi
      fi

  agent failure_summary
    label: "Failure Summary"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: high
    prompt:
      The sprint runner has exhausted its failure budget (3 total failures across all sprints).

      Read .ai/ledger.yaml. Report:
      1. Which sprints completed successfully
      2. Which sprints failed and were skipped
      3. Which sprints remain planned
      4. Whether the project is in a usable partial state
      5. Concrete next steps for recovery

  edges
    Start -> check_yq
    check_yq -> check_ledger           when ctx.tool_stdout = yq-ok         label: yq_ok
    check_yq -> yq_missing             when ctx.tool_stdout = yq-not-found  label: yq_missing
    check_yq -> Exit
    yq_missing -> Exit
    check_ledger -> Exit               when ctx.tool_stdout = all_done       label: all_done
    check_ledger -> no_ledger_exit     when ctx.tool_stdout = no_ledger     label: no_ledger
    check_ledger -> execute_sprint     when ctx.tool_stdout startswith next- label: next_sprint
    check_ledger -> Exit
    no_ledger_exit -> Exit
    execute_sprint -> report_progress  when ctx.outcome = success           label: sprint_done
    execute_sprint -> handle_failure   when ctx.outcome = fail              label: sprint_failed
    execute_sprint -> handle_failure
    report_progress -> check_ledger    restart: true
    handle_failure -> check_ledger          when ctx.tool_stdout startswith retry-    label: retry_sprint    restart: true
    handle_failure -> check_ledger          when ctx.tool_stdout startswith skipped-  label: skip_continue   restart: true
    handle_failure -> failure_summary       when ctx.tool_stdout startswith budget-   label: budget_blown
    handle_failure -> failure_summary
    failure_summary -> Exit
