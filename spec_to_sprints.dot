digraph SpecToSprints {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];
  Start [label="Start", shape="Mdiamond"];
  Exit [label="Exit", shape="Msquare"];
  find_spec [label="Find Spec File", shape="parallelogram"];
  no_spec_exit [label="No Spec Found", shape="box"];
  analyze_spec [label="Analyze Spec", shape="box"];
  decompose_parallel [label="decompose_parallel", shape="component"];
  decompose_claude [label="Claude Decomposition", shape="box"];
  decompose_gpt [label="GPT Decomposition", shape="box"];
  decompose_gemini [label="Gemini Decomposition", shape="box"];
  decompose_join [label="decompose_join", shape="tripleoctagon"];
  critique_parallel [label="critique_parallel", shape="component"];
  critique_claude_on_gpt [label="Claude Critique of GPT", shape="box"];
  critique_claude_on_gemini [label="Claude Critique of Gemini", shape="box"];
  critique_gpt_on_claude [label="GPT Critique of Claude", shape="box"];
  critique_gpt_on_gemini [label="GPT Critique of Gemini", shape="box"];
  critique_gemini_on_claude [label="Gemini Critique of Claude", shape="box"];
  critique_gemini_on_gpt [label="Gemini Critique of GPT", shape="box"];
  critique_join [label="critique_join", shape="tripleoctagon"];
  merge_decomposition [label="Merge Decomposition", shape="box"];
  present_plan [label="Present Sprint Plan", shape="box"];
  approval_gate [label="Approve Sprint Plan", shape="hexagon"];
  apply_feedback [label="Apply Feedback", shape="box"];
  skip_approval [label="Skip Approval", shape="parallelogram"];
  setup_workspace [label="Setup .ai Workspace", shape="parallelogram"];
  write_sprint_docs [label="Write Sprint Docs", shape="box"];
  write_ledger [label="Write Ledger", shape="parallelogram"];
  validate_output [label="Validate Output", shape="parallelogram"];
  commit_output [label="Commit Output", shape="parallelogram"];

  Start -> find_spec;
  find_spec -> analyze_spec [condition="tool_stdout != no_spec_found", label="spec_found"];
  find_spec -> no_spec_exit [condition="tool_stdout = no_spec_found", label="no_spec"];
  no_spec_exit -> Exit;
  analyze_spec -> decompose_parallel;
  decompose_parallel -> decompose_claude;
  decompose_parallel -> decompose_gpt;
  decompose_parallel -> decompose_gemini;
  decompose_claude -> decompose_join;
  decompose_gpt -> decompose_join;
  decompose_gemini -> decompose_join;
  decompose_join -> critique_parallel;
  critique_parallel -> critique_claude_on_gpt;
  critique_parallel -> critique_claude_on_gemini;
  critique_parallel -> critique_gpt_on_claude;
  critique_parallel -> critique_gpt_on_gemini;
  critique_parallel -> critique_gemini_on_claude;
  critique_parallel -> critique_gemini_on_gpt;
  critique_claude_on_gpt -> critique_join;
  critique_claude_on_gemini -> critique_join;
  critique_gpt_on_claude -> critique_join;
  critique_gpt_on_gemini -> critique_join;
  critique_gemini_on_claude -> critique_join;
  critique_gemini_on_gpt -> critique_join;
  critique_join -> merge_decomposition;
  merge_decomposition -> present_plan;
  present_plan -> approval_gate;
  approval_gate -> apply_feedback [label="[A] Revise plan"];
  approval_gate -> skip_approval [label="[S] Approve / Skip"];
  apply_feedback -> approval_gate [restart="true", style="dashed"];
  skip_approval -> setup_workspace;
  setup_workspace -> write_sprint_docs;
  write_sprint_docs -> write_ledger;
  write_ledger -> validate_output;
  validate_output -> commit_output [condition="tool_stdout = valid", label="valid"];
  validate_output -> write_sprint_docs [condition="tool_stdout != valid", label="fix_validation", restart="true", style="dashed"];
  commit_output -> Exit;
}
