workflow SprintExecTier2Transcribe
  goal: "Execute one sprint — architect is a thin transcriber (for rich sprints that already contain the design). Nano executes, Fix handles mechanical errors."
  start: Setup
  exit: Done

  defaults
    provider: openai
    fidelity: summary:low

  tool Setup
    label: "Setup Environment"
    timeout: 120s
    command:
      set -eu
      sprint=$(ls .ai/sprints/SPRINT-*.md 2>/dev/null | head -1)
      if [ -z "$sprint" ]; then echo "no sprint doc found"; exit 1; fi
      if grep -qi "typescript\|tsx\|npm\|node" "$sprint" 2>/dev/null; then
        npm install 2>/dev/null || true
      fi
      if grep -qi "python\|fastapi\|pytest\|pip" "$sprint" 2>/dev/null; then
        python3 -m venv .venv && .venv/bin/pip install -q fastapi httpx pytest pytest-asyncio pydantic uvicorn 2>/dev/null || true
      fi
      printf 'setup-done'

  agent Generate
    label: "Transcribe sprint to contract + Generate"
    model: gpt-5.4
    provider: openai
    max_turns: 3
    prompt:
      You are working in `run.working_dir`.

      The sprint doc already contains a complete design — types, SQL schema, interface
      signatures, test plan, rules. Your job is NOT to design. Your job is to pass the
      sprint content to generate_code as the contract, with the files array matching
      the sprint's Expected Artifacts.

      Steps:
      1. bash: cat .ai/sprints/SPRINT-*.md
      2. Call generate_code ONCE with:
         - contract: the full sprint content verbatim
         - output_dir: a single dot (the working directory root)
         - files: array with one entry per path in Expected Artifacts, each entry
           {"path": "<path>", "description": "per the sprint contract"}

      Do not summarize, reword, or re-design. The sprint is the contract.

      You have ONLY these tools: bash, generate_code.
      Do NOT use: read, glob, grep_search, write, apply_patch, edit.

  tool RunTests
    label: "Run Tests"
    timeout: 120s
    command:
      set +e
      if [ -f package.json ]; then
        npm test 2>&1
        if [ $? -eq 0 ]; then printf 'tests-pass'; else printf 'tests-fail'; fi
      elif [ -d .venv ]; then
        .venv/bin/python -m pytest tests/ -v 2>&1
        if [ $? -eq 0 ]; then printf 'tests-pass'; else printf 'tests-fail'; fi
      else
        printf 'no-test-runner'
      fi

  agent Fix
    label: "Fix Failures"
    model: gpt-5.4
    provider: openai
    max_turns: 12
    prompt:
      You are working in `run.working_dir`.

      Code was generated by a nano model from the sprint doc. Your only job: run tests
      and fix failures with surgical edits.

      bash: run the test suite (npm test or .venv/bin/python -m pytest tests/ -v).
      Read each failure. Use edit for surgical fixes — change only the specific lines
      the traceback identifies. Re-run tests. Repeat until green.

      You have ONLY these tools: bash, edit.
      Do NOT use: read, glob, grep_search, write, apply_patch, generate_code.
      Never rewrite entire files. One targeted fix per failure.

  agent Done
    label: "Done"
    model: gpt-5.4
    provider: openai
    prompt:
      Sprint execution complete (tier2 transcribe).

  edges
    Setup -> Generate
    Generate -> RunTests
    Generate -> Done    when ctx.outcome = fail
    RunTests -> Fix     when ctx.tool_stdout contains tests-fail
    RunTests -> Done    when ctx.tool_stdout contains tests-pass
    RunTests -> Done
    Fix -> Done    when ctx.outcome = fail
    Fix -> Done
