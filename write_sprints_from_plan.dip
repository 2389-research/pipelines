workflow WriteSprintsFromPlan
  goal: "Write SPRINT-*.md files and ledger from an existing .ai/sprint_plan.md — use when sprint_plan is already written."
  start: Start
  exit: Exit

  defaults
    model: gpt-5.4
    provider: openai
    max_retries: 3
    max_restarts: 5
    fidelity: summary:medium

  agent Start
    label: Start
    prompt:
      Begin sprint doc writing from existing sprint_plan.md.

  agent Exit
    label: Exit
    prompt:
      Sprint docs written successfully.

  tool setup_workspace
    label: "Setup .ai Workspace"
    timeout: 10s
    command:
      set -eu
      mkdir -p .ai/sprints .ai/drafts
      if [ ! -f .ai/ledger.tsv ]; then
        printf 'sprint_id\ttitle\tstatus\tcreated_at\tupdated_at\n' > .ai/ledger.tsv
      fi
      if [ ! -f .ai/sprint_plan.md ]; then
        printf 'no_sprint_plan'
        exit 0
      fi
      printf 'ready'

  agent no_plan_exit
    label: "No Sprint Plan"
    prompt:
      No .ai/sprint_plan.md found. Run spec_to_sprints first.

  agent write_sprint_docs
    label: "Write Sprint Docs"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    reads: sprint_plan, spec_analysis
    fallback_target: Exit
    prompt:
      You are working in `run.working_dir`.

      Read .ai/sprint_plan.md in full.

      Your job: delegate all file writing to nano via generate_code (single-call mode).

      ## Step 1: Build the contract
      Write a contract string that contains:
      1. The full content of sprint_plan.md
      2. This exact output instruction appended at the end:

      OUTPUT INSTRUCTIONS:
      Write every sprint as a separate file using this separator format:
      # === FILE: .ai/sprints/SPRINT-NNN.md ===
      (raw markdown content — NOT Python, NOT code, NOT string assignments)

      Each file must be raw markdown with exactly these sections:
      # Sprint NNN — Title
      ## Scope
      ## Non-goals
      ## Requirements
      ## Dependencies
      ## Expected Artifacts
      ## DoD
      - [ ] item
      ## Validation

      IDs zero-padded 3-digit. Output ALL sprint files. No Python wrappers.

      ## Step 2: Call generate_code
      Pass:
      - contract: your contract from Step 1
      - output_dir: "."
      Do NOT pass a files array. Use single-call mode only.

      Do not write any files yourself. Only call generate_code.

  tool write_ledger
    label: "Write Ledger"
    timeout: 10s
    command:
      set -eu
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      printf 'sprint_id\ttitle\tstatus\tcreated_at\tupdated_at\n' > .ai/ledger.tsv
      for f in .ai/sprints/SPRINT-*.md; do
        [ -f "$f" ] || continue
        id=$(basename "$f" .md | sed 's/SPRINT-//')
        title=$(head -1 "$f" | sed 's/^# Sprint [0-9]* *[-—–]* *//' | sed 's/^# //' | tr -d '\t')
        printf '%s\t%s\t%s\t%s\t%s\n' "$id" "$title" "planned" "$now" "$now" >> .ai/ledger.tsv
      done
      count=$(awk 'NR>1' .ai/ledger.tsv | wc -l | tr -d ' ')
      printf 'wrote-%s-sprints' "$count"

  tool validate_output
    label: "Validate Output"
    timeout: 15s
    command:
      set -eu
      errors=""
      stray=$(ls SPRINT-*.md 2>/dev/null | wc -l | tr -d ' ')
      if [ "$stray" -gt 0 ]; then errors="${errors}sprint-files-in-root "; fi
      ledger_ids=$(awk -F '\t' 'NR>1{print $1}' .ai/ledger.tsv | sort)
      file_ids=$(ls .ai/sprints/SPRINT-*.md 2>/dev/null | sed 's|.*/SPRINT-||;s|\.md||' | sort)
      if [ "$ledger_ids" != "$file_ids" ]; then errors="${errors}ledger-file-mismatch "; fi
      if [ -z "$(awk 'NR>1' .ai/ledger.tsv)" ]; then errors="${errors}empty-ledger "; fi
      if [ -n "$errors" ]; then
        printf 'invalid-%s' "$errors"
        exit 0
      fi
      printf 'valid'

  tool commit_output
    label: "Commit Output"
    timeout: 30s
    command:
      set -eu
      if [ ! -d .git ]; then printf 'no-git-skipped'; exit 0; fi
      for f in .ai/ledger.tsv .ai/sprints .ai/spec_analysis.md .ai/sprint_plan.md; do
        [ -e "$f" ] && git add "$f"
      done
      if git diff --cached --quiet; then printf 'no-changes-skipped'; exit 0; fi
      count=$(awk 'NR>1' .ai/ledger.tsv | wc -l | tr -d ' ')
      git commit -m "feat(sprints): decompose spec into ${count} sprints [hybrid]"
      printf 'committed-%s-sprints' "$count"

  edges
    Start -> setup_workspace
    setup_workspace -> write_sprint_docs  when ctx.tool_stdout = ready
    setup_workspace -> no_plan_exit  when ctx.tool_stdout = no_sprint_plan
    no_plan_exit -> Exit
    write_sprint_docs -> write_ledger
    write_ledger -> validate_output
    validate_output -> commit_output  when ctx.tool_stdout = valid
    validate_output -> write_sprint_docs  when ctx.tool_stdout != valid  restart: true
    commit_output -> Exit
