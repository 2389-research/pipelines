# ABOUTME: Autonomous sprint runner v2 with re-decomposition sidecar for mis-scoped sprint recovery.
# ABOUTME: Fork of sprint_runner_yaml.dip — adds redecompose flow when RecoveryManager signals scope failure.
workflow SprintRunnerYamlV2
  goal: "Execute all sprints from .ai/ledger.yaml autonomously in sequence, retrying failed sprints once, re-decomposing mis-scoped sprints via sidecar, and skipping on repeated failure, until every sprint is completed/skipped/redecomposed or the failure budget is exhausted."
  start: Start
  exit: Exit

  defaults
    max_retries: 3
    max_restarts: 50
    fidelity: summary:medium

  agent Start
    label: Start
    max_turns: 1
    prompt:
      Acknowledge that the sprint runner is starting. Report ready status.

      HARD CONSTRAINT: Do NOT read project files. Do NOT write code. Do NOT create, modify, or delete any files. Do NOT install dependencies. Your ONLY job is to acknowledge the pipeline start.

  agent Exit
    label: Exit
    max_turns: 1
    prompt:
      Sprint runner pipeline complete. Report final status.

      HARD CONSTRAINT: Do NOT write code. Do NOT create, modify, or delete any files. Your ONLY job is to acknowledge completion.

  tool check_yq
    label: "Check yq"
    timeout: 5s
    command:
      set -eu
      if ! command -v yq >/dev/null 2>&1; then
        printf 'yq-not-found'
        exit 0
      fi
      printf 'yq-ok'

  agent yq_missing
    label: "yq Not Found"
    prompt:
      The yq YAML processor is required but not installed.

      Install it:
        macOS:  brew install yq
        Linux:  snap install yq  OR  wget https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 -O /usr/local/bin/yq && chmod +x /usr/local/bin/yq

      After installing, re-run the pipeline.

  tool check_ledger
    label: "Check Ledger"
    timeout: 15s
    command:
      set -eu
      if [ ! -f .ai/ledger.yaml ]; then
        printf 'no_ledger'
        exit 0
      fi
      candidates=$(yq '.sprints[] | select(.status != "completed" and .status != "skipped" and .status != "failed" and .status != "redecomposed") | .id' .ai/ledger.yaml)
      if [ -z "$candidates" ]; then
        rm -f .ai/runner-last-failed-sprint.txt .ai/runner-total-failures.txt
        printf 'all_done'
        exit 0
      fi
      target=""
      for cid in $candidates; do
        deps=$(yq ".sprints[] | select(.id == \"$cid\") | .depends_on[]?" .ai/ledger.yaml 2>/dev/null)
        if [ -z "$deps" ]; then
          target="$cid"
          break
        fi
        all_met=true
        for dep in $deps; do
          dep_status=$(yq ".sprints[] | select(.id == \"$dep\") | .status" .ai/ledger.yaml 2>/dev/null)
          if [ "$dep_status" != "completed" ] && [ "$dep_status" != "redecomposed" ]; then
            all_met=false
            break
          fi
        done
        if [ "$all_met" = "true" ]; then
          target="$cid"
          break
        fi
      done
      if [ -z "$target" ]; then
        # Find a failed dependency and reset it for retry
        retry_dep=""
        for cid in $candidates; do
          deps=$(yq ".sprints[] | select(.id == \"$cid\") | .depends_on[]?" .ai/ledger.yaml 2>/dev/null)
          for dep in $deps; do
            dep_status=$(yq ".sprints[] | select(.id == \"$dep\") | .status" .ai/ledger.yaml 2>/dev/null)
            if [ "$dep_status" = "failed" ]; then
              retry_dep="$dep"
              break 2
            fi
          done
        done
        if [ -n "$retry_dep" ]; then
          now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
          yq -i "(.sprints[] | select(.id == \"$retry_dep\")).status = \"planned\" | (.sprints[] | select(.id == \"$retry_dep\")).updated_at = \"$now\"" .ai/ledger.yaml
          target="$retry_dep"
        else
          rm -f .ai/runner-last-failed-sprint.txt .ai/runner-total-failures.txt
          printf 'deps_blocked'
          exit 0
        fi
      fi
      printf '%s' "$target" > .ai/current_sprint_id.txt
      printf 'next-%s' "$target"

  agent no_ledger_exit
    label: "No Ledger Found"
    prompt:
      No .ai/ledger.yaml found. The sprint runner requires an existing ledger with planned sprints.

      To create one, run spec_to_sprints_yaml.dip with a spec file.

  agent deps_blocked_exit
    label: "Dependencies Blocked"
    max_turns: 1
    prompt:
      All remaining sprints have unmet dependencies — their depends_on sprints are not completed (they are failed, skipped, or still planned).

      Read .ai/ledger.yaml and report:
      1. Which sprints completed successfully
      2. Which sprints are blocked and what dependency they are waiting on
      3. Concrete next steps to unblock (e.g. re-run failed sprints manually, or re-plan)

      HARD CONSTRAINT: Do NOT write code. Do NOT create, modify, or delete any files. Your ONLY job is to report the blocked state.

  subgraph execute_sprint
    ref: sprint_exec_yaml_v2.dip

  tool report_progress
    label: "Report Progress"
    timeout: 10s
    command:
      set -eu
      total=$(yq '.sprints | length' .ai/ledger.yaml)
      done=$(yq '[.sprints[] | select(.status == "completed")] | length' .ai/ledger.yaml)
      skipped=$(yq '[.sprints[] | select(.status == "skipped")] | length' .ai/ledger.yaml)
      failed=$(yq '[.sprints[] | select(.status == "failed")] | length' .ai/ledger.yaml)
      remaining=$((total - done - skipped - failed))
      if [ "$total" -gt 0 ]; then
        pct=$(( (done + skipped) * 100 / total))
      else
        pct=0
      fi
      printf 'progress-%s-of-%s-%spct-failed-%s-remaining-%s' "$done" "$total" "$pct" "$failed" "$remaining"

  tool handle_failure
    label: "Handle Sprint Failure"
    timeout: 10s
    command:
      set -eu
      target=$(cat .ai/current_sprint_id.txt 2>/dev/null || echo "unknown")
      last_failed=$(cat .ai/runner-last-failed-sprint.txt 2>/dev/null || echo "none")
      total_failures=$(cat .ai/runner-total-failures.txt 2>/dev/null || echo "0")
      # Check if RecoveryManager requested redecomposition AND it matches current target
      if [ -f .ai/redecompose-request.yaml ]; then
        req_target=$(yq '.failed_sprint_id' .ai/redecompose-request.yaml 2>/dev/null || echo "")
        if [ "$req_target" = "$target" ]; then
          printf 'redecompose-%s' "$target"
          exit 0
        else
          # Stale request from a different sprint — discard it
          rm -f .ai/redecompose-request.yaml
        fi
      fi
      total_failures=$((total_failures + 1))
      printf '%s' "$total_failures" > .ai/runner-total-failures.txt
      if [ "$target" = "$last_failed" ]; then
        now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
        yq -i "(.sprints[] | select(.id == \"$target\")).status = \"failed\" | (.sprints[] | select(.id == \"$target\")).updated_at = \"$now\"" .ai/ledger.yaml
        rm -f .ai/runner-last-failed-sprint.txt
        if [ "$total_failures" -ge 10 ]; then
          printf 'budget-exhausted-%s-total-failures' "$total_failures"
        else
          printf 'skipped-%s-moving-on' "$target"
        fi
      else
        printf '%s' "$target" > .ai/runner-last-failed-sprint.txt
        if [ "$total_failures" -ge 10 ]; then
          printf 'budget-exhausted-%s-total-failures' "$total_failures"
        else
          printf 'retry-%s-attempt-2' "$target"
        fi
      fi

  tool snapshot_before_redecompose
    label: "Snapshot Ledger"
    timeout: 10s
    command:
      set -eu
      # Save ledger state and completed count before redecompose subgraph runs
      cp .ai/ledger.yaml .ai/ledger-pre-redecompose.yaml
      completed=$(yq '[.sprints[] | select(.status == "completed")] | length' .ai/ledger.yaml)
      printf '%s' "$completed" > .ai/ledger-pre-redecompose-count.txt
      printf 'snapshot-saved-%s-completed' "$completed"

  tool prepare_redecompose
    label: "Prepare Redecompose"
    timeout: 15s
    command:
      set -eu
      if [ ! -f .ai/redecompose-request.yaml ]; then
        printf 'no-request'
        exit 0
      fi
      target=$(yq '.failed_sprint_id' .ai/redecompose-request.yaml)
      # Calculate next available ID — handle non-numeric IDs gracefully
      max_id=$(yq '.sprints[-1].id' .ai/ledger.yaml)
      # Strip any non-digit suffix to get the numeric base
      numeric_base=$(printf '%s' "$max_id" | sed 's/[^0-9].*$//')
      if [ -z "$numeric_base" ]; then
        numeric_base="099"
      fi
      next_id=$(printf '%03d' $((10#$numeric_base + 1)))
      yq -i ".next_available_id = \"$next_id\"" .ai/redecompose-request.yaml
      # Calculate existing sprint count
      count=$(yq '.sprints | length' .ai/ledger.yaml)
      yq -i ".existing_sprint_count = $count" .ai/redecompose-request.yaml
      printf 'ready-to-redecompose-%s-next-%s' "$target" "$next_id"

  subgraph redecompose_sprint
    ref: spec_to_sprints_yaml_v2.dip

  tool validate_ledger_after_redecompose
    label: "Validate Ledger Integrity"
    timeout: 15s
    command:
      set -eu
      if [ ! -f .ai/ledger-pre-redecompose-count.txt ]; then
        printf 'no-snapshot-skipping'
        exit 0
      fi
      expected=$(cat .ai/ledger-pre-redecompose-count.txt)
      actual=$(yq '[.sprints[] | select(.status == "completed")] | length' .ai/ledger.yaml)
      if [ "$actual" -lt "$expected" ]; then
        # Ledger was corrupted — completed sprints disappeared. Restore from snapshot.
        cp .ai/ledger-pre-redecompose.yaml .ai/ledger.yaml
        rm -f .ai/ledger-pre-redecompose.yaml .ai/ledger-pre-redecompose-count.txt
        printf 'restored-ledger-%s-completed-were-%s' "$expected" "$actual"
      else
        rm -f .ai/ledger-pre-redecompose.yaml .ai/ledger-pre-redecompose-count.txt
        printf 'ledger-ok-%s-completed' "$actual"
      fi

  tool splice_ledger
    label: "Splice Redecomposed Sprints"
    timeout: 30s
    command:
      set -eu
      if [ ! -f .ai/redecompose-result.yaml ]; then
        printf 'no-result'
        exit 1
      fi
      original_id=$(yq '.original_sprint_id' .ai/redecompose-result.yaml)
      now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      # Read count before cleanup
      new_count=$(yq '.new_sprint_ids | length' .ai/redecompose-result.yaml)
      # Mark original sprint as redecomposed
      yq -i "(.sprints[] | select(.id == \"$original_id\")).status = \"redecomposed\" | (.sprints[] | select(.id == \"$original_id\")).updated_at = \"$now\"" .ai/ledger.yaml
      # Rewrite dependents
      for dep_id in $(yq '.dependents_to_rewrite | keys | .[]' .ai/redecompose-result.yaml 2>/dev/null); do
        old_dep=$(yq ".dependents_to_rewrite.\"$dep_id\".old_dep" .ai/redecompose-result.yaml)
        # Remove old dep and add new deps
        yq -i "(.sprints[] | select(.id == \"$dep_id\")).depends_on -= [\"$old_dep\"]" .ai/ledger.yaml
        for new_dep in $(yq ".dependents_to_rewrite.\"$dep_id\".new_deps[]" .ai/redecompose-result.yaml); do
          yq -i "(.sprints[] | select(.id == \"$dep_id\")).depends_on += [\"$new_dep\"]" .ai/ledger.yaml
        done
        # Also update the sprint YAML if it exists
        dep_yaml=".ai/sprints/SPRINT-${dep_id}.yaml"
        if [ -f "$dep_yaml" ]; then
          yq -i ".depends_on -= [\"$old_dep\"]" "$dep_yaml"
          for new_dep in $(yq ".dependents_to_rewrite.\"$dep_id\".new_deps[]" .ai/redecompose-result.yaml); do
            yq -i ".depends_on += [\"$new_dep\"]" "$dep_yaml"
          done
        fi
      done
      # Clean up transient files
      rm -f .ai/redecompose-request.yaml .ai/redecompose-result.yaml
      printf 'spliced-%s-redecomposed-into-%s-sprints' "$original_id" "$new_count"

  tool report_redecompose
    label: "Report Redecomposition"
    timeout: 10s
    command:
      set -eu
      total=$(yq '.sprints | length' .ai/ledger.yaml)
      done=$(yq '[.sprints[] | select(.status == "completed")] | length' .ai/ledger.yaml)
      redecomposed=$(yq '[.sprints[] | select(.status == "redecomposed")] | length' .ai/ledger.yaml)
      remaining=$((total - done - redecomposed))
      printf 'redecompose-complete-total-%s-done-%s-remaining-%s' "$total" "$done" "$remaining"

  agent failure_summary
    label: "Failure Summary"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: high
    prompt:
      The sprint runner has exhausted its failure budget (3 total failures across all sprints).

      Read .ai/ledger.yaml. Report:
      1. Which sprints completed successfully
      2. Which sprints failed and were skipped
      3. Which sprints remain planned
      4. Whether the project is in a usable partial state
      5. Concrete next steps for recovery

  edges
    Start -> check_yq
    check_yq -> check_ledger           when ctx.tool_stdout = yq-ok         label: yq_ok
    check_yq -> yq_missing             when ctx.tool_stdout = yq-not-found  label: yq_missing
    check_yq -> Exit
    yq_missing -> Exit
    check_ledger -> Exit               when ctx.tool_stdout = all_done       label: all_done
    check_ledger -> no_ledger_exit     when ctx.tool_stdout = no_ledger     label: no_ledger
    check_ledger -> deps_blocked_exit  when ctx.tool_stdout = deps_blocked  label: deps_blocked
    check_ledger -> execute_sprint     when ctx.tool_stdout startswith next- label: next_sprint
    check_ledger -> Exit
    no_ledger_exit -> Exit
    deps_blocked_exit -> Exit
    execute_sprint -> handle_failure   when ctx.tool_stdout startswith failed-  label: sprint_failed
    execute_sprint -> report_progress  when ctx.outcome = success               label: sprint_done
    execute_sprint -> handle_failure
    report_progress -> check_ledger    restart: true
    handle_failure -> check_ledger          when ctx.tool_stdout startswith retry-        label: retry_sprint    restart: true
    handle_failure -> check_ledger          when ctx.tool_stdout startswith skipped-      label: skip_continue   restart: true
    handle_failure -> failure_summary       when ctx.tool_stdout startswith budget-       label: budget_blown
    handle_failure -> snapshot_before_redecompose  when ctx.tool_stdout startswith redecompose-  label: redecompose
    handle_failure -> failure_summary
    snapshot_before_redecompose -> prepare_redecompose
    prepare_redecompose -> redecompose_sprint                when ctx.tool_stdout startswith ready-   label: prepared
    prepare_redecompose -> check_ledger                     when ctx.tool_stdout = no-request        label: stale_request  restart: true
    prepare_redecompose -> check_ledger                     restart: true
    redecompose_sprint -> validate_ledger_after_redecompose  when ctx.outcome = success  label: redecompose_done
    redecompose_sprint -> validate_ledger_after_redecompose  when ctx.outcome = fail     label: redecompose_failed
    redecompose_sprint -> validate_ledger_after_redecompose
    validate_ledger_after_redecompose -> splice_ledger      when ctx.tool_stdout startswith ledger-ok     label: ledger_intact
    validate_ledger_after_redecompose -> splice_ledger      when ctx.tool_stdout startswith restored-    label: ledger_restored
    validate_ledger_after_redecompose -> check_ledger       restart: true
    splice_ledger -> report_redecompose     when ctx.outcome = success  label: spliced
    splice_ledger -> check_ledger           when ctx.outcome = fail     label: splice_failed  restart: true
    splice_ledger -> report_redecompose
    report_redecompose -> check_ledger       restart: true
    failure_summary -> Exit
