digraph SpecToDip {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];
  Start [label="Start", shape="Mdiamond"];
  Done [label="Done", shape="Msquare"];
  no_spec_exit [label="No Spec Found", shape="box"];
  find_spec [label="Find Spec File", shape="parallelogram"];
  find_plan [label="Find Superpowers Plan", shape="parallelogram"];
  analyze_spec [label="Analyze Spec", shape="box"];
  check_analysis [label="Check Analysis File", shape="parallelogram"];
  identify_perspectives [label="Identify Perspectives", shape="box"];
  gen_parallel [label="gen_parallel", shape="component"];
  gen_claude [label="Claude Generation", shape="box"];
  gen_gpt [label="GPT Generation", shape="box"];
  gen_gemini [label="Gemini Generation", shape="box"];
  gen_join [label="gen_join", shape="tripleoctagon"];
  validate_all [label="Validate All Candidates", shape="parallelogram"];
  fix_claude [label="Fix Claude Candidate", shape="box"];
  fix_gpt [label="Fix GPT Candidate", shape="box"];
  fix_gemini [label="Fix Gemini Candidate", shape="box"];
  fix_all [label="Fix All Candidates", shape="box"];
  compliance_parallel [label="compliance_parallel", shape="component"];
  compliance_claude [label="Claude Compliance Check", shape="box"];
  compliance_gpt [label="GPT Compliance Check", shape="box"];
  compliance_gemini [label="Gemini Compliance Check", shape="box"];
  compliance_join [label="compliance_join", shape="tripleoctagon"];
  review_parallel [label="review_parallel", shape="component"];
  review_structure [label="Structure Review", shape="box"];
  review_compliance [label="Compliance Review", shape="box"];
  review_robustness [label="Robustness Review", shape="box"];
  review_efficiency [label="Efficiency Review", shape="box"];
  review_prompts [label="Prompt Quality Review", shape="box"];
  review_join [label="review_join", shape="tripleoctagon"];
  synthesize_scores [label="Synthesize Tournament Results", shape="box"];
  human_select [label="Tournament results are in. Pick winner, merge best elements, or rework?", shape="hexagon"];
  copy_winner [label="Copy Winner to Final", shape="box"];
  merge_candidates [label="Merge Best Elements", shape="box"];
  validate_merge [label="Validate Merged Output", shape="parallelogram"];
  fix_merge [label="Fix Merged Output", shape="box"];
  rework_feedback [label="What needs to change? Provide specific feedback.", shape="hexagon"];
  rework_analysis [label="Incorporate Rework Feedback", shape="box"];
  final_validate [label="Final Validation Suite", shape="parallelogram"];
  final_fix [label="Fix Final Issues", shape="box"];
  simmer_judge [label="Simmer Judge", shape="box"];
  simmer_refine [label="Simmer Refine", shape="box"];
  simmer_revalidate [label="Simmer Revalidate", shape="parallelogram"];
  fresh_eyes [label="Fresh-Eyes Review", shape="box"];
  fresh_eyes_revalidate [label="Fresh-Eyes Revalidate", shape="parallelogram"];
  publish_output [label="Publish Final Pipeline", shape="box"];

  Start -> find_spec;
  find_spec -> find_plan [condition="tool_stdout != no_spec_found", label="tool_stdout != no_spec_found"];
  find_spec -> no_spec_exit [condition="tool_stdout = no_spec_found", label="tool_stdout = no_spec_found"];
  find_plan -> analyze_spec;
  no_spec_exit -> Done;
  analyze_spec -> check_analysis;
  check_analysis -> identify_perspectives [condition="tool_stdout = analysis_ok", label="tool_stdout = analysis_ok"];
  check_analysis -> analyze_spec [condition="tool_stdout = analysis_missing", label="tool_stdout = analysis_missing", restart="true", style="dashed"];
  identify_perspectives -> gen_parallel;
  gen_parallel -> gen_claude;
  gen_parallel -> gen_gpt;
  gen_parallel -> gen_gemini;
  gen_claude -> gen_join;
  gen_gpt -> gen_join;
  gen_gemini -> gen_join;
  gen_join -> validate_all;
  validate_all -> compliance_parallel [condition="tool_stdout = all_valid", label="tool_stdout = all_valid"];
  validate_all -> fix_claude [condition="tool_stdout = claude_errors", label="tool_stdout = claude_errors"];
  validate_all -> fix_gpt [condition="tool_stdout = gpt_errors", label="tool_stdout = gpt_errors"];
  validate_all -> fix_gemini [condition="tool_stdout = gemini_errors", label="tool_stdout = gemini_errors"];
  validate_all -> fix_all [condition="tool_stdout = multiple_errors", label="tool_stdout = multiple_errors"];
  fix_claude -> validate_all [restart="true", style="dashed"];
  fix_gpt -> validate_all [restart="true", style="dashed"];
  fix_gemini -> validate_all [restart="true", style="dashed"];
  fix_all -> validate_all [restart="true", style="dashed"];
  compliance_parallel -> compliance_claude;
  compliance_parallel -> compliance_gpt;
  compliance_parallel -> compliance_gemini;
  compliance_claude -> compliance_join;
  compliance_gpt -> compliance_join;
  compliance_gemini -> compliance_join;
  compliance_join -> review_parallel;
  review_parallel -> review_structure;
  review_parallel -> review_compliance;
  review_parallel -> review_robustness;
  review_parallel -> review_efficiency;
  review_parallel -> review_prompts;
  review_structure -> review_join;
  review_compliance -> review_join;
  review_robustness -> review_join;
  review_efficiency -> review_join;
  review_prompts -> review_join;
  review_join -> synthesize_scores;
  synthesize_scores -> human_select;
  human_select -> copy_winner [label="[P] Pick winner"];
  human_select -> merge_candidates [label="[M] Merge best elements"];
  human_select -> rework_feedback [label="[R] Rework with feedback"];
  copy_winner -> final_validate;
  merge_candidates -> validate_merge;
  validate_merge -> fix_merge [condition="tool_stdout = errors", label="tool_stdout = errors"];
  fix_merge -> validate_merge [restart="true", style="dashed"];
  validate_merge -> final_validate [condition="tool_stdout = valid", label="tool_stdout = valid"];
  rework_feedback -> rework_analysis;
  rework_analysis -> gen_parallel [restart="true", style="dashed"];
  final_validate -> final_fix [condition="tool_stdout = grade_C", label="tool_stdout = grade_C"];
  final_validate -> final_fix [condition="tool_stdout = grade_F", label="tool_stdout = grade_F"];
  final_fix -> final_validate [restart="true", style="dashed"];
  final_validate -> simmer_judge [condition="tool_stdout = grade_A", label="tool_stdout = grade_A"];
  final_validate -> simmer_judge [condition="tool_stdout = grade_B", label="tool_stdout = grade_B"];
  simmer_judge -> fresh_eyes [condition="outcome = success", label="outcome = success"];
  simmer_judge -> simmer_refine [condition="outcome = fail", label="outcome = fail"];
  simmer_refine -> simmer_revalidate;
  simmer_revalidate -> simmer_judge [condition="tool_stdout = valid", label="tool_stdout = valid", restart="true", style="dashed"];
  simmer_revalidate -> simmer_refine [condition="tool_stdout = errors", label="tool_stdout = errors", restart="true", style="dashed"];
  fresh_eyes -> publish_output [condition="outcome = success", label="outcome = success"];
  fresh_eyes -> fresh_eyes_revalidate [condition="outcome = fail", label="outcome = fail"];
  fresh_eyes_revalidate -> fresh_eyes [restart="true", style="dashed"];
  publish_output -> Done;
}
